<customwindow:CustomWindow xmlns="https://github.com/avaloniaui"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:customwindow="clr-namespace:ForkPlus.Avalonia"
                           xmlns:local="clr-namespace:ForkPlus.Avalonia.QuickLaunch"
                           xmlns:controls="clr-namespace:ForkPlus.Avalonia.Controls"
                           x:Class="ForkPlus.Avalonia.QuickLaunch.QuickLaunchWindow"
                           Width="620" Height="370"
                           ShowHeader="False"
                           CanResize="False"
                           WindowStartupLocation="CenterScreen"
                           BorderBrush="{DynamicResource WindowBorderBrush}"
                           BorderThickness="1"
                           Background="{DynamicResource BackgroundBrush}">
    <!--
        QuickLaunchWindow.axaml: 命令面板窗口（spike 简化版）。
        WPF 源对照: src/ForkPlus/UI/QuickLaunch/QuickLaunchWindow.xaml (174 行)
        Avalonia 版差异:
          1. WPF CustomWindow (ForkPlus.UI) -> Avalonia CustomWindow (ForkPlus.Avalonia)
          2. WPF ResizeMode="NoResize" -> Avalonia CanResize="False"
          3. WPF DataTemplateKey + ItemTemplate(ContentControl) -> Avalonia ListBox.DataTemplates (DataType 匹配)
          4. WPF Visibility -> Avalonia IsVisible (bool)
          5. WPF Image.Source -> Avalonia Image.Source (IImage)
          6. WPF FuzzyHighlightableTextBlock.FuzzySearchString -> Avalonia Query (spike 改名)
          7. WPF MouseUp -> Avalonia PointerReleased
          8. WPF LayoutTransform 跳过 (spike 简化)
          9. WPF ItemContainerStyle + ControlTemplate 跳过 (spike 用默认 ListBoxItem 样式)
         10. WPF DataTemplate.Triggers (IsSelected 切换图标/前景色) 跳过 (spike 简化)
         11. XML 注释不含双连字符 (task spec 要求)
        DataTemplate 顺序: 特定类型在前 (HeaderCommandProviderItem, RepositoryInfoItem),
                          基类 CommandProviderItem 在后 (匹配 PaletteCommandItem/ReferenceItem 等派生类)
    -->
    <Grid RowDefinitions="Auto,Auto,*" Margin="0,10,0,0">
        <!-- Row 1: 搜索框 (Border + StackPanel + SearchIcon + CommandTextBox) -->
        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,7">
                <Image Source="{DynamicResource SearchIcon}" Margin="0,3,6,0" Width="16" />
                <controls:CommandTextBox FontSize="16" BorderThickness="0" x:Name="CommandTextBox" />
            </StackPanel>
        </Border>
        <!-- Row 2: ListBox (命令面板列表) -->
        <ListBox Grid.Row="2" BorderThickness="0" SelectionMode="Single" Margin="0"
                 x:Name="RepositoriesListBox"
                 PointerReleased="RepositoriesListBox_PointerReleased">
            <ListBox.DataTemplates>
                <!-- HeaderCommandProviderItem: 分组标题 (特定类型, 优先匹配) -->
                <DataTemplate DataType="local:HeaderCommandProviderItem">
                    <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
                        <TextBlock DockPanel.Dock="Left" FontSize="13.5" Margin="0,0,0,4" FontWeight="Medium" VerticalAlignment="Bottom"
                                   Text="{Binding Title}" />
                    </DockPanel>
                </DataTemplate>
                <!-- RepositoryInfoItem: 仓库条目 (特定类型, 优先匹配) -->
                <DataTemplate DataType="local:RepositoryInfoItem">
                    <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
                        <Image DockPanel.Dock="Left" Height="14" Width="14" VerticalAlignment="Bottom" Margin="0,0,4,4"
                               Source="{Binding Icon}" />
                        <controls:FuzzyHighlightableTextBlock DockPanel.Dock="Left" FontSize="14" Margin="0,0,0,4" VerticalAlignment="Bottom"
                                                              Text="{Binding Title}" Query="{Binding FuzzySearchString}" />
                        <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="4,0,4,4" VerticalAlignment="Bottom"
                                   IsVisible="{Binding DescriptionVisibility}" />
                        <controls:FuzzyHighlightableTextBlock FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Bottom" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"
                                                              Text="{Binding SecondaryTitle}" Query="{Binding FuzzySearchString}" />
                    </DockPanel>
                </DataTemplate>
                <!-- CommandProviderItem: 基类模板 (匹配 PaletteCommandItem/ReferenceItem/RemoteItem/WorkspaceItem/RepositoryFileItem 等派生类) -->
                <DataTemplate DataType="local:CommandProviderItem">
                    <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
                        <Image DockPanel.Dock="Left" Height="14" Width="14" VerticalAlignment="Bottom" Margin="0,0,4,4"
                               Source="{Binding Icon}" />
                        <controls:FuzzyHighlightableTextBlock DockPanel.Dock="Left" FontSize="14" Margin="0,0,0,4" VerticalAlignment="Bottom"
                                                              Text="{Binding Title}" Query="{Binding FuzzySearchString}" />
                        <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="4,0,4,4" VerticalAlignment="Bottom"
                                   IsVisible="{Binding DescriptionVisibility}" />
                        <controls:FuzzyHighlightableTextBlock FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Bottom" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"
                                                              Text="{Binding SecondaryTitle}" Query="{Binding FuzzySearchString}" />
                    </DockPanel>
                </DataTemplate>
            </ListBox.DataTemplates>
        </ListBox>
    </Grid>
</customwindow:CustomWindow>
