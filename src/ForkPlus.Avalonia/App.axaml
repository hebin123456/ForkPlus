<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.App"
             RequestedThemeVariant="Default">
    <!--
        Phase 1/2.5：Avalonia Application 资源与主题。

        RequestedThemeVariant="Default" 跟随系统主题；AvaloniaThemeService.ApplyTheme()
        会运行时切换为 Light/Dark（按 ThemeType.IsDarkBase 二元映射）。

        Application.Styles：
          - FluentTheme：Avalonia 内置 Fluent 主题（兜底，所有控件默认样式）
          - Avalonia.Fonts.Inter 的 Inter 字体（WithInterFont() 已在 Program.cs 启用）

        Application.Resources.MergedDictionaries：
          - Geometries.axaml：8 个 Geometry 路径资源（Sidebar/Account 图标）
          - Focusvisual.axaml：焦点边框样式
          - Images.Light/Dark.axaml：242 个 Bitmap 资源（运行时按主题切换由 AvaloniaThemeService 处理）
          - Colors.{Skin}.axaml + Brushes.axaml：运行时由 AvaloniaThemeService 动态加载

        后续 Phase 3 起，会在这里追加从 WPF 工程按需迁移的自定义 Style
        （Button/Combobox/Listview 等控件样式，按 UserControl 迁移需要逐步加入）。
    -->
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ForkPlus.Avalonia/Themes/Styles/Geometries.axaml" />
                <ResourceInclude Source="avares://ForkPlus.Avalonia/Themes/Styles/Focusvisual.axaml" />
                <ResourceInclude Source="avares://ForkPlus.Avalonia/Themes/Styles/Images.Light.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
