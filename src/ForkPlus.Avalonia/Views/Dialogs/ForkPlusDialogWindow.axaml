<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ForkPlus.Avalonia.Views.Dialogs.ForkPlusDialogWindow"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        MinWidth="240" MinHeight="120">
    <!--
        Phase 4.0：Avalonia 版 ForkPlusDialogWindow 简化基类。

        对照 WPF 工程 src/ForkPlus/UI/Dialogs/ForkPlusDialogWindow.cs（770 行）：
          - 继承自 CustomWindow（自定义标题栏）
          - 命令预览区域（动态生成 Grid + ScrollViewer）
          - ForkPlusDialogFooter（Submit/Cancel 按钮 + 状态图标 + BusyIndicator）
          - Logo 图标（左上角 64x64）
          - 警告图标（可选）
          - 主题切换（ApplicationThemeChanged 事件）
          - 焦点管理（Loaded 时 MoveFocus 到第一个控件）
          - 模态对话框行为（DialogResult）

        本简化版实现：
          - 继承自 Avalonia Controls.Window（用系统标题栏）
          - Grid 3 行布局：Header / Content / Footer
          - Header：DialogTitleTextBlock + DialogDescriptionTextBlock
          - Content：ContentControl 占位（子类 XAML 内容）
          - Footer：SubmitButton + CancelButton（默认显示）
          - Escape 键关闭（OnKeyDown）
          - SubmitButton.IsEnabled 绑定 IsSubmitAllowed

        暂不实现（依赖未迁移的子系统）：
          - CustomWindow 自定义标题栏（依赖 WindowChrome / Win32 API）
          - 命令预览区域（GetCommandPreview 虚方法）
          - Logo 图标
          - 警告图标
          - 主题切换（依赖 Theme / NotificationCenter）
          - 焦点管理（Avalonia 用 Keyboard.Focus）
          - ForkPlusDialogFooter 自定义控件（用 StackPanel + Button 替代）
          - 模态对话框行为（Avalonia 用 ShowDialog<T>()）
    -->
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Row 0: Header（DialogTitle + DialogDescription）-->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <TextBlock Name="DialogTitleTextBlock"
                       Text="[Dialog Title]"
                       FontSize="15" FontWeight="Medium" />
            <TextBlock Name="DialogDescriptionTextBlock"
                       Text=""
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                       Margin="0,2,0,0"
                       IsVisible="False" />
        </StackPanel>

        <!-- Row 1: Content（子类 XAML 内容会插入到这里）-->
        <ContentControl Grid.Row="1" Name="DialogContentContainer" />

        <!-- Row 2: Footer（Submit + Cancel 按钮）-->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Name="SubmitButton"
                    Content="OK"
                    Click="SubmitButton_Click"
                    Margin="0,0,8,0"
                    MinWidth="75" />
            <Button Name="CancelButton"
                    Content="Cancel"
                    Click="CancelButton_Click"
                    MinWidth="75" />
        </StackPanel>
    </Grid>
</Window>
