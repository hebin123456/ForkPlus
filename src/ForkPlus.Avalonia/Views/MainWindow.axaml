<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ForkPlus.Avalonia.ViewModels"
        xmlns:views="using:ForkPlus.Avalonia.Views"
        xmlns:userControls="using:ForkPlus.Avalonia.Views.UserControls"
        xmlns:platform="clr-namespace:Avalonia.Platform;assembly=Avalonia.Controls"
        x:Class="ForkPlus.Avalonia.Views.MainWindow"
        Width="1000" Height="600"
        MinWidth="650" MinHeight="400"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="{x:Static platform:ExtendClientAreaChromeHints.NoChrome}"
        ExtendClientAreaTitleBarHeightHint="40"
        SystemDecorations="Full"
        WindowState="Normal"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        Activated="MainWindow_Activated">
    <!--
        Phase 3.1/3.2：Avalonia 版 MainWindow 骨架 + ToolbarUserControl。

        对照 WPF 工程 src/ForkPlus/UI/MainWindow.xaml：
          - WPF 用 ui:CustomWindow（自定义标题栏 + 系统按钮 + Menu 占位 + 通知 Popup）
          - Avalonia 用 ExtendClientAreaToDecorationsHint + ExtendClientAreaChromeHints=PreferNone
            实现等价的自定义标题栏（让客户端区域延伸到标题栏，系统按钮自绘）

        本 spike 版暂不迁移：
          - ClosableTabControl + TabManager（Phase 3.4，需要先迁移 RepositoryUserControl）
          - MainWindowMenuManager（动态菜单构造，独立子任务）
          - NotificationManagerUserControl（通知中心 Popup，Phase 3.x 后期）
          - 自动后台 fetch / 更新检查 / 仓库状态管理（Phase 3.x 后期）

        本 spike 版验证：
          - Avalonia 自定义标题栏（ExtendClientAreaToDecorationsHint）能正常工作
          - 窗口生命周期事件（Loaded/Closing/Activated）能触发
          - 系统按钮（最小化/最大化/关闭）能响应
          - 标题栏可拖动
          - 主题切换按钮（验证 IThemeService 工作）
          - Phase 3.2：ToolbarUserControl 三列布局正确显示
    -->
    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Row 0: 自定义标题栏（替代 WPF CustomWindow 的 ControlTemplate）-->
        <Border Grid.Row="0" Background="{DynamicResource Window.TitleBar.Background}"
                Height="40" Padding="8,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Col 0: 应用图标 + 标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/ForkPlusIcon.png" Width="20" Height="20" />
                    <TextBlock Name="TitleTextBlock" VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                </StackPanel>

                <!-- Col 1: 中间空白（可拖动区域）-->
                <Border Grid.Column="1" Background="Transparent" />

                <!-- Col 2: 主题切换 + 系统按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <Button Name="ThemeToggleButton" Content="Theme"
                            Click="ThemeToggle_Click"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <Button Name="MinimizeButton" Content="—"
                            Click="MinimizeButton_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <Button Name="MaximizeButton" Content="▢"
                            Click="MaximizeButton_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource ThemeForegroundBrush}" />
                    <Button Name="CloseButton" Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource ThemeForegroundBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Phase 3.2 ToolbarUserControl（三列布局：左操作区/状态区/右操作区）
             ToolbarUserControl 需 DI 注入 IThemeService，故不在 XAML 中实例化。
             改为在 MainWindow_Loaded 中通过 _serviceProvider 创建并装入此 ContentControl。-->
        <ContentControl Grid.Row="1" Name="ToolbarContainer" />

        <!-- Row 1b: Phase 4.0 MainMenu（对照 WPF ControlTemplate 中的 PART_MainMenu）
             由 MainWindowMenuManager 在 Loaded 时动态构造 File/View/Repository/Window/Help 5 个根菜单项。
             spike 版简化：用 Avalonia.Controls.Menu，菜单项由 MainWindowMenuManager 动态创建。-->
        <Menu Grid.Row="1" Name="MainMenu" IsVisible="False" />

        <!-- Row 2: 内容区（Phase 3.13 起装入 RepositoryUserControl，
             对照 WPF MainWindow.xaml 的 ClosableTabControl。
             spike 阶段简化为单个 RepositoryUserControl，未来 Phase 3.x 后期会接入 TabManager）-->
        <ContentControl Grid.Row="2"
                        Name="MainContentContainer"
                        Background="{DynamicResource ThemeBackgroundBrush}" />
    </Grid>
</Window>
