<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionFileTreeUserControl">
    <!--
        对照 WPF src/ForkPlus/UI/UserControls/RevisionFileTreeUserControl.xaml（46 行）：
          - Grid 2 列：
            Col 0 (MinWidth=220 MaxWidth=850): MultiselectionTreeView (FilesTreeView)
                          自定义 TreeView，含 ContextMenu
            Col 1 (*): FileContentControl 自定义控件
            GridSplitter (Col 0 右对齐, Style=VerticalGridSplitter)
          - Resources：DataTemplate for RevisionFileTreeViewItem
            （Grid 2 列: 14x14 Image(FileTypeIcon) + TextBlock(Title, TextTrimming=CharacterEllipsis)）

        装入路径：RevisionDetailsUserControl.axaml Row 2 → RevisionFileTreeUserControl

        Avalonia 适配：
          - WPF MultiselectionTreeView → 原生 TreeView + TreeDataTemplate
          - WPF RevisionFileTreeViewItem : MultiselectionTreeViewItem → POCO
          - WPF FileContentControl 自定义控件 → ContentControl 占位
          - WPF Image PNG FileTypeIcon → emoji TextBlock（spike 简化）
          - WPF MouseDoubleClick → DoubleTapped
          - WPF ContextMenu → Avalonia ContextMenu（spike 空菜单占位）
    -->
    <UserControl.DataTemplates>
        <TreeDataTemplate DataType="uc:RevisionFileTreeViewItem"
                          ItemsSource="{Binding Children}">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{Binding IconEmoji}"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center" />
            </Grid>
        </TreeDataTemplate>
    </UserControl.DataTemplates>

    <!-- 对照 WPF：<ColumnDefinition MinWidth="220" MaxWidth="850" /> + <ColumnDefinition />
         列宽约束必须挂在 ColumnDefinition 上，GridSplitter 拖动时才真正限制列宽 -->
    <Grid Name="ContainerGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="220" MaxWidth="850" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Col 0: FilesTreeView（对照 WPF MultiselectionTreeView） -->
        <TreeView Grid.Column="0"
                  Name="FilesTreeView"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0,0,1,0"
                  BorderBrush="{DynamicResource BorderBrush}"
                  DoubleTapped="FilesTreeView_DoubleTapped">
            <TreeView.ContextMenu>
                <ContextMenu />
            </TreeView.ContextMenu>
        </TreeView>

        <!-- Col 1: FileContentControl 占位（对照 WPF FileContentControl 自定义控件） -->
        <ContentControl Grid.Column="1"
                        Name="FileContentControl"
                        Background="{DynamicResource BackgroundBrush}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <TextBlock Text="(select a file to view content)"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryLabelBrush}"
                       Margin="8,4" />
        </ContentControl>

        <!-- GridSplitter（对照 WPF Style=VerticalGridSplitter, HAlign=Right） -->
        <GridSplitter Grid.Column="0"
                      Name="GridSplitter"
                      Classes="vertical-grid-splitter"
                      HorizontalAlignment="Right"
                      ResizeDirection="Columns" />
    </Grid>
</UserControl>
