<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionFileTreeUserControl">
    <!--
        Avalonia 版 RevisionFileTreeUserControl（spike 简化升级版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionFileTreeUserControl.xaml（46 行）：
          - Grid 2 列：
            Col 0 (MinWidth=220 MaxWidth=850): MultiselectionTreeView (FilesTreeView)
                          自定义 TreeView，含 ContextMenu
            Col 1 (*): FileContentControl 自定义控件
            GridSplitter (Col 0 右对齐)
          - Resources：DataTemplate for RevisionFileTreeViewItem（Grid 2 列: Image + TextBlock）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionFileTreeUserControl.xaml.cs（360 行）：
          - 公共方法：Refresh(Sha sha) / ShowRevisionDetails(string filePath)
          - 公共属性：RevisionDetailsUserControl（反向引用）
          - 异步 Task：GetRevisionFileTreeGitCommand（git ls-tree）+ UpdateFileDetails
          - 3 个 CommandBindings + 右键菜单 ~100 行 + _pendingFilePath 竞态处理

        Avalonia 版差异：
          - WPF MultiselectionTreeView → 原生 TreeView + HierarchicalDataTemplate
          - WPF RevisionFileTreeViewItem : MultiselectionTreeViewItem → POCO（RevisionFileTreeViewItem.cs）
          - WPF FileContentControl 自定义控件 → ContentControl 占位
          - WPF Image PNG 图标 → emoji TextBlock
          - WPF MouseDoubleClick → DoubleTapped

        spike 简化：
          - 用 TreeView 显示文件树，TreeViewItem 绑定 RevisionFileTreeViewItem POCO
          - Refresh(sha) 用 ObservableCollection 填充 TreeView 根节点
          - ShowRevisionDetails(filePath) 展开到指定文件
          - 右键菜单 / CommandBindings / git ls-tree 异步加载暂不实现
    -->
    <UserControl.DataTemplates>
        <TreeDataTemplate DataType="uc:RevisionFileTreeViewItem"
                          ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding IconEmoji}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding Title}" />
            </StackPanel>
        </TreeDataTemplate>
    </UserControl.DataTemplates>

    <Grid Name="ContainerGrid"
          ColumnDefinitions="220,Auto,*">

        <!-- Col 0: FilesTreeView（绑定 RevisionFileTreeViewItem POCO）-->
        <TreeView Grid.Column="0"
                  Name="FilesTreeView"
                  Background="{DynamicResource ThemeBackgroundBrush}"
                  BorderThickness="0,0,1,0"
                  BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                  DoubleTapped="FilesTreeView_DoubleTapped" />

        <!-- Col 1: GridSplitter -->
        <GridSplitter Grid.Column="1"
                      Name="FileTreeGridSplitter"
                      Width="4"
                      ResizeDirection="Columns"
                      Background="{DynamicResource ThemeBorderMidBrush}"
                      HorizontalAlignment="Stretch" />

        <!-- Col 2: FileContentControl 占位 -->
        <ContentControl Grid.Column="2"
                        Name="FileContentControl"
                        Background="{DynamicResource ThemeBackgroundBrush}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="(select a file to view content)"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                       Margin="8,4" />
        </ContentControl>
    </Grid>
</UserControl>
