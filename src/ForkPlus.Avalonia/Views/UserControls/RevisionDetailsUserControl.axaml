<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionDetailsUserControl">
    <!--
        Avalonia 版 RevisionDetailsUserControl（完全对照 WPF 6b4cbff~1）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml（40 行）：
          - controls:ContentContainer（自定义控件）→ spike 用 Grid 替代
          - Grid 3 行：
            Row 0 (Auto): TabHeaderContainer (Background=PanelBackgroundBrush)
              - Row 0 (30): 3 个 RadioButton (Commit/Changes/FileTree) Style=RevisionDetailsBarButton +
                            Col 4 (40) ShowRevisionInSeparateWindowButton (22x22, OpenInSeparateWindowIcon)
              - Row 1 (1.5): Canvas + IndicatorBorder (Background=SystemAccentBrush, 动画 Canvas.Left)
              - Col 0/1/2 (Auto) / Col 3 (*) / Col 4 (40)
            Row 1 (Auto): RevisionsHeaderUserControl (BorderBrush=BorderBrush)
            Row 2 (*): Border (BorderThickness=0,1,0,0, BorderBrush=BorderBrush, UseLayoutRounding=True)
              - Grid 包 3 个子 UserControl：
                - RevisionSummaryUserControl (默认可见)
                - RevisionChangesUserControl (默认 Collapsed)
                - RevisionFileTreeUserControl (默认 Collapsed)

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml.cs（595 行）：
          - 公共方法：Initialize(repo, mode) / ShowRevisionDetails(target, fileToSelect) /
            ShowInFileTreeTab(filePath) / HighlightSearchMatches(query) / ApplyLocalization
          - 公共事件：RevisionDetailsUpdated
          - 异步 Job：_loadFullRevisionDetailsJob（git 命令取 FullRevisionDetails）
          - Tab 切换动画（DoubleAnimation + TranslateTransform on IndicatorBorder）

        Avalonia 适配：
          - WPF ContentContainer（自定义控件）→ Grid 替代
          - WPF RevisionsHeaderUserControl → ContentControl 占位（spike 未迁移）
          - WPF Dispatcher.Invoke → Dispatcher.UIThread.Post
          - WPF JobQueue → Task.Run + Dispatcher.UIThread.Post
          - WPF Tab 切换动画 → spike 静态指示条（暂不迁移 DoubleAnimation）
          - WPF RevisionDetailsBarButton 样式 → tab-btn class（已在 Controls.axaml 定义）
          - WPF OpenInSeparateWindowIcon DynamicResource → 直接 /Assets/openinseparatewindow.png
    -->
    <UserControl.Styles>
        <!-- 本控件内 tab-btn normal Foreground 对照 WPF RevisionDetailsBarButton Foreground=ForegroundMidBrush
             （全局 tab-btn normal 用 ForegroundBrush 偏深，这里覆盖为 SecondaryLabel 中等灰）
             :checked 选中色用全局 SystemAccentBrush（跟随 22 套主题，不再局部覆盖） -->
        <Style Selector="RadioButton.tab-btn">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundMidBrush}" />
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: Tab 切换栏（对照 WPF TabHeaderContainer Background=PanelBackgroundBrush）
             Col 0/1/2: Commit/Changes/FileTree RadioButton (Style=RevisionDetailsBarButton)
             Col 3 (*): 空
             Col 4 (40): ShowRevisionInSeparateWindowButton (22x22, Margin=0,1.5,10,0)
             Row 0 (30): RadioButton + Button
             Row 1 (1.5): Canvas + IndicatorBorder（spike 静态在 Commit tab 下方，对照 WPF 动画）-->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,Auto,*,40"
              RowDefinitions="30,1.5"
              Background="{DynamicResource PanelBackgroundBrush}">
            <RadioButton Grid.Row="0" Grid.Column="0" Name="CommitTabRadioButton"
                         Classes="tab-btn"
                         Content="Commit" IsChecked="True"
                         Click="CommitTabRadioButton_Click" />
            <RadioButton Grid.Row="0" Grid.Column="1" Name="ChangesTabRadioButton"
                         Classes="tab-btn"
                         Content="Changes"
                         Click="ChangesTabRadioButton_Click" />
            <RadioButton Grid.Row="0" Grid.Column="2" Name="FileTreeTabRadioButton"
                         Classes="tab-btn"
                         Content="File Tree"
                         Click="FileTreeTabRadioButton_Click" />
            <!-- ShowRevisionInSeparateWindowButton（对照 WPF 22x22 Margin=0,1.5,10,0 Style=RevisionDetailsSwapButtonStyle）-->
            <Button Grid.Row="0" Grid.Column="4" Name="ShowRevisionInSeparateWindowButton"
                    Classes="icon-btn"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="22" Height="22"
                    Padding="2"
                    Margin="0,1.5,10,0"
                    ToolTip.Tip="Open in separate window"
                    Click="ShowRevisionInSeparateWindowButton_Click">
                <Image Source="/Assets/openinseparatewindow.png" Width="16" Height="16" />
            </Button>
            <!-- Row 1: 指示条（对照 WPF Canvas + IndicatorBorder Background=SystemAccentBrush）
                 spike 静态在 Commit tab 下方，Width=60（动画暂不迁移）-->
            <Canvas Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                <Border Name="IndicatorBorder"
                        Height="1.5"
                        Width="60"
                        Background="{DynamicResource SystemAccentBrush}"
                        Canvas.Left="0" />
            </Canvas>
        </Grid>

        <!-- Row 1: RevisionsHeaderUserControl（对照 WPF 直接嵌入 + BorderBrush=BorderBrush 分隔）
             WPF Row 1 直接 <uc:RevisionsHeaderUserControl x:Name=RevisionsHeader />
             外层 Border 提供 BorderThickness=0,0,0,1 底部分隔线（对照 WPF RevisionsHeader 内部 Border） -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <uc:RevisionsHeaderUserControl Name="RevisionsHeader" />
        </Border>

        <!-- Row 2: 3 个子 UserControl（对照 WPF Border BorderThickness=0,1,0,0 BorderBrush=BorderBrush）
             完全对照 WPF 用 RevisionSummaryUserControl / RevisionChangesUserControl / RevisionFileTreeUserControl -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <!-- Commit tab: RevisionSummaryUserControl（默认可见）-->
                <uc:RevisionSummaryUserControl Name="SummaryUserControl"
                                               IsVisible="True" />

                <!-- Changes tab: RevisionChangesUserControl（默认 Collapsed）-->
                <uc:RevisionChangesUserControl Name="ChangesUserControl"
                                               IsVisible="False" />

                <!-- FileTree tab: RevisionFileTreeUserControl（默认 Collapsed）-->
                <uc:RevisionFileTreeUserControl Name="FileTreeUserControl"
                                                IsVisible="False" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
