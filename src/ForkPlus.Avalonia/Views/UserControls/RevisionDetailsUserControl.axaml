<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionDetailsUserControl">
    <!--
        Phase 3.6：Avalonia 版 RevisionDetailsUserControl 骨架（spike 简化版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml（40 行）：
          - 顶层 ContentContainer（自定义控件，spike 用 Grid 替代）
          - Grid 3 行：
            Row 0 (Auto): TabHeaderContainer — 3 个 RadioButton (Commit/Changes/FileTree)
                          + Canvas 中 Border 指示器（动画，spike 不迁移）
                          + ShowRevisionInSeparateWindowButton
            Row 1 (Auto): RevisionsHeaderUserControl（自定义，spike 用 ContentControl 占位）
            Row 2 (*):    Border 包 Grid，同时装入 3 个子 UserControl 用 Visibility 切换：
                          - RevisionSummaryUserControl（Commit tab，默认 Visible）
                          - RevisionChangesUserControl（Changes tab，默认 Collapsed）
                          - RevisionFileTreeUserControl（FileTree tab，默认 Collapsed）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml.cs（595 行）：
          - 公共方法：Initialize(repo, mode) / ShowRevisionDetails(target, fileToSelect) /
            ShowInFileTreeTab(filePath) / HighlightSearchMatches(query) / ApplyLocalization
          - 公共事件：RevisionDetailsUpdated
          - 异步 Job：_loadFullRevisionDetailsJob（git 命令取 FullRevisionDetails）
          - Tab 切换动画（DoubleAnimation + TranslateTransform，spike 不迁移）

        装入路径（WPF）：
          RepositoryContentUserControl.xaml Row 2 → RevisionDetailsUserControl
          由 RevisionListViewUserControl.SelectionChanged 触发刷新链

        本 spike 版暂不迁移：
          - ContentContainer 自定义控件（用 Grid 替代）
          - RevisionsHeaderUserControl（自定义，用 ContentControl 占位）
          - RevisionSummaryUserControl / RevisionChangesUserControl / RevisionFileTreeUserControl
            完整实现（3 个都是独立 spike，用 ContentControl 占位）
          - Tab 指示器动画（DoubleAnimation + TranslateTransform）
          - ShowRevisionInSeparateWindowButton 命令绑定
          - 异步 Job（_loadFullRevisionDetailsJob）
          - ApplyLocalization（多语言）

        本 spike 版验证：
          - Grid 3 行布局正确显示
          - 3 个 RadioButton (Commit/Changes/FileTree) 可切换
          - 3 个子 UserControl 占位容器可见性随 RadioButton 切换
    -->
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: Tab 切换栏 -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,Auto,*"
              Background="{DynamicResource ThemeCardBackgroundBrush, FallbackValue=#2D2D30}"
              Padding="4,2">
            <RadioButton Grid.Column="0" Name="CommitTabRadioButton"
                         Content="Commit" IsChecked="True"
                         Click="CommitTabRadioButton_Click"
                         Margin="8,0" />
            <RadioButton Grid.Column="1" Name="ChangesTabRadioButton"
                         Content="Changes"
                         Click="ChangesTabRadioButton_Click"
                         Margin="8,0" />
            <RadioButton Grid.Column="2" Name="FileTreeTabRadioButton"
                         Content="File Tree"
                         Click="FileTreeTabRadioButton_Click"
                         Margin="8,0" />
            <Button Grid.Column="3" Name="ShowRevisionInSeparateWindowButton"
                    Content="↗" HorizontalAlignment="Right"
                    ToolTip.Tip="Open in separate window"
                    Click="ShowRevisionInSeparateWindowButton_Click"
                    Margin="8,0" />
        </Grid>

        <!-- Row 1: RevisionsHeaderUserControl 占位（自定义 UserControl，spike 用 ContentControl）-->
        <ContentControl Grid.Row="1"
                        Name="RevisionsHeaderContainer"
                        Background="{DynamicResource ThemeBackgroundBrush, FallbackValue=#1E1E1E}"
                        Padding="8,4">
            <TextBlock Text="(revision header placeholder)"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
        </ContentControl>

        <!-- Row 2: 3 个子 UserControl 占位（用 Visibility 切换）-->
        <Grid Grid.Row="2">
            <ContentControl Name="RevisionSummaryContainer"
                            IsVisible="True">
                <TextBlock Text="(Commit tab: RevisionSummaryUserControl placeholder)"
                           FontSize="11"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           Margin="8,4" />
            </ContentControl>
            <ContentControl Name="RevisionChangesContainer"
                            IsVisible="False">
                <TextBlock Text="(Changes tab: RevisionChangesUserControl placeholder)"
                           FontSize="11"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           Margin="8,4" />
            </ContentControl>
            <ContentControl Name="RevisionFileTreeContainer"
                            IsVisible="False">
                <TextBlock Text="(FileTree tab: RevisionFileTreeUserControl placeholder)"
                           FontSize="11"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           Margin="8,4" />
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
