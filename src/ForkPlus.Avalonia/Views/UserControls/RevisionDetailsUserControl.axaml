<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="https://github.com/avaloniaui/avaloniaedit"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionDetailsUserControl">
    <!--
        Avalonia 版 RevisionDetailsUserControl（对照 WPF d696088）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml（40 行）：
          - ContentContainer（自定义控件）→ spike 用 Grid 替代
          - Grid 3 行：
            Row 0 (Auto): TabHeaderContainer
              - Row 0 (30): 3 个 RadioButton (Commit/Changes/FileTree) + Col 4 (40) ShowRevisionInSeparateWindowButton
              - Row 1 (1.5): Canvas + IndicatorBorder（动画指示器，对照 SystemAccentBrush）
              - Col 0/1/2/Auto/Auto/Auto/* /40
            Row 1 (Auto): RevisionsHeaderUserControl（自定义）→ spike 用 ContentControl 占位
            Row 2 (*): Border 包 Grid，3 个子 UserControl：
              - RevisionSummaryUserControl（默认可见）
              - RevisionChangesUserControl（默认 Collapsed）
              - RevisionFileTreeUserControl（默认 Collapsed）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionDetailsUserControl.xaml.cs（595 行）：
          - 公共方法：Initialize(repo, mode) / ShowRevisionDetails(target, fileToSelect) /
            ShowInFileTreeTab(filePath) / HighlightSearchMatches(query) / ApplyLocalization
          - 公共事件：RevisionDetailsUpdated
          - 异步 Job：_loadFullRevisionDetailsJob
          - Tab 切换动画（DoubleAnimation + TranslateTransform on IndicatorBorder）

        Avalonia 版差异：
          - WPF Visibility.Collapsed/Visible → Avalonia IsVisible=false/true
          - WPF ContentContainer（自定义控件）→ Grid 替代
          - WPF RevisionsHeaderUserControl → ContentControl 占位
          - WPF Dispatcher.Invoke → Dispatcher.UIThread.Post
          - WPF JobQueue → Task.Run + Dispatcher.UIThread.Post
          - WPF AvalonEdit.TextEditor → AvaloniaEdit.TextEditor
          - WPF Tab 切换动画（DoubleAnimation + TranslateTransform）→ spike 暂不迁移
          - WPF RevisionDetailsBarButton 样式 → spike 用 tab-btn class 简化
    -->
    <UserControl.Styles>
        <Style Selector="RadioButton.tab-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundMidBrush}" />
        </Style>
        <Style Selector="RadioButton.tab-btn:checked">
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentBrush}" />
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: Tab 切换栏（对照 WPF TabHeaderContainer）
             Col 0/1/2: Commit/Changes/FileTree RadioButton
             Col 3 (*): 空
             Col 4 (40): ShowRevisionInSeparateWindowButton
             Row 0 (30): RadioButton + Button
             Row 1 (1.5): IndicatorBorder（spike 静态）-->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,Auto,*,40"
              RowDefinitions="30,1.5"
              Background="{DynamicResource ThemeCardBackgroundBrush}">
            <RadioButton Grid.Row="0" Grid.Column="0" Name="CommitTabRadioButton"
                         Classes="tab-btn"
                         Content="Commit" IsChecked="True"
                         Click="CommitTabRadioButton_Click" />
            <RadioButton Grid.Row="0" Grid.Column="1" Name="ChangesTabRadioButton"
                         Classes="tab-btn"
                         Content="Changes"
                         Click="ChangesTabRadioButton_Click" />
            <RadioButton Grid.Row="0" Grid.Column="2" Name="FileTreeTabRadioButton"
                         Classes="tab-btn"
                         Content="File Tree"
                         Click="FileTreeTabRadioButton_Click" />
            <Button Grid.Row="0" Grid.Column="4" Name="ShowRevisionInSeparateWindowButton"
                    Classes="icon-btn"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    ToolTip.Tip="Open in separate window"
                    Click="ShowRevisionInSeparateWindowButton_Click">
                <Image Source="/Assets/openinseparatewindow.png" Width="16" Height="16" />
            </Button>
            <!-- Row 1: 指示条（对照 WPF IndicatorBorder，spike 静态在 Commit tab 下方）-->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                    Name="IndicatorBorder"
                    Height="1.5"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource ThemeAccentBrush}"
                    Width="60" />
        </Grid>

        <!-- Row 1: RevisionsHeaderUserControl 占位 -->
        <ContentControl Grid.Row="1"
                        Name="RevisionsHeaderContainer"
                        Background="{DynamicResource ThemeBackgroundBrush}"
                        Padding="8,4">
            <TextBlock Text="(revision header)"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
        </ContentControl>

        <!-- Row 2: 3 个子面板（用 IsVisible 切换）-->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ThemeBorderMidBrush}">
            <Grid>

                <!-- Commit tab: 作者/日期/message + diff -->
                <ScrollViewer Name="RevisionSummaryContainer" IsVisible="True">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                          Margin="8,4">
                        <!-- Author -->
                        <Grid Grid.Row="0" ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Author:"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <TextBlock Grid.Column="1" Name="AuthorTextBlock"
                                       Text="(author)"
                                       FontSize="11" />
                        </Grid>
                        <!-- Date -->
                        <Grid Grid.Row="1" ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Date:"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <TextBlock Grid.Column="1" Name="DateTextBlock"
                                       Text="(date)"
                                       FontSize="11" />
                        </Grid>
                        <!-- SHA -->
                        <Grid Grid.Row="2" ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="SHA:"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <SelectableTextBlock Grid.Column="1" Name="ShaTextBlock"
                                                  Text="(sha)"
                                                  FontSize="11"
                                                  FontFamily="Consolas,Menlo,monospace" />
                        </Grid>
                        <!-- Message Subject -->
                        <Grid Grid.Row="3" ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Subject:"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <TextBlock Grid.Column="1" Name="SubjectTextBlock"
                                       Text="(subject)"
                                       FontSize="12" TextWrapping="Wrap" />
                        </Grid>
                        <!-- Message Body -->
                        <Grid Grid.Row="4" ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Message:"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                            <TextBlock Grid.Column="1" Name="MessageTextBlock"
                                       Text="(message body)"
                                       FontSize="11" TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </ScrollViewer>

                <!-- Changes tab: diff（spike 用 AvaloniaEdit.TextEditor）-->
                <Grid Name="RevisionChangesContainer" IsVisible="False">
                    <avalonEdit:TextEditor Name="DiffEditor"
                                           IsReadOnly="True"
                                           ShowLineNumbers="True"
                                           WordWrap="False"
                                           FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                           FontSize="13" />
                </Grid>

                <!-- FileTree tab: RevisionFileTreeUserControl 占位 -->
                <ContentControl Name="RevisionFileTreeContainer"
                                IsVisible="False">
                    <TextBlock Text="(file tree tab placeholder)"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               Margin="8,4" />
                </ContentControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
