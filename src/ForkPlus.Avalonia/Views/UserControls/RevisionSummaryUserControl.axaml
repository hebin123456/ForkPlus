<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionSummaryUserControl">
    <!--
        Phase 3.10：Avalonia 版 RevisionSummaryUserControl 骨架（spike 简化版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionSummaryUserControl.xaml（152 行）：
          - Grid 2 行：* / Auto
          - Row 0: ScrollViewer + Grid 2 行 × 4 列（82/*/48/*）
            Row 0: AuthorDetailsContainer（AvatarImage + Author/Email/Date）+
                   CommitterDetailsContainer（同结构）
            Row 1: commit 详情区（9 行子 Grid）：
              REFS → ReferencePanel（自定义控件，spike 用 ItemsControl 占位）
              SHA → SelectableTextBlock + AiExplainCommitButton（🤖 AI Explain）+
                    RevisionRemoteButtonsContainer
              PARENTS → ParentsContainer
              Subject / Description → SelectableTextBlock
              DiffList（ItemsControl）→ 每行 Expander 内嵌 FileDiffControl SubControlMode=True
              ExpandAllButton / DiffListLimitTextBlock
          - Row 1: BottomControl（spike 不迁移）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionSummaryUserControl.xaml.cs（625 行）：
          - 公共方法：Refresh(Sha, BugtrackerLinkDefinition[], UserColors) / ApplyLocalization /
            HighlightSearchMatches(RevisionSearchQuery)
          - 公共属性：RevisionDetailsUserControl（反向引用父控件）/
            RepositoryUserControl（通过父控件取）
          - 无 Initialize 注入模式（通过公共属性 RevisionDetailsUserControl 注入）

        装入路径（WPF）：
          RevisionDetailsUserControl.xaml Row 2 → RevisionSummaryUserControl（Commit tab）

        本 spike 版策略：
          - AvatarImage 用 Avalonia Image 占位（默认不显示）
          - SelectableTextBlock 用 Avalonia SelectableTextBlock（API 对应）
          - ReferencePanel 用 ItemsControl + TextBlock 占位
          - AiExplainCommitButton 保留（Button + emoji 文本）
          - DiffList 用 ItemsControl + Expander + DataTemplate，Expander 内容用 Phase 3.9a 的 FileDiffControl 占位
            （SubControlMode=True，嵌入式 diff）
          - 公共方法签名保留，body stub

        本 spike 版暂不迁移：
          - AvatarImage 真实 avatar 加载
          - ReferencePanel 真实 reference 渲染
          - ApplySearchAndButrackerHighlighting（搜索高亮）
          - CreateColorsPopup（用户颜色配置浮窗）
          - AiExplainCommitButton_Click（AI 调用，Phase 5）
          - CreateFileContextMenuItems（右键菜单，30+ 项）
          - LoadDiffEntryContent（git diff 调用）

        本 spike 版验证：
          - Grid 2 行布局正确显示
          - Row 0 ScrollViewer + Grid 2 行 × 4 列布局
          - Author/Committer 区占位可见
          - commit 详情区（REFS/SHA/PARENTS/Subject/Description）占位可见
          - DiffList 用空 ItemsControl 占位
    -->
    <Grid RowDefinitions="*,Auto">

        <!-- Row 0: ScrollViewer + Grid 2 行 × 4 列 -->
        <ScrollViewer Grid.Row="0">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="82,*,48,*">

                <!-- Row 0, Col 0-1: AuthorDetailsContainer -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="4">
                    <Image Name="AuthorAvatarImage"
                           Width="32" Height="32" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Name="AuthorNameTextBlock"
                                   Text="(author)"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeForegroundBrush}" />
                        <TextBlock Name="AuthorEmailTextBlock"
                                   Text="(email)"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <TextBlock Name="AuthorDateTextBlock"
                                   Text="(date)"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 0, Col 2-3: CommitterDetailsContainer -->
                <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
                            Orientation="Horizontal" Margin="4">
                    <Image Name="CommitterAvatarImage"
                           Width="32" Height="32" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Name="CommitterNameTextBlock"
                                   Text="(committer)"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeForegroundBrush}" />
                        <TextBlock Name="CommitterEmailTextBlock"
                                   Text="(email)"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <TextBlock Name="CommitterDateTextBlock"
                                   Text="(date)"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 1, ColSpan 4: commit 详情区 -->
                <Grid Grid.Row="1" Grid.ColumnSpan="4"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      Margin="4,8,4,4">

                    <!-- REFS -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="REFS:"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                   Margin="0,0,8,0" />
                        <ItemsControl Name="ReferencesContainer">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="(ref)" FontSize="11" Margin="0,0,8,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- SHA -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="SHA:"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                   Margin="0,0,8,0" />
                        <SelectableTextBlock Name="ShaTextBlock"
                                             Text="(sha)"
                                             FontSize="11"
                                             FontFamily="Consolas,Menlo,monospace" />
                        <Button Name="AiExplainCommitButton"
                                Content="🤖 AI Explain"
                                Margin="8,0"
                                Click="AiExplainCommitButton_Click" />
                    </StackPanel>

                    <!-- PARENTS -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="PARENTS:"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                   Margin="0,0,8,0" />
                        <ItemsControl Name="ParentsContainer">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <SelectableTextBlock Text="(parent sha)"
                                                         FontSize="11"
                                                         FontFamily="Consolas,Menlo,monospace"
                                                         Margin="0,0,8,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Subject -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Subject:"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                   Margin="0,0,8,0" />
                        <SelectableTextBlock Name="SubjectTextBlock"
                                             Text="(subject)"
                                             FontSize="12"
                                             TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Description:"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                   Margin="0,0,8,0" />
                        <SelectableTextBlock Name="DescriptionTextBlock"
                                             Text="(description)"
                                             FontSize="11"
                                             TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- DiffList（ItemsControl + Expander + FileDiffControl SubControlMode=True）-->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,2">
                        <Button Name="ExpandAllButton"
                                Content="Expand all"
                                Click="ExpandAllButton_Click"
                                Margin="0,0,8,0" />
                        <TextBlock Name="DiffListLimitTextBlock"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="6"
                                  Name="DiffList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="(file)">
                                    <uc:FileDiffControl SubControlMode="True" />
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
