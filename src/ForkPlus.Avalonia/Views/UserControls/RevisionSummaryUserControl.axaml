<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionSummaryUserControl">
    <!--
        对照 WPF src/ForkPlus/UI/UserControls/RevisionSummaryUserControl.xaml（152 行）：
          - Grid 2 行：* / Auto
          - Row 0: ScrollViewer + Grid 2 行 × 4 列（82/*/48/*）
            Row 0: AuthorDetailsContainer（82 列 AvatarImage 42x42 + * 列 AUTHOR 标签 +
                   Author/Email/Date SelectableTextBlock）+ CommitterDetailsContainer（同结构 48+*）
            Row 1: commit 详情区（9 行子 Grid 82+* 列）：
              REFS → ReferencePanel / SHA → SelectableTextBlock + AiExplainCommitButton +
                    RevisionRemoteButtonsContainer / PARENTS → ParentsContainer
              Subject / Description → SelectableTextBlock FontWeight=Medium FontSize=15
              DiffList（ItemsControl + Expander 内嵌 FileDiffControl SubControlMode=True）
              ExpandAllButton / DiffListLimitTextBlock
          - Row 1: BottomControl（spike 不迁移）

        装入路径：RevisionDetailsUserControl.axaml Row 2 → RevisionSummaryUserControl（Commit tab）
    -->
    <Grid RowDefinitions="*,Auto">

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="82,*,48,*">

                <!-- ===== Row 0, Col 0-1: AuthorDetailsContainer（对照 WPF Grid 3 行 × 2 列）===== -->
                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="AuthorDetailsContainer"
                      RowDefinitions="25,30,32"
                      ColumnDefinitions="82,*">
                    <!-- AuthorAvatarImage 42x42 HAlign=Right -->
                    <Image Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                           Name="AuthorAvatarImage"
                           Width="42" Height="42"
                           Margin="0,0,0,5"
                           HorizontalAlignment="Right" />
                    <!-- AUTHOR 标签 -->
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="AUTHOR"
                               Margin="16,10,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryLabelBrush}" />
                    <!-- Author + Email DockPanel -->
                    <DockPanel Grid.Row="1" Grid.Column="1"
                               Margin="16,8,4,4"
                               LastChildFill="False">
                        <SelectableTextBlock DockPanel.Dock="Left"
                                             Name="AuthorNameTextBlock"
                                             Text="(author)"
                                             FontSize="14"
                                             FontWeight="Medium"
                                             VerticalAlignment="Center" />
                        <SelectableTextBlock DockPanel.Dock="Left"
                                             Name="AuthorEmailTextBlock"
                                             Text="(email)"
                                             Margin="8,0,14,-1"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource SecondaryLabelBrush}" />
                    </DockPanel>
                    <!-- Author date -->
                    <SelectableTextBlock Grid.Row="2" Grid.Column="1"
                                         Name="AuthorDateTextBlock"
                                         Text="(date)"
                                         Margin="16,0,4,15"
                                         Foreground="{DynamicResource SecondaryLabelBrush}" />
                </Grid>

                <!-- ===== Row 0, Col 2-3: CommitterDetailsContainer（同结构 48+*）===== -->
                <Grid Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"
                      Name="CommitterDetailsContainer"
                      RowDefinitions="25,30,32"
                      ColumnDefinitions="42,*">
                    <Image Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                           Name="CommitterAvatarImage"
                           Width="42" Height="42"
                           Margin="0,0,0,5"
                           HorizontalAlignment="Right" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Name="CommitterTitleTextBlock"
                               Text="COMMITTER"
                               Margin="16,10,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryLabelBrush}" />
                    <DockPanel Grid.Row="1" Grid.Column="1"
                               Margin="16,8,10,4"
                               LastChildFill="False">
                        <SelectableTextBlock DockPanel.Dock="Left"
                                             Name="CommitterNameTextBlock"
                                             Text="(committer)"
                                             FontSize="14"
                                             FontWeight="Medium"
                                             VerticalAlignment="Center" />
                        <SelectableTextBlock DockPanel.Dock="Left"
                                             Name="CommitterEmailTextBlock"
                                             Text="(email)"
                                             Margin="8,0,14,-1"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource SecondaryLabelBrush}" />
                    </DockPanel>
                    <SelectableTextBlock Grid.Row="2" Grid.Column="1"
                                         Name="CommitterDateTextBlock"
                                         Text="(date)"
                                         Margin="16,0,10,15"
                                         Foreground="{DynamicResource SecondaryLabelBrush}" />
                </Grid>

                <!-- ===== Row 1, ColSpan 4: commit 详情区（对照 WPF 9 行子 Grid 82+* 列）===== -->
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                      RowDefinitions="Auto,18,28,16,Auto,Auto,14,Auto,Auto"
                      ColumnDefinitions="82,*">

                    <!-- Row 0: REFS（Label + ReferencePanel） -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="REFS"
                               HorizontalAlignment="Right"
                               Margin="16,2,0,0"
                               Foreground="{DynamicResource SecondaryLabelBrush}" />
                    <ItemsControl Grid.Row="0" Grid.Column="1"
                                  Name="ReferencePanel"
                                  Margin="16,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="(ref)"
                                           FontSize="11"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource ThemeAccentBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Row 1: SHA（Label + SelectableTextBlock + AiExplainCommitButton + RevisionRemoteButtonsContainer） -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="SHA"
                               HorizontalAlignment="Right"
                               Margin="16,2,0,0"
                               Foreground="{DynamicResource SecondaryLabelBrush}" />
                    <DockPanel Grid.Row="1" Grid.Column="1"
                               Margin="16,2,0,0"
                               HorizontalAlignment="Left">
                        <SelectableTextBlock DockPanel.Dock="Left"
                                             Name="ShaTextBlock"
                                             Text="(sha)"
                                             FontSize="13"
                                             FontFamily="Consolas,Menlo,monospace" />
                        <Button DockPanel.Dock="Left"
                                Name="AiExplainCommitButton"
                                Margin="8,0,0,0"
                                Padding="6,1"
                                Height="20"
                                FontSize="11"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Use AI to explain this commit"
                                Click="AiExplainCommitButton_Click">
                            <TextBlock Text="🤖 AI Explain" />
                        </Button>
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    Name="RevisionRemoteButtonsContainer" />
                    </DockPanel>

                    <!-- Row 2: PARENTS -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="PARENTS"
                               HorizontalAlignment="Right"
                               Margin="16,4,0,5"
                               Foreground="{DynamicResource SecondaryLabelBrush}" />
                    <StackPanel Grid.Row="2" Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="16,0,0,5"
                                Name="ParentsContainer">
                        <SelectableTextBlock Text="(parents)"
                                             FontSize="11"
                                             FontFamily="Consolas,Menlo,monospace"
                                             Foreground="{DynamicResource SecondaryLabelBrush}" />
                    </StackPanel>

                    <!-- Row 3: Separator -->
                    <Separator Grid.Row="3" Grid.ColumnSpan="2"
                               Margin="20,10,20,5" />

                    <!-- Row 4: Subject（FontWeight=Medium FontSize=15） -->
                    <SelectableTextBlock Grid.Row="4" Grid.Column="1"
                                         Name="SubjectTextBlock"
                                         Text="(subject)"
                                         Margin="16,5,10,5"
                                         FontWeight="Medium"
                                         FontSize="15"
                                         TextWrapping="Wrap" />

                    <!-- Row 5: Description -->
                    <SelectableTextBlock Grid.Row="5" Grid.Column="1"
                                         Name="DescriptionTextBlock"
                                         Text=""
                                         Margin="16,0,10,0"
                                         TextWrapping="Wrap" />

                    <!-- Row 6: Separator -->
                    <Separator Grid.Row="6" Grid.ColumnSpan="2"
                               Margin="20,8,20,4" />

                    <!-- Row 7: DiffList + ExpandAllButton（对照 WPF Grid + ItemsControl + Expander） -->
                    <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                        <ItemsControl Name="DiffList"
                                      Margin="0,16,0,0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="(file)"
                                              Padding="0"
                                              HorizontalAlignment="Stretch">
                                        <uc:FileDiffControl SubControlMode="True" />
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Name="ExpandAllButton"
                                Width="80"
                                Margin="8,0,20,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="ExpandAllButton_Click"
                                Content="Expand all" />
                    </Grid>

                    <!-- Row 8: DiffListLimitTextBlock（Collapsed 占位） -->
                    <TextBlock Grid.Row="8" Grid.ColumnSpan="2"
                               Name="DiffListLimitTextBlock"
                               Margin="0,5,0,10"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryLabelBrush}"
                               IsVisible="False" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
