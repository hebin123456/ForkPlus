<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.SidebarUserControl"
             Width="240">
    <!--
        Phase 5.2 完整迁移版：Avalonia 版 SidebarUserControl。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/SidebarUserControl.xaml（105 行）+
        SidebarUserControl.xaml.cs（2714 行）：
          - WPF 顶层 Grid 2 行（Auto/*）：
            Row 0: 仓库名 + 5 个 RadioButton（Changes/AllCommits/Branches/Search/Service）
            Row 1: TabControl（Branches/Search/Service 3 个 TabItem）
          - WPF SidebarTreeView 是 MultiselectionTreeView 自定义控件（自定义树视图）
            spike 版用 Avalonia 原生 TreeView + TreeDataTemplate 替代
          - WPF FilterTextBox 是自定义控件（带过滤的 TextBox）
            spike 版用普通 TextBox + TextChanged 事件替代

        Avalonia 11 适配：
          - TreeView 用 TreeDataTemplate + ItemsSource="{Binding Children}" 绑定
          - HierarchicalDataTemplate → TreeDataTemplate
          - Visibility.Collapsed/Visible → IsVisible = false/true
          - MouseDoubleClick → DoubleTapped

        spike 简化策略：
          - 图标用 emoji TextBlock（绑定 Icon 属性）
          - 普通 TextBox 过滤（替代自定义 FilterTextBox）
          - 不迁移 MultiselectionTreeView（用原生 TreeView）
    -->
    <UserControl.Resources>
        <!--
            树节点模板（对照 WPF HierarchicalDataTemplate）：
              ItemsSource="{Binding Children}" → 递归显示子节点
              Icon + Name → 横向排列 emoji 图标 + 名称
        -->
        <TreeDataTemplate x:Key="SidebarNodeTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1">
                <TextBlock Text="{Binding Icon}" FontSize="12" />
                <TextBlock Text="{Binding Name}" />
            </StackPanel>
        </TreeDataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource Sidebar.Static.Background}">

        <!-- Row 0: 标题栏 + 5 个 RadioButton -->
        <StackPanel Grid.Row="0" Margin="8,4">
            <!-- Repo 标题栏（仓库名 + 设置按钮）-->
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                <Button Grid.Column="0" Name="RepoSettingsButton" Content="⚙"
                        Click="RepoSettingsButton_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource ThemeForegroundBrush}" />
                <TextBlock Grid.Column="1" Name="RepositoryNameText"
                           Text="(no repository)"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button Grid.Column="2" Name="RepoHideButton" Content="◀"
                        Click="RepoHideButton_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource ThemeForegroundBrush}" />
            </Grid>

            <!-- 视图切换 RadioButton -->
            <StackPanel Orientation="Vertical" Spacing="2" Margin="0,4">
                <!--
                    ChangesRadioButton：对照 WPF ChangesRadioButton + ChangesTextBlock
                    用 TextBlock 名为 ChangesTextBlock 作 Content（供 ApplyLocalization 更新文本）
                -->
                <RadioButton Name="ChangesRadioButton"
                             Click="ChangesRadioButton_Click"
                             Foreground="{DynamicResource ThemeForegroundBrush}">
                    <TextBlock Name="ChangesTextBlock" Text="Changes" />
                </RadioButton>
                <RadioButton Name="AllCommitsRadioButton" Content="All Commits"
                             IsChecked="True"
                             Click="AllCommitsRadioButton_Click"
                             Foreground="{DynamicResource ThemeForegroundBrush}" />
            </StackPanel>

            <!-- 视图模式切换（Branches/Search/Service 3 个图标按钮）-->
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"
                        Margin="0,4">
                <RadioButton Name="BranchesRadioButton" Content="⌥"
                             ToolTip.Tip="Branches"
                             Click="BranchesRadioButton_Click"
                             Foreground="{DynamicResource ThemeForegroundBrush}" />
                <RadioButton Name="SearchRadioButton" Content="🔍"
                             ToolTip.Tip="Search Commits"
                             Click="SearchRadioButton_Click"
                             Foreground="{DynamicResource ThemeForegroundBrush}" />
                <RadioButton Name="ServiceRadioButton" Content="⇄"
                             ToolTip.Tip="Pull Requests"
                             IsVisible="False"
                             Click="ServiceRadioButton_Click"
                             Foreground="{DynamicResource ThemeForegroundBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Row 1: TabControl（Branches/Search/Service 3 个 Tab）-->
        <TabControl Grid.Row="1" Name="SidebarTabControl"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Name="BranchesTabItem" Header="Branches">
                <Grid RowDefinitions="Auto,*" Margin="4">
                    <!-- 过滤框（对照 WPF FilterTextBox，spike 用普通 TextBox）-->
                    <TextBox Grid.Row="0" Name="FilterTextBox"
                             Watermark="Filter branches..."
                             TextChanged="FilterTextBox_TextChanged"
                             Margin="0,2" />
                    <!--
                        树视图（对照 WPF SidebarTreeView = MultiselectionTreeView）
                        spike 版用 Avalonia 原生 TreeView + TreeDataTemplate
                        ItemsSource 绑定 _rootNodes（在 OnLoaded / Initialize 中赋值）
                    -->
                    <TreeView Grid.Row="1" Name="SidebarTreeView"
                              ItemTemplate="{StaticResource SidebarNodeTemplate}"
                              Background="Transparent"
                              BorderThickness="0" />
                </Grid>
            </TabItem>
            <TabItem Name="SearchTabItem" Header="Search">
                <TextBlock Text="(search not implemented in spike)"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           FontSize="11" />
            </TabItem>
            <TabItem Name="ServiceTabItem" Header="Service" IsVisible="False">
                <TextBlock Text="(service not implemented in spike)"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           FontSize="11" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
