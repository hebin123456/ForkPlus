<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.SidebarUserControl"
             Width="240">
    <!--
        对照 WPF SidebarUserControl.xaml（105 行）：
          Row 0: 仓库名(DockPanel: 设置按钮 + 仓库名) + 5 个 RadioButton(Changes/AllCommits
                 + Branches/Search/Service 3 个图标按钮)
          Row 1: TabControl（Branches/Search/Service 3 个 TabItem）
        Avalonia 版：emoji 换真实 PNG 图标，仓库名区按 WPF DockPanel 结构。
    -->
    <UserControl.Styles>
        <Style Selector="RadioButton.sidebar-nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="RadioButton.sidebar-icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <TreeDataTemplate x:Key="SidebarNodeTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                <Image Source="{Binding IconPath}" Width="16" Height="16" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
            </StackPanel>
        </TreeDataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*"
          Background="{DynamicResource Sidebar.Static.Background}">

        <!-- Row 0: 仓库名 + 视图切换按钮 -->
        <StackPanel Grid.Row="0" Margin="0">
            <!-- 仓库名栏（对照 WPF DockPanel: 仓库名 + 设置按钮）-->
            <Grid ColumnDefinitions="*,Auto" Margin="8,4,4,4">
                <TextBlock Grid.Column="0" Name="RepositoryNameText"
                           Text="(no repository)"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           FontWeight="Medium"
                           FontSize="13.5"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource ThemeForegroundBrush}" />
                <Button Grid.Column="1" Name="RepoSettingsButton" Classes="sidebar-btn"
                        ToolTip.Tip="Repository Settings"
                        Click="RepoSettingsButton_Click">
                    <Image Source="/Assets/settings.png" Width="16" Height="16" />
                </Button>
            </Grid>

            <!-- Changes / All Commits 视图切换（对照 WPF ChangesRadioButton + AllCommitsRadioButton）-->
            <RadioButton Name="ChangesRadioButton" Classes="sidebar-nav"
                         Click="ChangesRadioButton_Click"
                         Margin="4,2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Image Source="/Assets/changes.png" Width="16" Height="16" />
                    <TextBlock Name="ChangesTextBlock" Text="Changes"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>
            <RadioButton Name="AllCommitsRadioButton" Classes="sidebar-nav"
                         IsChecked="True"
                         Click="AllCommitsRadioButton_Click"
                         Margin="4,2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Image Source="/Assets/revisionlist.png" Width="16" Height="16" />
                    <TextBlock Name="AllCommitsTextBlock" Text="All Commits"
                               VerticalAlignment="Center" />
                </StackPanel>
            </RadioButton>

            <!-- Branches / Search / Service 3 个图标按钮（对照 WPF SidebarPathImageRadioButtonStyle）-->
            <Border Margin="0,5,0,0" BorderThickness="0,1,0,1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                    <RadioButton Name="BranchesRadioButton" Classes="sidebar-icon-btn"
                                 ToolTip.Tip="Branches"
                                 IsChecked="True"
                                 Click="BranchesRadioButton_Click">
                        <Image Source="/Assets/branch.png" Width="16" Height="16" />
                    </RadioButton>
                    <RadioButton Name="SearchRadioButton" Classes="sidebar-icon-btn"
                                 ToolTip.Tip="Search Commits"
                                 Click="SearchRadioButton_Click">
                        <Image Source="/Assets/search.png" Width="16" Height="16" />
                    </RadioButton>
                    <RadioButton Name="ServiceRadioButton" Classes="sidebar-icon-btn"
                                 ToolTip.Tip="Pull Requests"
                                 IsVisible="False"
                                 Click="ServiceRadioButton_Click">
                        <Image Source="/Assets/pullrequest.png" Width="16" Height="16" />
                    </RadioButton>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Row 1: TabControl（Branches/Search/Service 3 个 Tab）-->
        <TabControl Grid.Row="1" Name="SidebarTabControl"
                    Background="{DynamicResource Sidebar.Static.Background}"
                    Padding="0"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Name="BranchesTabItem" Header="Branches">
                <Grid RowDefinitions="Auto,*" Margin="4">
                    <TextBox Grid.Row="0" Name="FilterTextBox"
                             Watermark="Filter branches..."
                             TextChanged="FilterTextBox_TextChanged"
                             Margin="0,2" />
                    <TreeView Grid.Row="1" Name="SidebarTreeView"
                              ItemTemplate="{StaticResource SidebarNodeTemplate}"
                              Background="Transparent"
                              BorderThickness="0" />
                </Grid>
            </TabItem>
            <TabItem Name="SearchTabItem" Header="Search">
                <TextBlock Text="(search not implemented)"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           FontSize="11" />
            </TabItem>
            <TabItem Name="ServiceTabItem" Header="Service" IsVisible="False">
                <TextBlock Text="(service not implemented)"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           FontSize="11" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
