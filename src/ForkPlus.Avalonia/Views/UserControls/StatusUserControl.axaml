<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.StatusUserControl"
             Width="300">
    <!--
        Avalonia 版 StatusUserControl（spike 简化升级版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/StatusUserControl.xaml（138 行）：
          - 顶层 UserControl Width=300 → Border（CornerRadius=3，状态栏背景）
          - Grid 3 列 × 3 行（20/*/20 × 18/16/2）
          - TitleContainer（双行标题动画容器，含 TranslateTransform）
          - CancelButton / ShowActivityManagerToggleButton / FilterButton
          - StatusProgressBar（底部进度条）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/StatusUserControl.xaml.cs（278 行）：
          - 公共方法：ApplyLocalization / RunAnimation（标题切换动画）
          - 私有 Refresh() 由 200ms DispatcherTimer 驱动
          - 通过 MainWindow.Instance?.TabManager.ActiveRepositoryUserControl 单例式访问

        Avalonia 版差异：
          - WPF Visibility.Collapsed/Visible → Avalonia IsVisible=false/true
          - WPF Dispatcher.Invoke → Dispatcher.UIThread.Post
          - WPF Image.Show()/Hide()/Collapse() → IsVisible=true/false/false
          - CenteredDockPanel（自定义控件）→ Grid 替代
          - 标题动画用 TranslateTransform（API 一致，spike 不实现缓动）

        spike 简化：
          - 用 TextBlock 显示状态文本 + emoji（Clean=✓ / Dirty=⚠ / Ahead=⬆ / Behind=⬇）
          - ActivityManagerPopup 用空 Popup 占位
          - DispatcherTimer 200ms 刷新暂不启用
          - RunAnimation 只切换文字，不做 QuadraticEase 缓动
    -->
    <Border CornerRadius="3"
            Background="{DynamicResource ThemeCardBackgroundBrush}"
            BorderThickness="0">
        <Grid ColumnDefinitions="20,*,20"
              RowDefinitions="18,16,2">

            <!-- Row 0 + Row 1, ColSpan 3: TitleContainer（双行标题动画容器）-->
            <Grid Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="3"
                  Name="TitleContainer"
                  RowDefinitions="*,*">
                <!-- 次要标题（默认不可见，动画时显示）-->
                <TextBlock Grid.Row="0"
                           Name="SecondaryTitleTextBlock"
                           Text="(secondary title)"
                           FontSize="11"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           VerticalAlignment="Center" Margin="4,0"
                           IsVisible="False" />
                <!-- 主标题（含 emoji 状态前缀）-->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Name="StatusEmojiTextBlock"
                               Text=""
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Name="TitleTextBlock"
                               Text="(no repository)"
                               FontSize="12"
                               Foreground="{DynamicResource ThemeForegroundBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- RowSpan 3, Col 2: CancelButton（默认不可见）-->
            <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                    Name="CancelButton"
                    Content="✕"
                    Width="16" Height="16"
                    IsVisible="False"
                    Click="CancelButton_Click" />

            <!-- Row 1, ColSpan 3: 状态操作区（spike 用 Grid 替代 CenteredDockPanel）-->
            <Grid Grid.Row="1" Grid.ColumnSpan="3">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ToggleButton Name="ShowActivityManagerToggleButton"
                                  Content="⚙"
                                  ToolTip.Tip="Activity manager"
                                  Click="ShowActivityManagerToggleButton_Click"
                                  Margin="2,0" />
                    <Button Name="FilterButton"
                            Content="▼"
                            ToolTip.Tip="Branch filter"
                            Click="FilterButton_Click"
                            Margin="2,0" />
                    <TextBlock Name="DescriptionTextBlock"
                               Text="(status)"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                               VerticalAlignment="Center" Margin="4,0" />
                </StackPanel>
            </Grid>

            <!-- Row 2, ColSpan 3: StatusProgressBar -->
            <ProgressBar Grid.Row="2" Grid.ColumnSpan="3"
                         Name="StatusProgressBar"
                         Height="2"
                         IsIndeterminate="False"
                         Minimum="0" Maximum="100" Value="0"
                         IsVisible="False" />
        </Grid>
    </Border>
</UserControl>
