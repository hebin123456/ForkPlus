<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.ToolbarUserControl"
             Height="40">
    <!--
        Avalonia 版 ToolbarUserControl（spike 简化升级版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/ToolbarUserControl.xaml（326 行）+
        ToolbarUserControl.xaml.cs（962 行）：
          - WPF 三列 Grid 布局：左操作区（Quick Launch/Fetch/Pull/Push/Stash/Undo/Redo/Reflog）
            + 中状态区（StatusUserControl）+ 右操作区（Branch/Workspaces/Appearance/Console/AI/OpenIn）
          - 所有按钮用自定义控件 ToolbarButton/DropDownButton/ToolbarDropDownButton
          - 43 处 DynamicResource 引用主题样式/图标/画刷

        Avalonia 版差异：
          - 自定义控件 ToolbarButton/DropDownButton/ToolbarDropDownButton → 原生 Button
          - WPF PNG 图标 → emoji 文本（Fetch=⬇ / Pull=⬇⬆ / Push=⬆ / Branch=🌿 / Commit=✓ / Stash=📥）
          - WPF Visibility.Collapsed/Visible → Avalonia IsVisible=false/true
          - ContextMenu.Open() 直接在控件上调用

        spike 简化：
          - 用 StackPanel + Button 显示按钮，emoji 替代 PNG 图标
          - 主题切换菜单用 ContextMenu 动态构造
          - Pull/Push 数字角标用 TextBlock 占位（暂不实现）
          - Undo/Redo 历史菜单 / Stash/Branch/OpenIn 下拉菜单暂不实现
          - NotificationCenter 事件订阅暂不接入
    -->
    <Grid ColumnDefinitions="*,300,*"
          Background="{DynamicResource ToolbarBackgroundBrush}">

        <!-- Column 0: 左侧主操作区（emoji 图标按钮）-->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2"
                    VerticalAlignment="Center" Margin="8,0">
            <Button Name="QuickLaunchButton" Content="🔍"
                    ToolTip.Tip="Quick Launch"
                    Click="QuickLaunchButton_Click" Margin="0,0,2,0" />
            <Button Name="FetchButton" Content="⬇"
                    ToolTip.Tip="Fetch"
                    Click="FetchButton_Click" Margin="0,0,2,0" />
            <Button Name="PullButton" Content="⬇⬆"
                    ToolTip.Tip="Pull"
                    Click="PullButton_Click" Margin="0,0,2,0" />
            <Button Name="PushButton" Content="⬆"
                    ToolTip.Tip="Push"
                    Click="PushButton_Click" Margin="0,0,2,0" />
            <Button Name="BranchButton" Content="🌿"
                    ToolTip.Tip="Branch"
                    Click="BranchButton_Click" Margin="0,0,2,0" />
            <Button Name="CommitButton" Content="✓"
                    ToolTip.Tip="Commit"
                    Click="CommitButton_Click" Margin="0,0,2,0" />
            <Button Name="StashButton" Content="📥"
                    ToolTip.Tip="Stash"
                    Click="StashButton_Click" Margin="0,0,2,0" />
            <Button Name="UndoButton" Content="↶"
                    ToolTip.Tip="Undo"
                    Click="UndoButton_Click" Margin="0,0,2,0" />
            <Button Name="RedoButton" Content="↷"
                    ToolTip.Tip="Redo"
                    Click="RedoButton_Click" Margin="0,0,2,0" />
            <Button Name="ReflogButton" Content="📋"
                    ToolTip.Tip="Reflog"
                    Click="ReflogButton_Click" />
        </StackPanel>

        <!-- Column 1: 状态区（StatusUserControl 占位）-->
        <Border Grid.Column="1" Padding="8,0" VerticalAlignment="Center">
            <TextBlock Name="StatusText" Text="(no repository)"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                       FontSize="11" />
        </Border>

        <!-- Column 2: 右侧次操作区 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2"
                    VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0">
            <Button Name="WorkspacesButton" Content="🗂"
                    ToolTip.Tip="Workspaces"
                    Click="WorkspacesButton_Click" Margin="0,0,2,0" />
            <Button Name="AppearanceButton" Content="🎨"
                    ToolTip.Tip="Appearance"
                    Click="AppearanceButton_Click" Margin="0,0,2,0" />
            <Button Name="ConsoleButton" Content="🖥"
                    ToolTip.Tip="Console"
                    Click="ConsoleButton_Click" Margin="0,0,2,0" />
            <Button Name="AiButton" Content="🤖"
                    ToolTip.Tip="AI"
                    Click="AiButton_Click" Margin="0,0,2,0" />
            <Button Name="OpenInButton" Content="📂"
                    ToolTip.Tip="Open in"
                    Click="OpenInButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
