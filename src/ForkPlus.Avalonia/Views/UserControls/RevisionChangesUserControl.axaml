<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="https://github.com/avaloniaui/avaloniaedit"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionChangesUserControl">
    <!--
        对照 WPF src/ForkPlus/UI/UserControls/RevisionChangesUserControl.xaml：
          - Grid 2 列 × 3 行 + ClipToBounds
            Col 0 (MinWidth=220 MaxWidth=850) / Col 1 (*)
            Row 0 (Auto, Header DockPanel Height=17)
            Row 1 (Auto, FilterTextBox AnimationPlaceholder)
            Row 2 (*, FileListUserControl)
          - Row 0 Col 0: Header DockPanel Height=17 BG=BackgroundBrush LastChildFill=False
            Left: FilterButton (SearchIcon, ToolTip="Filter")
            Right: FileListSettingsDropdownButton (DropDownButton + ListIcon + ToolTip="View Mode")
            Right: ShowDiffPopupButton (PreviewIcon, ToolTip="Show diff side-by-side (space bar)")
          - Row 1 Col 0 + Row 2 Col 0: FilterTextBox（RowSpan=2, Margin=4, AnimationPlaceholder）
          - Row 2 Col 0: FileListUserControl（BorderThickness=0,1,0,0 BorderBrush=BorderBrush）
          - Col 1 RowSpan=3: FileDiffControl
          - GridSplitter Col 0 RowSpan=3 (VerticalGridSplitter HAlign=Right)

        Avalonia 适配：
          - FilterTextBox → TextBox（spike 简化）
          - FileListUserControl → ListBox（spike）
          - DropDownButton → Button（spike 简化，无下拉菜单）
          - FileDiffControl → AvaloniaEdit TextEditor（spike）
    -->
    <!-- 对照 WPF：<ColumnDefinition MinWidth="220" MaxWidth="850" /> + <ColumnDefinition /> -->
    <Grid Name="ContainerGrid"
          ClipToBounds="True"
          RowDefinitions="Auto,Auto,*">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="220" MaxWidth="850" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Row 0 Col 0: Header DockPanel Height=17 BG=BackgroundBrush LastChildFill=False
             对照 WPF DockPanel Dock=Right 声明顺序：
               先声明 FileListSettingsDropdownButton(List) → 贴最右
               后声明 ShowDiffPopupButton(Preview) → 靠左 -->
        <DockPanel Grid.Row="0" Grid.Column="0"
                   Height="17"
                   HorizontalAlignment="Stretch"
                   Background="{DynamicResource BackgroundBrush}"
                   LastChildFill="False">
            <!-- Filter Button (Dock=Left, SearchIcon, ToolTip="Filter") -->
            <Button DockPanel.Dock="Left"
                    Name="FilterButton"
                    Margin="6,0,0,0"
                    ToolTip.Tip="Filter"
                    Classes="icon-btn"
                    Click="FilterButton_Click">
                <Image Source="/Assets/search.png" Width="14" Height="14" />
            </Button>
            <!-- FileListSettingsDropdownButton (Dock=Right, ListIcon, ToolTip="View Mode") 贴最右 -->
            <Button DockPanel.Dock="Right"
                    Name="FileListSettingsDropdownButton"
                    ToolTip.Tip="View Mode"
                    Classes="icon-btn"
                    Click="FileListSettingsDropdownButton_Click">
                <Image Source="/Assets/list.png" Width="14" Height="14" />
            </Button>
            <!-- ShowDiffPopupButton (Dock=Right, PreviewIcon) 靠左 -->
            <Button DockPanel.Dock="Right"
                    Name="ShowDiffPopupButton"
                    ToolTip.Tip="Show diff side-by-side (space bar)"
                    Classes="icon-btn"
                    Click="ShowDiffPopupButton_Click">
                <Image Source="/Assets/preview.png" Width="14" Height="14" />
            </Button>
        </DockPanel>

        <!-- Row 1-2 Col 0: Filter TextBox（RowSpan=2, Margin=4，对照 WPF FilterTextBox） -->
        <TextBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                 Name="FilterTextBox"
                 Margin="4"
                 Watermark="Filter files..."
                 IsVisible="False"
                 BorderThickness="0,0,0,1"
                 BorderBrush="{DynamicResource BorderBrush}" />

        <!-- Row 2 Col 0: FileListUserControl（对照 WPF FileListUserControl BorderThickness=0,1,0,0） -->
        <ListBox Grid.Row="2" Grid.Column="0"
                 Name="FileListBox"
                 Background="{DynamicResource BackgroundBrush}"
                 BorderThickness="0,1,0,0"
                 BorderBrush="{DynamicResource BorderBrush}"
                 SelectionChanged="FileListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ChangeTypeEmoji}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Col 1 RowSpan=3: FileDiffControl（对照 WPF FileDiffControl，spike 用 AvaloniaEdit） -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                Background="{DynamicResource BackgroundBrush}">
            <avalonEdit:TextEditor Name="DiffEditor"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                   FontSize="13" />
        </Border>

        <!-- GridSplitter（对照 WPF VerticalGridSplitter HAlign=Right） -->
        <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                      Name="GridSplitter"
                      Classes="vertical-grid-splitter"
                      HorizontalAlignment="Right"
                      ResizeDirection="Columns" />
    </Grid>
</UserControl>
