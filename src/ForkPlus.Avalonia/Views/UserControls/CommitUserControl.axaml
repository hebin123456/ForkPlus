<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.CommitUserControl">
    <!--
        Phase 3.8：Avalonia 版 CommitUserControl 骨架（spike 简化版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/CommitUserControl.xaml（79 行）：
          - 顶层 Grid 3 列：280 / 1 / *
            Col 0: StageFileUserControl（自嵌套子控件，staged/unstaged 文件列表）
            Col 1: GridSplitter
            Col 2: 嵌套 Grid 3 行：
              Row 0: CommitFileDiffControl（diff 渲染，依赖 AvalonEdit，Phase 3.9a 已占位）
              Row 1: Border（分隔线）
              Row 2: commit message 编辑区：
                - SpellingPlaceholderTextBox（subject 输入框，自定义控件）
                - CommitDescriptionTextBox（description，自定义控件）
                - DropDownButton（最近消息下拉，自定义控件）
                - CheckBox（Amend）
                - Button（Commit 按钮）
                - DropDownButton（Commit 设置下拉，自定义控件）

        对照 WPF 工程 src/ForkPlus/UI/UserControls/CommitUserControl.xaml.cs（2339 行）：
          - 18 个公共方法/属性
          - 关键公共方法：Initialize(repo) / ApplyLocalization / Refresh(SubDomain) /
            StageSelectedFiles / LoadCommitMessage / SaveCommitMessage / EraseSavedCommitMessage
          - 公共属性：RepositoryUserControl / FullCommitMessage / AmendMode / IsCommitAllowed /
            CommittingInProgress / StageJob / ShowIgnoredFiles / DontRefreshOnAmend
          - 无公共事件（用 NotificationCenter WeakEventManager 事件总线替代）
          - Initialize 注入模式：Initialize(RepositoryUserControl) 注入父控件，
            并向下注入 FileDiffControl.RepositoryUserControl

        装入路径（WPF）：
          RepositoryContentUserControl.xaml → CommitUserControl
          （由 RepositoryViewMode.CommitViewMode 触发显示，RevisionListViewUserControl 是 RevisionViewMode）

        本 spike 版策略：
          - StageFileUserControl 用 Border + TextBlock 占位（不创建独立 axaml）
          - CommitFileDiffControl 用 Phase 3.9a 的占位 UserControl
          - SpellingPlaceholderTextBox / CommitDescriptionTextBox 用 Avalonia TextBox 占位
          - DropDownButton 用 Avalonia Button 占位（不实现下拉）
          - 公共方法签名保留，body stub
          - 公共属性用 object/string/bool 等简单类型占位

        本 spike 版暂不迁移：
          - StageFileUserControl 真实实现（staged/unstaged 文件列表 + 拖拽 stage/unstage）
          - SpellingPlaceholderTextBox / CommitDescriptionTextBox 自定义控件（拼写检查 + 自动补全）
          - DropDownButton 自定义控件（最近消息下拉 + Commit 设置下拉）
          - GitmojiAutocompleteProvider / CommitMessageAutocompleteProvider 自动补全
          - NotificationCenter WeakEventManager 事件订阅
          - DiffPopupWindow 弹窗
          - UpdateDiff / LoadWorkingDirectoryDiff / LoadRawWorkingDirectoryDiff git diff 调用
          - RecentCommitMessagesContextMenu_Opened（AI commit 生成菜单）
          - Amend / Commit 真实逻辑（git commit amend / git commit）

        本 spike 版验证：
          - Grid 3 列布局正确显示
          - Col 0 stage files 占位可见
          - Col 2 Row 0 diff 占位可见
          - Col 2 Row 2 commit message 编辑区可见（subject + description + Amend + Commit button）
    -->
    <Grid Name="CommitGrid"
          ColumnDefinitions="280,Auto,*"
          Background="{DynamicResource ThemeBackgroundBrush}">

        <!-- Col 0: StageFileUserControl 占位（WPF 是自嵌套子控件）-->
        <Border Grid.Column="0"
                Name="StageFileContainer"
                Background="{DynamicResource ThemeCardBackgroundBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource ThemeBorderMidBrush}">
            <TextBlock Text="(stage files placeholder)"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                       Margin="8,4" />
        </Border>

        <!-- Col 1: GridSplitter -->
        <GridSplitter Grid.Column="1"
                      Name="CommitGridSplitter"
                      Width="4"
                      ResizeDirection="Columns"
                      Background="{DynamicResource ThemeBorderMidBrush}"
                      HorizontalAlignment="Stretch" />

        <!-- Col 2: 嵌套 Grid 3 行（diff + 分隔 + commit message 编辑区）-->
        <Grid Grid.Column="2"
              RowDefinitions="*,Auto,Auto">

            <!-- Row 0: CommitFileDiffControl（Phase 3.9a 占位 UserControl）-->
            <uc:CommitFileDiffControl Grid.Row="0"
                                      Name="CommitFileDiffControl" />

            <!-- Row 1: 分隔线 -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource ThemeBorderMidBrush}" />

            <!-- Row 2: commit message 编辑区 -->
            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto,Auto"
                  Margin="8,4">
                <TextBox Grid.Row="0"
                         Name="CommitSubjectTextBox"
                         Watermark="Commit subject"
                         Margin="0,2" />
                <TextBox Grid.Row="1"
                         Name="CommitDescriptionTextBox"
                         Watermark="Commit description"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="80"
                         Margin="0,2" />
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                    <CheckBox Name="AmendCheckBox"
                              Content="Amend"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                    <Button Name="RecentCommitMessagesButton"
                            Content="▾"
                            ToolTip.Tip="Recent commit messages"
                            Margin="0,0,4,0"
                            Click="RecentCommitMessagesButton_Click" />
                    <Button Name="CommitSettingsButton"
                            Content="⚙"
                            ToolTip.Tip="Commit settings"
                            Margin="0,0,4,0"
                            Click="CommitSettingsButton_Click" />
                    <Button Name="CommitButton"
                            Content="Commit"
                            Click="CommitButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
