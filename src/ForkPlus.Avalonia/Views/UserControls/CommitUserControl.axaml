<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             x:Class="ForkPlus.Avalonia.Views.UserControls.CommitUserControl">
    <!--
        Avalonia 版 CommitUserControl（完全对照 WPF 6b4cbff~1）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/CommitUserControl.xaml（79 行）：
          - 顶层 Grid 3 列：
              Col 0 Width=280 MinWidth=220 MaxWidth=850 → StageFileUserControl
              Col 1 Width=1                                  → GridSplitter (VerticalGridSplitter Style)
              Col 2 Width=* MinWidth=200                     → 嵌套 Grid 3 行
          - Col 2 嵌套 Grid Background=PanelBackgroundBrush：
              Row 0 (*,   DiffRow)    : CommitFileDiffControl (Background=HeaderToolbarBackgroundBrush)
              Row 1 (1,   BorderRow)  : Border (BorderThickness=1, BorderBrush=BorderBrush)
              Row 2 (Auto, MessageRow) : Grid Margin=15,15,15,15
                Row 0 (Height=24) :
                  - SpellingPlaceholderTextBox (CommitSubjectTextBox, BorderThickness=1,1,1,0,
                    Padding=4,1,74,1, Placeholder="Commit subject", Style=CommitPlaceholderTextBox)
                  - SubjectLengthLimitTextBlock (right-aligned, FontSize=12, Margin=1,3,47,1)
                  - ClearCommitMessageButton (18x18, X mark Path, right-aligned Margin=1,1,25,1)
                  - RecentCommitMessagesDropDownButton (18x18, ListIcon, right-aligned Margin=1,1,3,1)
                  - Border (1px line at bottom Margin=1,0,1,0)
                Row 1 (Auto) :
                  - CommitDescriptionTextBox (BorderThickness=1,0,1,1, TextWrapping=Wrap,
                    AcceptsReturn=True, Placeholder="Description", Margin=0,-1,0,0)
                Row 2 (Auto) :
                  - DockPanel LastChildFill=False Margin=0,8,0,0:
                    - Left: CheckBoxAmend (Content="Amend", Margin=0,6,0,4)
                    - Right: StagedDiffStatsContainer (added/removed TextBlocks) +
                             CommitButton (CommitButtonVisibleDropdownStyle) +
                             CommitDropdownButton (CommitDropDownButtonStyle, ToolTip="Commit Settings")
                    - Right: WarningMessageContainer (TextBlock + Warning.png image)

        对照 WPF 工程 src/ForkPlus/UI/UserControls/CommitUserControl.xaml.cs（2339 行）：
          - 18 个公共方法/属性（Initialize / ApplyLocalization / Refresh / StageSelectedFiles /
            LoadCommitMessage / SaveCommitMessage / EraseSavedCommitMessage / UpdateCommitMode /
            RefreshStageControls / UpdateCommitSection / FocusCommitMessageField / ToggleShowIgnoredFiles
            + 属性 RepositoryUserControl / FullCommitMessage / AmendMode / IsCommitAllowed /
            CommittingInProgress / StageJob / ShowIgnoredFiles / DontRefreshOnAmend）

        Avalonia 适配：
          - SpellingPlaceholderTextBox / CommitDescriptionTextBox → 标准 TextBox + Watermark
          - DropDownButton（最近消息/Commit 设置）→ 普通 Button（spike 不实现下拉 ContextMenu）
          - StageFileUserControl 双列表 → 内联 ItemsControl + DataTemplate
          - 拼写检查 → 省略（Avalonia 不原生支持）
          - 状态图标 PNG → emoji（M=📝 / A=✨ / D=🗑 / R=🔀 / Untracked=❓）
          - JobQueue → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          - PreferencesLocalization → ServiceLocator.Localization
          - Visibility.Collapsed/Visible → IsVisible = false/true
    -->
    <Grid Name="CommitGrid"
          ColumnDefinitions="280,Auto,*"
          Background="{DynamicResource ThemeBackgroundBrush}">

        <!-- Col 0: 文件列表面板（对照 WPF StageFileUserControl，spike 内联 ItemsControl）-->
        <Border Grid.Column="0"
                Name="StageFileContainer"
                Background="{DynamicResource ThemeCardBackgroundBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource ThemeBorderMidBrush}">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Row 0: 文件过滤搜索框 -->
                <TextBox Grid.Row="0"
                         Name="FileFilterTextBox"
                         Watermark="Filter files..."
                         Margin="6,4,6,2"
                         TextChanged="FileFilterTextBox_TextChanged" />

                <!-- Row 1: 工具栏按钮（Stage All / Unstage All / Discard） -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="6,2,6,4">
                    <Button Name="StageAllButton"
                            Content="Stage All"
                            Margin="0,0,4,0"
                            Click="StageAllButton_Click" />
                    <Button Name="UnstageAllButton"
                            Content="Unstage All"
                            Margin="0,0,4,0"
                            Click="UnstageAllButton_Click" />
                    <Button Name="DiscardButton"
                            Content="Discard"
                            Click="DiscardButton_Click" />
                </StackPanel>

                <!-- Row 2: 可滚动文件列表（CheckBox + emoji + 文件名） -->
                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="FileListItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      Margin="6,1"
                                      Background="Transparent">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsStaged, Mode=OneWay}"
                                              Click="FileRowStaged_Click"
                                              VerticalAlignment="Center"
                                              Margin="0,0,4,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusEmoji}"
                                               Margin="0,0,4,0"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Path}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               PointerPressed="FileRow_PointerPressed" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Col 1: GridSplitter（对照 WPF Width=1 + VerticalGridSplitter Style）-->
        <GridSplitter Grid.Column="1"
                      Name="CommitGridSplitter"
                      Classes="vertical-grid-splitter"
                      Width="1"
                      ResizeDirection="Columns"
                      Background="{DynamicResource BorderBrush}" />

        <!-- Col 2: 嵌套 Grid 3 行（diff / 分隔线 / commit message 编辑区）
             Background=PanelBackgroundBrush 对照 WPF -->
        <Grid Grid.Column="2"
              Background="{DynamicResource PanelBackgroundBrush}"
              RowDefinitions="*,Auto,Auto">

            <!-- Row 0: CommitFileDiffControl（对照 WPF Background=HeaderToolbarBackgroundBrush）-->
            <uc:CommitFileDiffControl Grid.Row="0"
                                      Name="CommitFileDiffControl"
                                      Background="{DynamicResource HeaderToolbarBackgroundBrush}" />

            <!-- Row 1: 1px 分隔线（对照 WPF Border BorderThickness=1 BorderBrush=BorderBrush）-->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderBrush}" />

            <!-- Row 2: commit message 编辑区（对照 WPF Grid Margin=15,15,15,15）-->
            <Grid Grid.Row="2"
                  RowDefinitions="24,Auto,Auto"
                  Margin="15,15,15,15">

                <!-- Row 0 (Height=24): Subject TextBox + 计数器 + Clear + Recent + 底部 1px Border
                     对照 WPF:
                       - SpellingPlaceholderTextBox (CommitSubjectTextBox, BorderThickness=1,1,1,0,
                         Padding=4,1,74,1, Placeholder="Commit subject")
                       - SubjectLengthLimitTextBlock (right Margin=1,3,47,1, FontSize=12)
                       - ClearCommitMessageButton (18x18, X mark, right Margin=1,1,25,1)
                       - RecentCommitMessagesDropDownButton (18x18, ListIcon, right Margin=1,1,3,1)
                       - Border (1px bottom Margin=1,0,1,0) -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto,Auto">
                    <!-- Subject TextBox（单行，BorderThickness=1,1,1,0 对照 WPF 上左右有边框、下无边框）-->
                    <TextBox Grid.Column="0"
                             Name="CommitSubjectTextBox"
                             Watermark="Commit subject"
                             BorderThickness="1,1,1,0"
                             Padding="4,1,74,1"
                             TextChanged="CommitSubjectTextBox_TextChanged"
                             GotFocus="CommitTextBox_GotFocus"
                             LostFocus="CommitTextBox_LostFocus" />
                    <!-- 长度计数器（对照 WPF SubjectLengthLimitTextBlock）-->
                    <TextBlock Grid.Column="1"
                               Name="SubjectLengthLimitTextBlock"
                               Margin="1,3,8,1"
                               FontSize="12"
                               VerticalAlignment="Center"
                               IsVisible="False" />
                    <!-- Clear 按钮（对照 WPF ClearCommitMessageButton，18x18 X mark Path）-->
                    <Button Grid.Column="2"
                            Name="ClearCommitMessageButton"
                            Classes="icon-btn"
                            Width="18"
                            Height="18"
                            Margin="0,1,2,1"
                            Padding="0"
                            ToolTip.Tip="Clear commit message"
                            Click="ClearCommitMessageButton_Click">
                        <Path Data="M3,3 L9,9 M9,3 L3,9"
                              Stroke="{DynamicResource ThemeForegroundMidBrush}"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" />
                    </Button>
                    <!-- Recent 下拉按钮（对照 WPF RecentCommitMessagesDropDownButton，18x18 ListIcon）-->
                    <Button Grid.Column="3"
                            Name="RecentCommitMessagesButton"
                            Classes="icon-btn"
                            Width="18"
                            Height="18"
                            Margin="0,1,3,1"
                            Padding="0"
                            ToolTip.Tip="Recent commit messages"
                            Click="RecentCommitMessagesButton_Click">
                        <Image Source="/Assets/list.png"
                               Width="14"
                               Height="14" />
                    </Button>
                </Grid>
                <!-- 底部 1px border（对照 WPF Border BorderThickness=1 Height=1 VerticalAlignment=Bottom Margin=1,0,1,0）
                     subject 与 description 之间的分隔线 -->
                <Border Grid.Row="0"
                        VerticalAlignment="Bottom"
                        Height="1"
                        Background="{DynamicResource BorderBrush}"
                        Margin="1,0,1,0"
                        IsHitTestVisible="False" />

                <!-- Row 1 (Auto): Description TextBox（多行，对照 WPF CommitDescriptionTextBox:
                     BorderThickness=1,0,1,1, TextWrapping=Wrap, AcceptsReturn=True,
                     Placeholder="Description", Margin=0,-1,0,0）
                     上无边框（与 subject 底部 border 重合），左右下有边框 -->
                <TextBox Grid.Row="1"
                         Name="CommitDescriptionTextBox"
                         Watermark="Description"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         BorderThickness="1,0,1,1"
                         Margin="0,-1,0,0"
                         MinHeight="60"
                         TextChanged="CommitDescriptionTextBox_TextChanged"
                         GotFocus="CommitTextBox_GotFocus"
                         LostFocus="CommitTextBox_LostFocus" />

                <!-- Row 2 (Auto): DockPanel Margin=0,8,0,0（对照 WPF LastChildFill=False）-->
                <DockPanel Grid.Row="2"
                           LastChildFill="False"
                           Margin="0,8,0,0">

                    <!-- Left: Amend CheckBox（对照 WPF DockPanel.Dock=Left Margin=0,6,0,4）-->
                    <CheckBox Name="AmendCheckBox"
                              Content="Amend"
                              DockPanel.Dock="Left"
                              Margin="0,6,0,4"
                              VerticalAlignment="Center"
                              Click="AmendCheckBox_Click" />

                    <!-- Right: StagedDiffStats + CommitButton + CommitDropdownButton
                         （对照 WPF DockPanel.Dock=Right StackPanel）-->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <!-- StagedDiffStatsContainer（对照 WPF StackPanel x:Name=StagedDiffStatsContainer）
                             - StagedDiffAddedRun (Foreground=Diff.Added.Foreground)
                             - 中间空格 TextBlock
                             - StagedDiffDeletedRun (Foreground=Diff.Removed.Foreground) -->
                        <StackPanel Name="StagedDiffStatsContainer"
                                    Margin="0,3,8,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Name="StagedDiffAddedTextBlock"
                                       FontSize="12"
                                       Foreground="{DynamicResource Diff.Added.Foreground}" />
                            <TextBlock Text=" "
                                       FontSize="12" />
                            <TextBlock Name="StagedDiffDeletedTextBlock"
                                       FontSize="12"
                                       Foreground="{DynamicResource Diff.Removed.Foreground}" />
                        </StackPanel>
                        <!-- CommitButton（对照 WPF CommitButton Style=CommitButtonVisibleDropdownStyle）-->
                        <Button Name="CommitButton"
                                Content="Commit"
                                Padding="10,2"
                                Margin="0"
                                Click="CommitButton_Click" />
                        <!-- CommitDropdownButton（对照 WPF CommitDropdownButton Style=CommitDropDownButtonStyle,
                             ToolTip="Commit Settings"）
                             spike 用 Button + 小箭头 Path 替代 DropDownButton -->
                        <Button Name="CommitSettingsButton"
                                Classes="icon-btn"
                                Width="18"
                                Height="24"
                                Margin="0"
                                Padding="0"
                                ToolTip.Tip="Commit settings"
                                Click="CommitSettingsButton_Click">
                            <Path Data="{DynamicResource ArrowGeometry}"
                                  Fill="{DynamicResource ThemeForegroundBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- Right: WarningMessageContainer（对照 WPF DockPanel.Dock=Right StackPanel）
                         - WarningTextBlock (Margin=4,2,4,2)
                         - Image (Warning.png, Width=16) -->
                    <StackPanel Name="WarningMessageContainer"
                                Orientation="Horizontal"
                                DockPanel.Dock="Right">
                        <TextBlock Name="WarningTextBlock"
                                   Margin="4,2,4,2"
                                   VerticalAlignment="Center" />
                        <Image Source="/Assets/warning.png"
                               Width="16"
                               Margin="0,4,4,4"
                               VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
