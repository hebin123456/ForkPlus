<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:ForkPlus.Avalonia.Views.UserControls"
             xmlns:avalonedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="ForkPlus.Avalonia.Views.UserControls.CommitUserControl">
    <!--
        Phase 5.3 完整迁移版：Avalonia 版 CommitUserControl。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/CommitUserControl.xaml（79 行）+
        CommitUserControl.xaml.cs（2339 行）：
          - 顶层 Grid 3 列：280 / 1 / *
            Col 0: StageFileUserControl（staged/unstaged 文件列表）
            Col 1: GridSplitter
            Col 2: 嵌套 Grid 3 行：CommitFileDiffControl / 分隔线 / commit message 编辑区

        Avalonia 版差异（Phase 5.3 完整迁移）：
          - StageFileUserControl 双列表 → 内联 ItemsControl + DataTemplate（CheckBox + emoji + 文件名）
          - SpellingPlaceholderTextBox / CommitDescriptionTextBox → 单个 AvaloniaEdit.TextEditor
            （CommitMessageTextBox，Document.Text 替代 .Text，Document.TextChanged 替代 TextChanged）
          - DropDownButton（最近消息/Commit 设置下拉）→ 普通 Button（spike 不实现下拉）
          - CommitMessageAutocompleteProvider / GitmojiAutocompleteProvider → 省略自动补全（保留注释）
          - 拼写检查 → 省略（Avalonia 不原生支持）
          - 状态图标 PNG → emoji（M=📝 / A=✨ / D=🗑 / R=🔀 / Untracked=❓）
          - JobQueue → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          - PreferencesLocalization → ServiceLocator.Localization
          - Application.Current.Resources[key] → Application.Current!.TryGetResource(key, null, out var v)
          - Visibility.Collapsed/Visible → IsVisible = false/true

        公共 API（对照 WPF 18 个公共方法/属性 + task spec 简化 API）：
          - Initialize / ApplyLocalization / Refresh(ChangedFile[], string[]) / Refresh(SubDomain)
          - StageSelectedFiles / LoadCommitMessage / SaveCommitMessage / EraseSavedCommitMessage
          - UpdateCommitMode / RefreshStageControls / UpdateCommitSection / FocusCommitMessageField
          - ToggleShowIgnoredFiles
          - task spec: SetCommitMessage / GetCommitMessage / StageFile / UnstageFile /
            StageAll / UnstageAll / DiscardChanges / Commit / CommitAndPush / AmendCommit
          - task spec 属性: CommitMessage / StagedFiles / UnstagedFiles / SelectedFile
          - WPF 属性: RepositoryUserControl / FullCommitMessage / AmendMode / IsCommitAllowed /
            CommittingInProgress / StageJob / ShowIgnoredFiles / DontRefreshOnAmend
    -->
    <Grid Name="CommitGrid"
          ColumnDefinitions="300,Auto,*"
          Background="{DynamicResource ThemeBackgroundBrush}">

        <!-- Col 0: 文件列表面板（staged/unstaged 文件列表，内联 ItemsControl + DataTemplate） -->
        <Border Grid.Column="0"
                 Name="StageFileContainer"
                 Background="{DynamicResource ThemeCardBackgroundBrush}"
                 BorderThickness="0,0,1,0"
                 BorderBrush="{DynamicResource ThemeBorderMidBrush}">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Row 0: 文件过滤搜索框 -->
                <TextBox Grid.Row="0"
                         Name="FileFilterTextBox"
                         Watermark="Filter files..."
                         Margin="6,4,6,2"
                         TextChanged="FileFilterTextBox_TextChanged" />

                <!-- Row 1: 工具栏按钮（Stage All / Unstage All / Discard） -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="6,2,6,4">
                    <Button Name="StageAllButton"
                            Content="Stage All"
                            Margin="0,0,4,0"
                            Click="StageAllButton_Click" />
                    <Button Name="UnstageAllButton"
                            Content="Unstage All"
                            Margin="0,0,4,0"
                            Click="UnstageAllButton_Click" />
                    <Button Name="DiscardButton"
                            Content="Discard"
                            Click="DiscardButton_Click" />
                </StackPanel>

                <!-- Row 2: 可滚动文件列表（CheckBox + emoji + 文件名） -->
                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="FileListItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      Margin="6,1"
                                      Background="Transparent">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsStaged, Mode=OneWay}"
                                              Click="FileRowStaged_Click"
                                              VerticalAlignment="Center"
                                              Margin="0,0,4,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusEmoji}"
                                               Margin="0,0,4,0"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Path}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               PointerPressed="FileRow_PointerPressed" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Col 1: GridSplitter -->
        <GridSplitter Grid.Column="1"
                      Name="CommitGridSplitter"
                      Width="4"
                      ResizeDirection="Columns"
                      Background="{DynamicResource ThemeBorderMidBrush}"
                      HorizontalAlignment="Stretch" />

        <!-- Col 2: 嵌套 Grid 3 行（diff / 分隔线 / commit message 编辑区） -->
        <Grid Grid.Column="2"
              RowDefinitions="*,Auto,Auto">

            <!-- Row 0: CommitFileDiffControl（diff 预览，Phase 3.9a 占位 UserControl） -->
            <uc:CommitFileDiffControl Grid.Row="0"
                                      Name="CommitFileDiffControl" />

            <!-- Row 1: 分隔线 -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource ThemeBorderMidBrush}" />

            <!-- Row 2: commit message 编辑区 -->
            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  Margin="8,4">

                <!-- Row 0: 提交消息编辑器（AvaloniaEdit TextEditor，多行） -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                        BorderThickness="1"
                        Height="120">
                    <avalonedit:TextEditor Name="CommitMessageTextBox"
                                           ShowLineNumbers="False"
                                           IsReadOnly="False"
                                           FontFamily="Consolas,Menlo,monospace"
                                           FontSize="13"
                                           WordWrap="True" />
                </Border>

                <!-- Row 1: subject 长度计数器 + 警告消息 -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto"
                      Margin="0,2">
                    <TextBlock Grid.Column="0"
                               Name="SubjectLengthLimitTextBlock"
                               Text=""
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Name="WarningTextBlock"
                               Text=""
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Column="2"
                               Name="StagedDiffStatsTextBlock"
                               Text=""
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </Grid>

                <!-- Row 2: 工具按钮行（Clear / Co-authored-by 模板） -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Margin="0,2">
                    <Button Name="ClearCommitMessageButton"
                            Content="Clear"
                            Margin="0,0,4,0"
                            Click="ClearCommitMessageButton_Click" />
                    <Button Name="InsertCoAuthoredButton"
                            Content="Co-authored-by"
                            ToolTip.Tip="Insert Co-authored-by template"
                            Margin="0,0,4,0"
                            Click="InsertCoAuthoredButton_Click" />
                </StackPanel>

                <!-- Row 3: Amend + Recent + Settings + Commit 按钮 -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                    <CheckBox Name="AmendCheckBox"
                              Content="Amend"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Click="AmendCheckBox_Click" />
                    <Button Name="RecentCommitMessagesButton"
                            Content="Recent"
                            ToolTip.Tip="Recent commit messages"
                            Margin="0,0,4,0"
                            Click="RecentCommitMessagesButton_Click" />
                    <Button Name="CommitSettingsButton"
                            Content="Settings"
                            ToolTip.Tip="Commit settings"
                            Margin="0,0,4,0"
                            Click="CommitSettingsButton_Click" />
                    <Button Name="CommitButton"
                            Content="Commit"
                            Click="CommitButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
