<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionListStatusBarUserControl">
    <!--
        Phase 3.5：Avalonia 版 RevisionListStatusBarUserControl（完整迁移版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/RevisionListStatusBarUserControl.xaml（31 行）：
          - 顶层 Border（Height=22, BorderThickness=0,0,0,1, BorderBrush=BorderBrush, Background=BackgroundBrush）
          - 内部 StackPanel horizontal：
            - HeaderTextBlock（Margin=10,0,6,0, Foreground=ForegroundBrush.Gray）
            - ReferencesTextBlock（Margin=0,0,6,0, Foreground=ForegroundBrush）
            - StatusBarButton（FontSize=12, Style=TextButtonStyle, Click=StatusBarButton_Click）

        Avalonia 版差异（spike 简化）：
          - DynamicResource BorderBrush/BackgroundBrush → ThemeBorderMidBrush/ThemeCardBackgroundBrush
          - DynamicResource ForegroundBrush.Gray/ForegroundBrush → ThemeForegroundLowBrush/ThemeForegroundBrush
          - DynamicResource TextButtonStyle → 不绑定样式（spike 用默认 Button 样式）
          - 新增 LoadingSpinner（ProgressBar IsIndeterminate=true，对照 task spec ShowLoading API）
          - 新增 CountTextBlock（对照 task spec SetCount API，显示 total/filtered 计数）
          - Visibility.Collapsed/Visible → IsVisible=false/true

        本 spike 版验证：
          - StackPanel horizontal 布局正确显示
          - HeaderTextBlock + ReferencesTextBlock + StatusBarButton 可见性可控
          - LoadingSpinner + CountTextBlock 占位可见
    -->
    <Border Name="Container"
            Height="22"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource ThemeBorderMidBrush}"
            Background="{DynamicResource ThemeCardBackgroundBrush}"
            IsVisible="False">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

            <!-- Loading 指示器（spike 新增，对照 task spec ShowLoading(bool) API）-->
            <ProgressBar Name="LoadingSpinner"
                         IsVisible="False"
                         IsIndeterminate="True"
                         Width="14"
                         Height="14"
                         Margin="10,0,6,0"
                         VerticalAlignment="Center" />

            <TextBlock Name="HeaderTextBlock"
                       Margin="10,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}" />

            <TextBlock Name="ReferencesTextBlock"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForegroundBrush}"
                       TextTrimming="CharacterEllipsis" />

            <Button Name="StatusBarButton"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Click="StatusBarButton_Click"
                    IsVisible="False" />

            <!-- 计数文本（spike 新增，对照 task spec SetCount(total, filtered) API）-->
            <TextBlock Name="CountTextBlock"
                       Margin="10,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForegroundLowBrush}"
                       FontSize="12"
                       IsVisible="False" />
        </StackPanel>
    </Border>
</UserControl>
