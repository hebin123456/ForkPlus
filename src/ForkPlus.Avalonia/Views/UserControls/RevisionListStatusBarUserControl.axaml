<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.RevisionListStatusBarUserControl">
    <!--
        对照 WPF src/ForkPlus/UI/UserControls/RevisionListStatusBarUserControl.xaml（30 行）：
          - Border Name=Container Height=22 BorderThickness=0,0,0,1 BorderBrush=BorderBrush Background=BackgroundBrush
          - StackPanel horizontal：
            - HeaderTextBlock Margin=10,0,6,0 Foreground=ForegroundBrush.Gray
            - ReferencesTextBlock Margin=0,0,6,0 Foreground=ForegroundBrush
            - StatusBarButton FontSize=12 Style=TextButtonStyle Click=StatusBarButton_Click

        Avalonia 适配：
          - DynamicResource BorderBrush/BackgroundBrush → ThemeBorderMidBrush/ThemeCardBackgroundBrush（等价）
          - DynamicResource ForegroundBrush.Gray/ForegroundBrush → ThemeForegroundLowBrush/ThemeForegroundBrush（等价）
          - DynamicResource TextButtonStyle → 不绑定样式（spike 用默认 Button 样式）
          - Visibility.Collapsed/Visible → IsVisible=false/true（由 code-behind 控制）

        装入路径：RevisionListViewUserControl Row 2 → RevisionListStatusBarUserControl
    -->
    <Border Name="Container"
            Height="22"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource BackgroundBrush}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Name="HeaderTextBlock"
                       Margin="10,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundBrush.Gray}" />

            <TextBlock Name="ReferencesTextBlock"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundBrush}" />

            <!-- StatusBarButton（对照 WPF Style=TextButtonStyle：透明背景、无边框的文本/链接按钮） -->
            <Button Name="StatusBarButton"
                    Classes="text-btn"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Click="StatusBarButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
