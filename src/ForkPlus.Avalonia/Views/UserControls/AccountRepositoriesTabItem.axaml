<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.AccountRepositoriesTabItem">
    <!--
        Avalonia 版 AccountRepositoriesTabItem（spike 简化新建版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/AccountRepositoriesTabItem.xaml（56 行）：
          - TabItem 基类，含 ResourceDictionary 两个 DataTemplate
            （AccountRepositoryItem / AccountHeaderItem）
          - FilterTextBox 控件（自定义过滤输入框）
          - RepositoriesListBox（按 Owner 分组的仓库列表）
          - FallbackUserControl（错误/加载提示）

        Avalonia 版差异（spike 简化）：
          - WPF TabItem 基类 → Avalonia UserControl
          - WPF FilterTextBox 自定义控件 → Avalonia TextBox + Watermark
          - WPF DataTemplate（AccountRepositoryItem / AccountHeaderItem）→
            spike DataTemplate 用 POCO + 内联 Grid
          - WPF FallbackUserControl → spike TextBlock 占位
          - WPF DockPanel → Grid ColumnDefinitions
          - WPF Image PNG 仓库图标 → TextBlock emoji（📦）
          - WPF Image Source={DynamicResource DownloadIcon} → TextBlock "⬇"
          - WPF ToolTip Binding → ToolTip.Tip Binding

        spike 简化：
          - JobQueue 异步加载仓库列表 → spike 不实现（需 Git 服务网络层），
            改用 SetRepositories(IEnumerable<GitServiceRepository>) 公共方法
          - DelayedAction filter 延迟 → spike 简化为直接过滤
          - CloneButton_Click 调用 MainWindow.Commands.ShowCloneWindow → onClone 回调注入
    -->
    <Grid RowDefinitions="30,*">
        <!-- Row 0: 过滤输入框 -->
        <TextBox Grid.Row="0"
                 Name="FilterTextBox"
                 Margin="4"
                 Watermark="Filter repositories..."
                 TextChanged="FilterTextBox_TextChanged" />

        <!-- Row 1: 仓库列表 -->
        <ListBox Grid.Row="1"
                 Name="RepositoriesListBox"
                 BorderThickness="0"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="10,0,0,0" ColumnDefinitions="*,Auto">
                        <!-- Col 0: 名称 + 图标 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📦"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       FontSize="11" />
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <!-- Col 1: Clone 按钮 -->
                        <Button Grid.Column="1"
                                Name="CloneButton"
                                VerticalAlignment="Center"
                                Padding="4,2"
                                Margin="2,0"
                                Click="CloneButton_Click"
                                Content="⬇"
                                ToolTip.Tip="{Binding Tooltip}"
                                IsVisible="{Binding IsRepository}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Row 1 (overlapping): 加载/错误提示 -->
        <Border Grid.Row="1"
                Name="FallbackPanel"
                Background="{DynamicResource ThemeBackgroundBrush}"
                IsVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Name="FallbackTitle"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           FontWeight="Medium"
                           Margin="0,0,0,4" />
                <TextBlock Name="FallbackMessage"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
