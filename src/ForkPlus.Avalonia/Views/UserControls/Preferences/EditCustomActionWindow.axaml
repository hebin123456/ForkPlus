<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Views.UserControls.Preferences.EditCustomActionWindow"
                              Title="Edit Action"
                              Width="540" Height="440"
                              CanResize="True"
                              WindowStartupLocation="CenterOwner">
    <!--
        Avalonia 版 EditCustomActionWindow（spike 简化新建版，继承 ForkPlusDialogWindow）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/Preferences/EditCustomActionWindow.xaml + .xaml.cs（298 行）：
          - public partial class EditCustomActionWindow : ForkPlusDialogWindow
          - 构造函数(CustomCommand, CustomCommandAction, showCancel)：
            * DialogTitle / DialogDescription / SubmitButtonTitle
            * RefreshControls(target, action)：按 action 类型切换 UI 显隐
            * CancelComboBoxItem.Show()（showCancel=true 时）
          - OutAction getter：按 ComboBoxItem 选择返回 Process/Sh/Url/Cancel action
          - CustomCommandTypeComboBox_SelectionChanged：切换 action 类型
          - ScriptPathButton_Click：OpenDialog.SelectFile
          - RefreshShowOutputCheckBox / RefreshStatus：状态更新
          - UpdateDescription(Inline[] inlines)：DescriptionTextBlock.Inlines

        Avalonia 版差异（spike 简化策略）：
          - WPF ForkPlusDialogWindow 基类动态构造 chrome == spike 子类 axaml 自带 Header + Footer
          - WPF Inlines（DescriptionTextBlock.Inlines.Add(new Run(...))）== spike
            改用 TextBlock.Text（spike 不用富文本）
          - WPF OpenDialog.SelectFile == spike 移除
          - WPF ForkPlusDialogStatus.Warning + SetStatus == spike 保留（基类已实现）
          - WPF FontConstants.MonospaceFontFamily == spike 硬编码 "Cascadia Mono,Consolas,monospace"
          - WPF target.CreateVariablesList（WPF 扩展方法）== spike 移除（spike 不显示变量列表）
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Text="Edit Action"
                   Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock2"
                   FontSize="12"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Action type -->
                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0"
                               Text="Type:"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1"
                              Name="CustomCommandTypeComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="CustomCommandTypeComboBox_SelectionChanged">
                        <ComboBoxItem Name="ProcessComboBoxItem" Content="Process" />
                        <ComboBoxItem Name="BashComboBoxItem" Content="Bash" />
                        <ComboBoxItem Name="UrlComboBoxItem" Content="URL" />
                        <ComboBoxItem Name="CancelComboBoxItem" Content="Cancel" IsVisible="False" />
                    </ComboBox>
                </Grid>

                <!-- Process: Script path -->
                <StackPanel Name="ProcessCustomCommandContainer" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0"
                                   Text="Script path:"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Name="ScriptPathTextBox"
                                 Watermark="${git} or path to executable"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,0,4,0"
                                 TextChanged="ScriptPathTextBox_TextChanged" />
                        <Button Grid.Column="2"
                                Content="Browse..."
                                FontSize="12"
                                Margin="4,0,0,0"
                                Click="ScriptPathButton_Click" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0"
                                   Text="Arguments:"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Name="ArgumentsTextBox"
                                 HorizontalAlignment="Stretch" />
                    </Grid>
                </StackPanel>

                <!-- Bash: Script -->
                <StackPanel Name="ShScriptContainer" Margin="0,0,0,8">
                    <TextBlock Name="ShScriptTextBlock"
                               Text="Script:"
                               FontSize="13"
                               Margin="0,0,0,4" />
                    <TextBox Name="ShScriptTextBox"
                             AcceptsReturn="True"
                             FontFamily="Cascadia Mono,Consolas,monospace"
                             FontSize="12"
                             MinHeight="100"
                             HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- URL -->
                <StackPanel Name="UrlContainer" Margin="0,0,0,8">
                    <TextBlock Name="UrlTextBlock"
                               Text="URL:"
                               FontSize="13"
                               Margin="0,0,0,4" />
                    <TextBox Name="UrlTextBox"
                             Watermark="https://..."
                             HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- Checkboxes (Process / Bash) -->
                <CheckBox Name="WaitForExitCheckBox"
                          Content="Wait for exit"
                          FontSize="13"
                          Margin="0,4,0,2"
                          Click="WaitForExitCheckBox_Changed" />
                <CheckBox Name="ShowOutputCheckBox"
                          Content="Show output"
                          FontSize="13"
                          Margin="0,2,0,4" />

                <!-- Description (spike: TextBlock.Text 替代 WPF Inlines) -->
                <TextBlock Name="DescriptionTextBlock"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                           Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
