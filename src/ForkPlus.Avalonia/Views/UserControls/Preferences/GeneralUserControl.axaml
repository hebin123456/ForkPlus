<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Views.UserControls.Preferences.GeneralUserControl">
    <!--
        Avalonia 版 GeneralUserControl（spike 简化新建版）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/Preferences/GeneralUserControl.xaml + .xaml.cs（357 行）：
          - Grid 多行：Source Dirs ListBox / Diff Code Editor / Sort Order RadioButtons /
            Fetch Options CheckBoxes / Space Character ComboBox / Language ComboBox
          - Initialize(ForkPlusDialogWindow)：读 ForkPlusSettings + RefreshSourceDirs +
            InitializeDiffCodeEditor + RefreshLanguageComboBoxItems
          - AddSrcDirButton / RemoveSrcDirButton / EditSrcDirButton（context menu）
          - TextBox TextChanged 写 ForkPlusSettings.Default + NotificationCenter.Raise*

        Avalonia 版差异（spike 简化策略）：
          - WPF ForkPlusDialogWindow _parentWindow == spike 用 object? 占位
          - WPF DiffCodeEditor（自定义控件）== spike 移除（spike 不渲染 diff 预览）
          - WPF RepositoryManager.Instance.SourceDirs == spike 保留（Core）
          - WPF OpenDialog.SelectDirectory == spike 移除（spike 用 stub 注释）
          - WPF NotificationCenter.Current.Raise* == spike 移除
          - WPF PreferencesLocalization.GetLanguages() == spike 保留（已 stub）
          - WPF SpaceCharacterComboBox.ItemsSource = Consts.Git.References.SpaceCharacterReplacements
            == spike 保留（Core 常量）
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="Auto,*" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Source dirs header -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Source directories:"
                       FontSize="13" FontWeight="Medium"
                       Margin="0,0,0,4" />

            <!-- Row 1: Source dirs ListBox + buttons -->
            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                <ListBox Grid.Column="0"
                         Name="SrcDirsListBox"
                         MinHeight="80" MaxHeight="160"
                         HorizontalAlignment="Stretch"
                         SelectionChanged="SrcDirsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Path}"
                                           FontSize="13"
                                           Margin="4,1,8,1"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Edit"
                                        FontSize="11"
                                        Margin="2,0"
                                        Click="EditSrcDirButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Column="1"
                        Name="AddSrcDirButton"
                        Content="Add"
                        FontSize="12"
                        Margin="4,0,2,0"
                        VerticalAlignment="Top"
                        Click="AddSrcDirButton_Click" />
                <Button Grid.Column="2"
                        Name="RemoveSrcDirButton"
                        Content="Remove"
                        FontSize="12"
                        Margin="2,0,0,0"
                        VerticalAlignment="Top"
                        Click="RemoveSrcDirButton_Click" />
            </Grid>

            <!-- Row 2: spacer -->
            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="6" />

            <!-- Row 3: Diff show change marks -->
            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="ShowDiffChangeMarksCheckBox"
                      Content="Show diff change marks"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="ShowDiffChangeMarksCheckBox_Click" />

            <!-- Row 4: Code editor font size -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Code editor font size:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,4,12,4" />
            <TextBox Grid.Row="4" Grid.Column="1"
                     Name="CodeEditorFontSizeTextBox"
                     HorizontalAlignment="Stretch"
                     Margin="0,4,0,4"
                     TextChanged="CodeEditorFontSizeTextBox_TextChanged" />

            <!-- Row 5: spacer -->
            <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Height="6" />

            <!-- Row 6: Sort order header -->
            <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Revision sort order:"
                       FontSize="13" FontWeight="Medium"
                       Margin="0,0,0,4" />

            <!-- Row 7: Sort order radios -->
            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Name="DateSortOrderRadioButton"
                             Content="Date"
                             FontSize="13"
                             Margin="0,0,16,0"
                             Click="SortOrderRadioButton_Click" />
                <RadioButton Name="TopologicalSortOrderRadioButton"
                             Content="Topological"
                             FontSize="13"
                             Click="SortOrderRadioButton_Click" />
            </StackPanel>

            <!-- Row 8: Fetch options header -->
            <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Fetch options:"
                       FontSize="13" FontWeight="Medium"
                       Margin="0,0,0,4" />

            <!-- Row 9: Fetch remotes automatically -->
            <CheckBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="FetchRemotesAutomaticallyCheckBox"
                      Content="Fetch remotes automatically"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="FetchRemotesAutomaticallyCheckBox_Click" />

            <!-- Row 10: Fetch all tags -->
            <CheckBox Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="FetchAllTagsCheckBox"
                      Content="Fetch all tags"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="FetchAllTagsCheckBox_Click" />

            <!-- Row 11: Update repo status / submodules / disable syntax highlighting -->
            <CheckBox Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="UpdateRepoStatusAutomaticallyCheckBox"
                      Content="Update repo status automatically"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="UpdateRepoStatusAutomaticallyCheckBox_Click" />
            <CheckBox Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="UpdateSubmodulesAutomaticallyCheckBox"
                      Content="Update submodules automatically on checkout"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="UpdateSubmodulesAutomaticallyCheckBox_Click" />
            <CheckBox Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="DisableSyntaxHighlightingCheckBox"
                      Content="Disable syntax highlighting"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="DisableSyntaxHighlightingCheckBox_Click" />

            <!-- Row 14: Space character + Push automatically + Compact labels + Undo/Redo -->
            <TextBlock Grid.Row="14" Grid.Column="0"
                       Text="Reference space character:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,4,12,4" />
            <ComboBox Grid.Row="14" Grid.Column="1"
                      Name="SpaceCharacterComboBox"
                      HorizontalAlignment="Stretch"
                      Margin="0,4,0,4"
                      SelectionChanged="SpaceCharacterComboBox_SelectionChanged" />

            <CheckBox Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="PushAutomaticallyOnCommitCheckBox"
                      Content="Push automatically on commit"
                      FontSize="13"
                      Margin="0,4,0,4"
                      Click="PushAutomaticallyOnCommitCheckBox_Click" />
            <CheckBox Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2"
                      Name="CompactBranchLabelsCheckBox"
                      Content="Compact branch labels"
                      FontSize="13"
                      Margin="0,28,0,4"
                      Click="CompactBranchLabelsCheckBox_Click" />

            <!-- Row 16: UI Language -->
            <TextBlock Grid.Row="16" Grid.Column="0"
                       Text="UI language:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,4,12,4" />
            <ComboBox Grid.Row="16" Grid.Column="1"
                      Name="LanguageComboBox"
                      HorizontalAlignment="Stretch"
                      Margin="0,4,0,4"
                      SelectionChanged="LanguageComboBox_SelectionChanged" />
        </Grid>
    </ScrollViewer>
</UserControl>
