  <SolidColorBrush x:Key="InteractiveRebase.ComboBoxButton.MouseOver" Color="{DynamicResource InteractiveRebase.ComboBoxButton.MouseOverColor}" />
  <SolidColorBrush x:Key="RevisionList.TagBorder" Color="{DynamicResource RevisionList.TagBorderColor}" />
  <SolidColorBrush x:Key="RevisionList.TagBackground" Color="{DynamicResource RevisionList.TagBackgroundColor}" />
  <SolidColorBrush x:Key="RevisionList.StashBorder" Color="{DynamicResource RevisionList.StashBorderColor}" />
  <SolidColorBrush x:Key="RevisionList.StashBackground" Color="{DynamicResource RevisionList.StashBackgroundColor}" />
  <SolidColorBrush x:Key="RevisionList.BisectGoodBorder" Color="{DynamicResource RevisionList.BisectGoodBorderColor}" />
  <SolidColorBrush x:Key="RevisionList.BisectGoodBackground" Color="{DynamicResource RevisionList.BisectGoodBackgroundColor}" />
  <SolidColorBrush x:Key="RevisionList.BisectBadBorder" Color="{DynamicResource RevisionList.BisectBadBorderColor}" />
  <SolidColorBrush x:Key="RevisionList.BisectBadBackground" Color="{DynamicResource RevisionList.BisectBadBackgroundColor}" />
  <SolidColorBrush x:Key="RevisionSummary.ReferenceBorder" Color="{DynamicResource RevisionSummary.ReferenceBorderColor}" />
  <SolidColorBrush x:Key="RevisionSummary.ReferenceBackground" Color="{DynamicResource RevisionSummary.ReferenceBackgroundColor}" />
  <SolidColorBrush x:Key="RevisionChanges.FallbackIconBackground" Color="{DynamicResource RevisionChanges.FallbackIconBackgroundColor}" />
  <SolidColorBrush x:Key="BinaryDiffBackground" Color="{DynamicResource BinaryDiffBackgroundColor}" />
  <SolidColorBrush x:Key="BinaryDiffBorder" Color="{DynamicResource BinaryDiffBorderColor}" />
  <SolidColorBrush x:Key="BinaryDiffProgressBackground" Color="{DynamicResource BinaryDiffProgressBackgroundColor}" />
  <SolidColorBrush x:Key="ShowButton.Static.Background" Color="{DynamicResource ShowButton.Static.BackgroundColor}" />
  <SolidColorBrush x:Key="ShowButton.Pressed.Background" Color="{DynamicResource ShowButton.Pressed.BackgroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.Static.Foreground" Color="{DynamicResource SliderThumb.Static.ForegroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.MouseOver.Background" Color="{DynamicResource SliderThumb.MouseOver.BackgroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.MouseOver.Border" Color="{DynamicResource SliderThumb.MouseOver.BorderColor}" />
  <SolidColorBrush x:Key="SliderThumb.Pressed.Background" Color="{DynamicResource SliderThumb.Pressed.BackgroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.Pressed.Border" Color="{DynamicResource SliderThumb.Pressed.BorderColor}" />
  <SolidColorBrush x:Key="SliderThumb.Disabled.Background" Color="{DynamicResource SliderThumb.Disabled.BackgroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.Disabled.Border" Color="{DynamicResource SliderThumb.Disabled.BorderColor}" />
  <SolidColorBrush x:Key="SliderThumb.Static.Background" Color="{DynamicResource SliderThumb.Static.BackgroundColor}" />
  <SolidColorBrush x:Key="SliderThumb.Static.Border" Color="{DynamicResource SliderThumb.Static.BorderColor}" />
  <SolidColorBrush x:Key="SliderThumb.Track.Border" Color="{DynamicResource SliderThumb.Track.BorderColor}" />
  <SolidColorBrush x:Key="SliderThumb.Track.Background" Color="{DynamicResource SliderThumb.Track.BackgroundColor}" />
  <SolidColorBrush x:Key="NoColorButtonBrush" Color="{DynamicResource NoColorButtonColor}" />

  <!-- ========== Theme* 别名（对照 Avalonia Fluent 命名约定）==========
       274 处 XAML 引用 ThemeXxxBrush（如 ThemeBackgroundBrush / ThemeBorderMidBrush /
       ThemeForegroundLowBrush / ThemeAccentBrush 等），由 FluentTheme 兜底提供。
       但本工程的 Colors.*.axaml + Brushes.axaml 切换主题时会覆盖 BackgroundColor 等
       基础 Color，FluentTheme 自带的 Theme*Brush 不会同步更新，导致运行时显示
       Fluent 默认色（与 22 套主题脱节）。
       此处显式定义 Theme*Brush 引用本工程 Color 资源，让主题切换时同步刷新。 -->
  <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="{DynamicResource BackgroundColor}" />
  <SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="{DynamicResource TileBackgroundColor}" />
  <SolidColorBrush x:Key="ThemeBorderMidBrush" Color="{DynamicResource BorderColor}" />
  <SolidColorBrush x:Key="ThemeBorderLowBrush" Color="{DynamicResource MouseOver.BorderColor}" />
  <SolidColorBrush x:Key="ThemeBorderHighBrush" Color="{DynamicResource BorderColor}" />
  <SolidColorBrush x:Key="ThemeAccentBrush" Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="ThemeHighlightBrush" Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="ThemeErrorBrush" Color="{DynamicResource Merge.StatusLabel.RedColor}" />
  <SolidColorBrush x:Key="ThemeForegroundBrush" Color="{DynamicResource ForegroundColor}" />
  <SolidColorBrush x:Key="ThemeForegroundMidBrush" Color="{DynamicResource SecondaryLabelColor}" />
  <SolidColorBrush x:Key="ThemeForegroundLowBrush" Color="{DynamicResource ForegroundColor.DimGray}" />
  <SolidColorBrush x:Key="ThemeControlMidBrush" Color="{DynamicResource GroupBoxBackgroundColor}" />
  <SolidColorBrush x:Key="ThemeControlLowBrush" Color="{DynamicResource MouseOver.BackgroundColor}" />
  <SolidColorBrush x:Key="ThemeControlDarkBrush" Color="{DynamicResource Pressed.BackgroundColor}" />
</ResourceDictionary>