<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.RemoveTagWindow"
                              Title="Delete Tag"
                              Width="590"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.41b：Avalonia 版 RemoveTagWindow（对照 WPF RemoveTagWindow.xaml 44 行 + .cs 127 行）。

        对照 WPF：
          - public partial class RemoveTagWindow : ForkPlusDialogWindow
          - 字段: RepositoryUserControl _repositoryUserControl / RepositoryReferences _references /
                  Tag[] _tags / RepositoryRemotes _remotes
          - 构造函数 (RepositoryUserControl, Tag[], RepositoryReferences)
          - 单个 tag: GitPointView.Value = tag，标题 "Delete Tag"
          - 多个 tag: GitPoints.ItemsSource = tags，标题 "Delete Tags" / "Delete {N} tags"
          - GetCommandPreview: "git tag -d tag1 tag2..." + 可选 push 到远端并删除
          - OnSubmit: RemoveTagGitCommand().Execute(...) → 过滤 PinnedReferences/FilterReferences
            → Close(Success 或 result)

        Avalonia 版差异：
          1. spike 模式：构造函数 SetFooter/Footer 注入
          2. RepositoryUserControl 参数 → GitModule + RepositoryReferences + Remote[] + Action onCompleted 回调
          3. GitPointView 自定义控件 → spike 版用 TextBlock 显示 tag name 简化
          4. GitPoints (ItemsControl + BindableGitPointView) → spike 版用 ItemsControl + DataTemplate 显示 tag name
          5. spike 基类不提供 GetCommandPreview/RefreshCommandPreview → 自行维护 CommandPreviewTextBlock
          6. spike 基类不提供 DisableEditableControls → 手动禁用 DeleteFromRemotesCheckBox
          7. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          8. Collapse/Show 扩展方法 → IsVisible = false / true
          9. PreferencesLocalization.Current/FormatCurrent → ServiceLocator.Localization
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Tag/Tags label + 单个 tag (TextBlock) 或 多个 tag (ItemsControl) -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Name="StartPointTextBlock"
                       Text="Tag:"
                       FontSize="13"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <!-- 单个 tag 时显示 -->
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Name="SingleTagTextBlock"
                       Margin="8,4,0,4"
                       FontSize="13"
                       IsVisible="False" />
            <!-- 多个 tag 时显示 -->
            <Border Grid.Row="0" Grid.Column="1"
                    Name="TagsContainer"
                    Margin="8,4,0,2"
                    Height="100"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    BorderThickness="1"
                    IsVisible="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="TagsItemsControl" Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <!-- Row 1: Delete from remotes checkbox -->
            <CheckBox Grid.Row="1" Grid.Column="1"
                      Name="DeleteFromRemotesCheckBox"
                      Margin="8,8,0,4"
                      HorizontalAlignment="Left"
                      FontSize="13"
                      IsCheckedChanged="DeleteFromRemotesCheckBox_Changed" />
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       FontWeight="Medium"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
