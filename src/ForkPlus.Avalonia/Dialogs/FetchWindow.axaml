<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.FetchWindow"
                              Title="Fetch"
                              Width="540"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0" Name="TitleTextBlock" FontSize="14" FontWeight="Medium" Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1" Name="DescriptionTextBlock" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" Margin="0,0,0,8" />

        <!-- Row 2: Content - Remote / FetchAll CheckBox / Command preview -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Remote ComboBox -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Remote:" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4" />
            <ComboBox Grid.Row="0" Grid.Column="1" Name="RemoteComboBox"
                      HorizontalAlignment="Stretch" Margin="0,4,0,4"
                      SelectionChanged="RemotesComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- Row 1: Fetch all remotes checkbox -->
            <CheckBox Grid.Row="1" Grid.Column="1" Name="FetchAllRemotesCheckBox"
                      Margin="0,4,0,4" HorizontalAlignment="Left" FontSize="13"
                      Content="Fetch all remotes"
                      IsCheckedChanged="FetchAllRemotesCheckBox_Changed" />
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Command:" FontSize="13"
                       FontWeight="Medium" Margin="0,8,8,4"
                       VerticalAlignment="Top" HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1" Name="CommandPreviewTextBox"
                     IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                     TextWrapping="Wrap" Margin="0,8,0,4" Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
