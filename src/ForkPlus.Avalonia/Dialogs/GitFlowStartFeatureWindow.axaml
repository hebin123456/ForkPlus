<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.GitFlowStartFeatureWindow"
                              Title="Start Git Flow feature"
                              Width="540"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.x：Avalonia 版 GitFlowStartFeatureWindow（对照 WPF GitFlowStartFeatureWindow.xaml 40 行 + .cs 147 行）。

        对照 WPF：
          - public partial class GitFlowStartFeatureWindow : ForkPlusDialogWindow
          - 字段: static string UnfinishedBranchName / GitModule _gitModule / LocalBranch[] _localBranches / GitFlowSettings _gitFlowSettings
          - 构造函数 (GitModule gitModule) → spike 改为 (GitModule, GitFlowSettings, LocalBranch[])
          - IsSubmitAllowed: ValidateGitFlow 失败 Warning / 重复分支 Warning
          - GetCommandPreview: "git flow feature start {name} {baseBranch.Name}"
          - OnSubmit: StartGitFlowFeatureGitCommand().Execute(...) → 失败 SaveUnfinishedBranchName / 成功 ClearUnfinishedBranchName → Close(result)

        Avalonia 版差异（spike）：
          1. 构造函数注入 GitFlowSettings + LocalBranch[] 替代 MainWindow 依赖
          2. spike 基类不提供 GetCommandPreview/RefreshCommandPreview → 自行维护 CommandPreviewTextBox
          3. spike 基类不提供 DisableEditableControls → 手动禁用 BranchesComboBox + FeatureNameTextBox
          4. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          5. PreferencesLocalization → ServiceLocator.Localization.Translate
          6. ReferenceTextBox.Placeholder → TextBox Watermark
          7. ComboBox ItemTemplate 绑定 Name（Reference 无 ToString 重写）
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0" Name="TitleTextBlock" FontSize="14" FontWeight="Medium" Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1" Name="DescriptionTextBlock" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" Margin="0,0,0,8" />

        <!-- Row 2: Content - ComboBox + TextBox + CommandPreview -->
        <Grid Grid.Row="2" Margin="0,4,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Base branch:" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,8,4" />
            <ComboBox Grid.Row="0" Grid.Column="1" Name="BranchesComboBox"
                      HorizontalAlignment="Stretch" Margin="0,4,0,4"
                      SelectionChanged="BranchesComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Feature name:" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,8,4" />
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,4">
                <TextBlock Name="FeaturePrefixTextBlock" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Name="FeatureNameTextBox" Watermark="Feature name" MinWidth="280"
                         TextChanged="FeatureName_TextChanged" />
            </StackPanel>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Command:" FontSize="13"
                       FontWeight="Medium" Margin="0,8,0,4" />
            <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                     Name="CommandPreviewTextBox" IsReadOnly="True" FontFamily="Consolas"
                     FontSize="12" TextWrapping="Wrap" Padding="6" Margin="0,0,0,0" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
