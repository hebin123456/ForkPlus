<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              xmlns:commands="clr-namespace:ForkPlus.Git.Commands;assembly=ForkPlus.Core"
                              x:Class="ForkPlus.Avalonia.Dialogs.ResetBranchWindow"
                              Title="Reset"
                              Width="560"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0" Name="TitleTextBlock" FontSize="14" FontWeight="Medium" Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1" Name="DescriptionTextBlock" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" Margin="0,4,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Branch:" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="1" Name="ActiveBranchTextBlock" FontSize="13"
                       Margin="8,4,0,4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Move to:" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="1" Name="DestinationTextBlock" FontSize="13"
                       Margin="8,4,0,4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Reset type:" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,4" />
            <ComboBox Grid.Row="2" Grid.Column="1" Name="ResetTypeCombobox"
                      HorizontalAlignment="Stretch" Margin="8,4,0,4"
                      SelectionChanged="ResetTypeCombobox_SelectionChanged">
                <ComboBoxItem Tag="{x:Static commands:BranchResetType.Soft}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="#FF34C84A" Margin="0,0,6,0" />
                        <TextBlock Text="Soft" Width="60" FontSize="13" />
                        <TextBlock Text="(S)" Width="30" FontSize="12"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <TextBlock Text="Keep all changes. Stage differences" FontSize="13" />
                    </StackPanel>
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static commands:BranchResetType.Mixed}" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="#FFFDBE41" Margin="0,0,6,0" />
                        <TextBlock Text="Mixed" Width="60" FontSize="13" />
                        <TextBlock Text="(M)" Width="30" FontSize="12"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <TextBlock Text="Keep all changes. Unstage differences" FontSize="13" />
                    </StackPanel>
                </ComboBoxItem>
                <ComboBoxItem Tag="{x:Static commands:BranchResetType.Hard}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="#FFFA4B49" Margin="0,0,6,0" />
                        <TextBlock Text="Hard" Width="60" FontSize="13" />
                        <TextBlock Text="(H)" Width="30" FontSize="12"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <TextBlock Text="Discard all local changes" FontSize="13" />
                    </StackPanel>
                </ComboBoxItem>
            </ComboBox>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Command:" FontSize="13"
                       FontWeight="Medium" Margin="0,8,0,4" />
            <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                     Name="CommandPreviewTextBox" IsReadOnly="True" FontFamily="Consolas"
                     FontSize="12" TextWrapping="Wrap" Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
