<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ForkPlus.Avalonia.Dialogs.ForkPlusDialogFooter">
    <!--
        Phase 4.0b：Avalonia 版 ForkPlusDialogFooter（从 WPF 工程迁移）。

        对照 WPF 工程 src/ForkPlus/UI/UserControls/ForkPlusDialogFooter.xaml（26 行）：
          - UserControl 包 DockPanel
          - DockPanel 4 个子控件：
            1. StackPanel (Dock=Right)：Submit Button (IsDefault=True) + Cancel Button
            2. ContentControl (Dock=Left, Name=CustomSection)：留给子类塞自定义内容
            3. ProgressBar (Dock=Left, Name=BusyIndicator, Visibility=Hidden,
               Style={DynamicResource CircularProgressBar})：14x14 圆形进度指示
            4. Image (Dock=Left, Name=StatusImage, Visibility=Collapsed, Source=Warning.png)
            5. TextBlock (Name=StatusMessageTextBlock, Visibility=Collapsed,
               TextTrimming=CharacterEllipsis)
          - 2 个 Click 事件：SubmitButton_Click + CancelButton_Click
          - AlignStatusRight() 方法：把 status 控件从 Left 改到 Right

        Avalonia 版差异（spike 简化策略）：
          1. DockPanel 改用 Grid + HorizontalAlignment（Avalonia 也支持 DockPanel，
             但 Grid + ColumnDefinitions 更直观）
          2. spike 版用 Avalonia.ProgressBar IsIndeterminate=True 替代 CircularProgressBar
             （WPF 的 CircularProgressBar 是自定义 Style，spike 不迁移样式，留 Phase 2.10）
          3. StatusImage 用 Avalonia TextBlock + emoji（"⚠" / "✓" / "✗"）替代 PNG
             （Avalonia.Image 加载 PNG 需要 Asset Path，spike 简化为 emoji）
          4. Cancel/Submit 事件用标准 .NET event，与 WPF 一致

        本 spike 版验证：
          - Submit/Cancel 按钮点击可触发事件
          - StatusMessage / BusyIndicator 可由 ForkPlusDialogWindow.SetStatus 控制
          - 整个 footer 可在 ForkPlusDialogWindow.axaml 中嵌入
    -->
    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="0,10,0,0">
        <!-- CustomSection：留给子类塞自定义内容（对照 WPF ContentControl Name=CustomSection） -->
        <ContentControl Grid.Column="0" Name="CustomSection" />

        <!-- BusyIndicator：14x14 圆形进度（spike 用 ProgressBar IsIndeterminate） -->
        <ProgressBar Grid.Column="1"
                     Name="BusyIndicator"
                     IsIndeterminate="True"
                     IsVisible="False"
                     Width="14"
                     Height="14"
                     Margin="0,0,5,0"
                     Foreground="{DynamicResource ThemeForegroundMidBrush}" />

        <!-- StatusImage：spike 用 TextBlock + emoji 替代 PNG（"⚠" / "✓" / "✗"） -->
        <TextBlock Grid.Column="2"
                   Name="StatusImage"
                   IsVisible="False"
                   FontSize="16"
                   Margin="0,0,5,0"
                   VerticalAlignment="Center" />

        <!-- StatusMessageTextBlock：状态消息（TextTrimming=CharacterEllipsis） -->
        <TextBlock Grid.Column="3"
                   Name="StatusMessageTextBlock"
                   IsVisible="False"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   TextTrimming="CharacterEllipsis" />

        <!-- Submit / Cancel 按钮（对照 WPF StackPanel Dock=Right） -->
        <Button Grid.Column="4"
                Name="SubmitButton"
                Content="Submit"
                Margin="4,0,4,0"
                Click="SubmitButton_Click" />

        <Button Grid.Column="5"
                Name="CancelButton"
                Content="Cancel"
                Margin="4,0,0,0"
                Click="CancelButton_Click" />
    </Grid>
</UserControl>
