<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.SaveSnapshotWindow"
                              Title="Save Snapshot"
                              Width="590"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.32b：Avalonia 版 SaveSnapshotWindow（对照 WPF SaveSnapshotWindow.xaml 32 行 + .cs 96 行）。

        对照 WPF：
          - public partial class SaveSnapshotWindow : ForkPlusDialogWindow
          - 字段: RepositoryUserControl _repositoryUserControl
          - 构造函数 (RepositoryUserControl repositoryUserControl)
          - GetCommandPreview override: git stash push with optional include-untracked and m flag
          - OnSubmit: SaveWorkingDirectoryAsStashGitCommand().Execute(gitModule, msg, stageNewFiles, sourceString, monitor)
            then Close(result)

        Avalonia 版差异：
          1. spike 模式结构：根 Grid 4 行 = Header / Content / Footer
          2. RepositoryUserControl 参数替换为 GitModule + RepositoryReferences + Action onCompleted 回调
          3. spike 基类不提供 GetCommandPreview/RefreshCommandPreview，自行维护 CommandPreviewTextBlock
          4. spike 基类不提供 DisableEditableControls，手动禁用 StashMessageTextBox + StageNewFilesCheckBox
          5. JobQueue + Dispatcher.Async 替换为 Task.Run + Dispatcher.UIThread.Post + JobMonitor
          6. PlaceholderTextBox.Placeholder 替换为 TextBox Watermark
          7. CheckBox Checked/Unchecked 事件替换为 IsCheckedChanged 事件
          8. TextChangedEventArgs 使用 Avalonia 同名类型
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Message label + TextBox -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Message:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="0" Grid.Column="1"
                     Name="StashMessageTextBox"
                     Watermark="Stash message (optional)"
                     Margin="8,4,0,4"
                     Padding="4,2,4,2"
                     FontSize="13"
                     TextChanged="StashMessageTextBox_TextChanged" />
            <!-- Row 2: Stage new files checkbox + hint -->
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" Margin="8,6,0,4">
                <CheckBox Name="StageNewFilesCheckBox"
                          Content="Stage new files"
                          FontSize="13"
                          IsCheckedChanged="StageNewFilesCheckBox_Changed" />
                <TextBlock Margin="20,0,0,0"
                           Text="By default stash ignores new files until you stage them"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            </StackPanel>
            <!-- Row 3: Command preview -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="3" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
