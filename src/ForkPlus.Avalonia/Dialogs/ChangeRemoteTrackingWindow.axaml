<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.ChangeRemoteTrackingWindow"
                              Title="Change Tracking Reference"
                              Width="540"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Branch label + name -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Branch:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Name="LocalBranchTextBlock"
                       Margin="8,4,0,4"
                       FontSize="13"
                       VerticalAlignment="Center" />
            <!-- Row 1: Track label + ComboBox -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Track:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <ComboBox Grid.Row="1" Grid.Column="1"
                      Name="RemoteBranchesComboBox"
                      Margin="8,4,0,4"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="RemoteBranchesComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <!-- Separator 项渲染为 Separator 控件；其它项渲染为 TextBlock Title -->
                            <Separator IsVisible="{Binding IsSeparator}" Margin="0,2" Width="200" />
                            <TextBlock Text="{Binding Title}" FontSize="13" VerticalAlignment="Center"
                                       IsVisible="{Binding IsTextItem}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
