<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.RemoveStashWindow"
                              Title="Delete Stash"
                              Width="590"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.36b：Avalonia 版 RemoveStashWindow（对照 WPF RemoveStashWindow.xaml + .cs 104 行）。
        GitPointView → TextBlock 单个；GitPoints → ItemsControl 多个。
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Stash label + name (单个) 或 ItemsControl (多个) -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Name="StartPointTextBlock"
                       Text="Stash:"
                       FontSize="13"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <!-- 单个 stash 时显示 -->
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Name="SingleStashTextBlock"
                       Margin="8,4,0,4"
                       FontSize="13"
                       IsVisible="False" />
            <!-- 多个 stash 时显示 -->
            <ItemsControl Grid.Row="0" Grid.Column="1"
                          Name="StashesItemsControl"
                          Margin="8,4,0,4"
                          IsVisible="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ReflogName}" FontSize="13" Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
