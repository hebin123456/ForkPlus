<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.CherryPickWindow"
                              Title="Cherry Pick"
                              Width="560"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0" Name="TitleTextBlock" FontSize="14" FontWeight="Medium" Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1" Name="DescriptionTextBlock" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" Margin="0,4,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Row 0: 单 commit 显示；多 commit 时通过 GitPointsContainer 显示 -->
            <TextBlock Grid.Row="0" Grid.Column="0" Name="GitPointTextBlock" FontSize="13"
                       VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,0,2" />
            <TextBlock Grid.Row="0" Grid.Column="1" Name="RevisionGitPointView" FontSize="13"
                       Margin="8,6,0,0" VerticalAlignment="Top" TextTrimming="CharacterEllipsis" />
            <!-- 多 commit 列表容器：与 RevisionGitPointView 同位置叠加，按可见性切换 -->
            <Border Grid.Row="0" Grid.Column="1" Name="GitPointsContainer"
                    Margin="8,6,0,2" MaxHeight="80" BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    IsVisible="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="GitPoints">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,1,0,1" FontSize="13" TextTrimming="CharacterEllipsis"
                                           Text="{Binding Message}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <!-- Row 1: Parent to skip (合并 commit 时显示) -->
            <TextBlock Grid.Row="1" Grid.Column="0" Name="RevisionParentTextBlock"
                       Text="Parent to skip:" FontSize="13" Margin="0,8,0,0"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       IsVisible="False" />
            <ComboBox Grid.Row="1" Grid.Column="1" Name="RevisionParentComboBox"
                      Margin="8,8,0,0" HorizontalAlignment="Stretch"
                      IsVisible="False"
                      SelectionChanged="RevisionParentComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" FontSize="13" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- Row 2: Commit checkbox -->
            <CheckBox Grid.Row="2" Grid.Column="1" Name="CommitCheckBox"
                      Content="Commit the changes"
                      FontSize="13" Margin="8,8,0,0" HorizontalAlignment="Left"
                      IsCheckedChanged="CommitCheckBox_Changed" />
            <!-- Row 3: Append origin sha checkbox -->
            <CheckBox Grid.Row="3" Grid.Column="1" Name="AppendOriginShaCheckBox"
                      Content="Append origin to commit message"
                      FontSize="13" Margin="8,8,0,0" HorizontalAlignment="Left"
                      IsCheckedChanged="AppendOriginShaCheckBox_Changed" />
            <!-- Row 4-5: Command preview -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Command:" FontSize="13"
                       FontWeight="Medium" Margin="0,8,0,4" />
            <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                     Name="CommandPreviewTextBox" IsReadOnly="True" FontFamily="Consolas"
                     FontSize="12" TextWrapping="Wrap" Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
