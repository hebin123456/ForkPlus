<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.Accounts.GitLabLoginWindow"
                              Title="Login to GitLab"
                              Width="450"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.25b：Avalonia 版 GitLabLoginWindow（对照 WPF GitLabLoginWindow.xaml 38 行 + .cs 147 行）。

        对照 WPF：
          - public partial class GitLabLoginWindow : ForkPlusDialogWindow, IServiceLoginWindow
          - 字段: JobQueue _jobQueue / bool _server / Account Account
          - 构造函数 (bool server = false, Account account = null):
            * !server: ServerTextBlock.Collapse() + ServerTextBox.Collapse()（隐藏 Server 输入框，使用 gitlab.com）
            * server: ServerTextBox.Text = account?.ServerUrl ?? "https://gitlab.com"
          - IsSubmitAllowed override: _server && Uri.TryCreate(ServerUrl) + !IsNullOrEmpty(Token)
          - OnSubmit: 根据 serverUrl 判断 RemoteType.Gitlab / RemoteType.GitlabServer
            构造 GitLabPrivateAccessTokenAuthentication / Connection / GitLabService
            → service.GetUser() → 成功则 LogOut 旧 + 创建新 Account + AddOrUpdate + CloseWithOk
          - OpenPersonalAccessTokenConfigurationUrlButton_Click: 打开 GitLab tokens URL

        Avalonia 版差异：
          1. spike 模式结构：根 Grid 4 行 = Header / Content / Footer
          2. PreferencesLocalization.Translate → ServiceLocator.Localization.Translate
          3. PlaceholderTextBox.Placeholder → TextBox Watermark
          4. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post
          5. DisableEditableControls/EnableEditableControls → 手动禁用 ServerTextBox + TokenTextBox
          6. MainWindow.ActiveRepositoryUserControl?.InvalidateAndRefresh → Action? onAccountChanged 回调
          7. ToolTip 设置：WPF Button.ToolTip="..." → Avalonia ToolTip.SetTip(button, ...)
          8. Collapse/Show 扩展方法 → IsVisible = false / true
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,4,0">
            <TextBlock Text="Log in to GitLab"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </StackPanel>
        <!-- Row 1: DescriptionTextBlock -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="140,*" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Separator (Row 0, span 2) -->
            <Separator Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" />
            <!-- Server (Row 1) -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Name="ServerTextBlock"
                       Text="Server:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="1" Grid.Column="1"
                     Name="ServerTextBox"
                     Watermark="https://gitlab.com"
                     Margin="10,4,0,4"
                     Padding="4,2,4,2"
                     FontSize="13" />
            <!-- Token (Row 2) -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Personal Access Token:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="TokenTextBox"
                     Watermark="Token with 'api write_repository' scopes"
                     Margin="10,4,0,4"
                     Padding="4,2,4,2"
                     FontSize="13" />
            <!-- Access token hint (Row 3) -->
            <StackPanel Grid.Row="3" Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="0,-6,0,0">
                <TextBlock Name="StatusTextBlock"
                           Margin="8,4,0,0"
                           FontSize="12"
                           Text="Manage " />
                <Button Name="OpenPersonalAccessTokenConfigurationUrlButton"
                        Content="personal access tokens"
                        Margin="0"
                        HorizontalAlignment="Left"
                        Click="OpenPersonalAccessTokenConfigurationUrlButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
