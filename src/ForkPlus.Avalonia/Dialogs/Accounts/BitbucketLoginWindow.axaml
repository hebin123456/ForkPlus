<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.Accounts.BitbucketLoginWindow"
                              Title="Login to Bitbucket"
                              Width="450"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.26b：Avalonia 版 BitbucketLoginWindow（对照 WPF BitbucketLoginWindow.xaml 55 行 + .cs 175 行）。

        对照 WPF：
          - public partial class BitbucketLoginWindow : ForkPlusDialogWindow, IServiceLoginWindow
          - 字段: JobQueue _jobQueue / AuthenticationItem[] / Account Account
          - 三字段: AuthenticationTypeComboBox + EmailTextBox + TokenTextBox（API Token 用 Basic Auth）
          - IsSubmitAllowed override: ComboBox 选中 AccessToken + !IsNullOrEmpty(Email) + !IsNullOrEmpty(Token)
          - AuthenticateWithAccessToken:
            * 构造 BasicAuthentication(null, email, token) + Connection + BitbucketService
            * service.GetUser() → 成功则创建 BitbucketBasicAuthentication + Account + AddOrUpdate
          - OpenApiTokensConfigurationUrlButton_Click: 打开 Atlassian API tokens URL

        Avalonia 版差异：
          1. spike 模式结构：根 Grid 4 行 = Header / Content / Footer
          2. PreferencesLocalization.Translate → ServiceLocator.Localization.Translate
          3. PlaceholderTextBox.Placeholder → TextBox Watermark
          4. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post
          5. DisableEditableControls/EnableEditableControls → 手动禁用 EmailTextBox + TokenTextBox + ComboBox
          6. MainWindow.ActiveRepositoryUserControl?.InvalidateAndRefresh → Action? onAccountChanged 回调
          7. Button.ToolTip → ToolTip.SetTip(button, ...)
          8. TextChanged 事件签名: EventArgs → TextChangedEventArgs
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,4,0">
            <TextBlock Text="Log in to Bitbucket"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </StackPanel>
        <!-- Row 1: DescriptionTextBlock -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Separator (Row 0) -->
            <Separator Grid.Row="0" Margin="0,0,0,8" />
            <!-- AuthenticationTypeComboBox (Row 1) -->
            <ComboBox Grid.Row="1"
                      Name="AuthenticationTypeComboBox"
                      Margin="95,4,0,6"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="AuthenticationTypeComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   Margin="0,0,4,0"
                                   Text="{Binding Title}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- TokenContainer (Row 2) -->
            <Grid Grid.Row="2" Name="TokenContainer" ColumnDefinitions="95,*">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>
                <!-- Email (Row 0) -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Email:"
                           Margin="0,0,8,0"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Name="EmailTextBox"
                         Watermark="Email"
                         Margin="0"
                         Padding="4,2,4,2"
                         FontSize="13" />
                <!-- API Token (Row 1) -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="API Token:"
                           Margin="0,4,8,0"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Name="TokenTextBox"
                         Watermark="Token"
                         Margin="0,4,0,0"
                         Padding="4,2,4,2"
                         FontSize="13" />
                <!-- Hint (Row 2) -->
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Name="StatusTextBlock"
                               Margin="0"
                               FontSize="12"
                               Text="Create" />
                    <Button Name="OpenApiTokensConfigurationUrlButton"
                            Content="API token with scopes"
                            Margin="2,-3,0,0"
                            HorizontalAlignment="Left"
                            Click="OpenApiTokensConfigurationUrlButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
