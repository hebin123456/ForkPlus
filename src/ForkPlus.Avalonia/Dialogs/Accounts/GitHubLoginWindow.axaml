<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.Accounts.GitHubLoginWindow"
                              Title="Login to GitHub"
                              Width="450"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.24b：Avalonia 版 GitHubLoginWindow（对照 WPF GitHubLoginWindow.xaml 52 行 + .cs 171 行）。

        对照 WPF：
          - public partial class GitHubLoginWindow : ForkPlusDialogWindow, IServiceLoginWindow
          - 字段: JobQueue _jobQueue / AuthenticationItem[] / Account Account
          - 构造函数 (Account account = null):
            * SubmitButtonTitle = "Sign In"
            * AuthenticationTypeComboBox.ItemsSource = _authenticationItems
            * SelectAuthenticationType(AccessToken)
            * TokenTextBox.TextChanged → UpdateSubmitButton
          - IsSubmitAllowed override: ComboBox 选中 AccessToken + !IsNullOrEmpty(TokenTextBox.Text)
          - OnSubmit: AuthenticateWithAccessToken
          - AuthenticateWithAccessToken:
            * 构造 GitHubAccessTokenAuthentication / Connection / GitHubService
            * service.GetUser() → 成功则 LogOut 旧 + 创建新 Account + AddOrUpdate + CloseWithOk
          - OpenPersonalAccessTokenConfigurationUrlButton_Click: 打开 GitHub tokens URL

        Avalonia 版差异：
          1. spike 模式结构：根 Grid 4 行 = Header / Content / Footer
          2. PreferencesLocalization.Current → ServiceLocator.Localization.Translate
          3. PlaceholderTextBox.Placeholder → TextBox Watermark
          4. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post
          5. DisableEditableControls/EnableEditableControls → 手动禁用 TokenTextBox + ComboBox
          6. MainWindow.ActiveRepositoryUserControl?.InvalidateAndRefresh → Action? onAccountChanged 回调
          7. base.Dispatcher.Async(TokenTextBox.Focus()) → Dispatcher.UIThread.Post(TokenTextBox.Focus())
          8. TextChanged 事件签名: EventArgs → TextChangedEventArgs
          9. SelectionChangedEventArgs → Avalonia 同名类型（namespace Avalonia.Controls）
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,4,0">
            <TextBlock Text="Log in to GitHub"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </StackPanel>
        <!-- Row 1: DescriptionTextBlock -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Separator (Row 0) -->
            <Separator Grid.Row="0" Margin="0,0,0,8" />
            <!-- AuthenticationTypeComboBox (Row 1) -->
            <ComboBox Grid.Row="1"
                      Name="AuthenticationTypeComboBox"
                      Margin="95,4,0,6"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="AuthenticationTypeComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   Margin="0,0,4,0"
                                   Text="{Binding Title}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- TokenContainer (Row 2) -->
            <Grid Grid.Row="2" Name="TokenContainer" ColumnDefinitions="95,*">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Access Token:"
                           Margin="0,0,8,0"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                <TextBox Grid.Column="1"
                         Name="TokenTextBox"
                         Watermark="Token"
                         Margin="0"
                         Padding="4,2,4,2"
                         FontSize="13"
                         TextChanged="TokenTextBox_TextChanged" />
                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Name="StatusTextBlock"
                               Margin="0"
                               FontSize="12"
                               Text="Manage" />
                    <Button Name="OpenPersonalAccessTokenConfigurationUrlButton"
                            Content="personal access tokens"
                            Margin="2,-3,0,0"
                            HorizontalAlignment="Left"
                            Click="OpenPersonalAccessTokenConfigurationUrlButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
