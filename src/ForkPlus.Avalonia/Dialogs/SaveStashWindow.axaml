<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.SaveStashWindow"
                              Title="Save Stash"
                              Width="590"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Avalonia 版 SaveStashWindow（对照 WPF SaveStashWindow.xaml + .cs 197 行）。

        对照 WPF：
          - public partial class SaveStashWindow : ForkPlusDialogWindow
          - 字段: GitModule _gitModule / bool _aiGenerating
          - 构造函数 (GitModule gitModule)
          - GetCommandPreview: git stash push [-m "msg"] [include untracked flag]
          - OnSubmit: SaveStashGitCommand().Execute(_gitModule, msg, stageNewFiles, monitor) then Close(result)
          - AiGenerateStashNameButton_Click: 读 workdir diff → OpenAiService.GenerateStashName → 流式写 TextBox

        Avalonia 版差异：
          1. spike 模式：4 行 Grid = Header / Description / Content / Footer
          2. RepositoryUserControl → GitModule + Action<GitCommandResult>? onCompleted 回调
          3. spike 基类不提供 GetCommandPreview/RefreshCommandPreview → 自行维护 CommandPreviewTextBox
          4. spike 基类不提供 DisableEditableControls → 手动禁用
          5. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          6. PlaceholderTextBox.Placeholder → TextBox Watermark
          7. CheckBox Checked/Unchecked 事件 → IsCheckedChanged 事件
          8. AiGenerateStashNameButton.Collapse() → IsVisible = false
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Message label + TextBox + AI button -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Message:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <Grid Grid.Row="0" Grid.Column="1" Margin="8,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Name="StashMessageTextBox"
                         Watermark="Stash message (optional)"
                         Padding="4,2,4,2"
                         FontSize="13"
                         TextChanged="StashMessageTextBox_TextChanged" />
                <Button Grid.Column="1"
                        Name="AiGenerateStashNameButton"
                        Content="🤖 AI"
                        Margin="6,0,0,0"
                        Padding="8,2"
                        Height="24"
                        FontSize="12"
                        VerticalAlignment="Center"
                        Click="AiGenerateStashNameButton_Click" />
            </Grid>
            <!-- Row 1: Stage new files checkbox + hint -->
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="8,6,0,4">
                <CheckBox Name="StageNewFilesCheckBox"
                          Content="Stage new files"
                          FontSize="13"
                          IsCheckedChanged="CheckBox_Changed" />
                <TextBlock Margin="20,0,0,0"
                           Text="By default stash ignores new files until you stage them"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
            </StackPanel>
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
