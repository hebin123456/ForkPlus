<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.PushMultipleTagsWindow"
                              Title="Push"
                              Width="540"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.43b：Avalonia 版 PushMultipleTagsWindow（对照 WPF PushMultipleTagsWindow.xaml 64 行 + .cs 130 行）。

        对照 WPF：
          - public partial class PushMultipleTagsWindow : ForkPlusDialogWindow
          - 字段: RepositoryUserControl _repositoryUserControl / Tag[] _tags / Remote _remoteToSelect
          - 构造函数 (RepositoryUserControl, Tag[] tags, Remote remote)
          - IsSubmitAllowed: RemotesComboBox.SelectedItem is Remote
          - GetCommandPreview: "git push remote.Name tag1.FullReference tag2.FullReference..."
          - OnSubmit: PushMultipleTagsGitCommand().Execute(...) → Close()

        Avalonia 版差异：
          1. spike 模式：构造函数 SetFooter/Footer 注入
          2. RepositoryUserControl 参数 → GitModule + Tag[] + Remote[] + Remote? + RepositoryReferences? + Action onCompleted 回调
          3. TagsItemsControl 用 Image + TextBlock → spike 版用 TextBlock 显示 tag name 简化（省略 TagIcon）
          4. spike 基类不提供 GetCommandPreview/RefreshCommandPreview → 自行维护 CommandPreviewTextBlock
          5. spike 基类不提供 DisableEditableControls → 手动禁用 RemotesComboBox
          6. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          7. ErrorWindow + InvalidateAndRefresh → spike 由 onCompleted 回调由调用方处理
          8. ComboBox ItemTemplate 用 Image + TextBlock → spike 版用 TextBlock 显示 Remote.Name 简化
          9. PreferencesLocalization.Translate → ServiceLocator.Localization.Translate
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Row 0: Tags: ItemsControl -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Tags:"
                       FontSize="13"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <Border Grid.Row="0" Grid.Column="1"
                    Margin="8,6,0,2"
                    MinHeight="80"
                    MaxHeight="180"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl Name="TagsItemsControl" Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="13" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <!-- Row 1: Remote: ComboBox -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Remote:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
            <ComboBox Grid.Row="1" Grid.Column="1"
                      Name="RemotesComboBox"
                      HorizontalAlignment="Stretch"
                      Margin="8,4,0,4"
                      SelectionChanged="RemotesComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- Row 2: Command preview -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       FontWeight="Medium"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
