<dialogs:ForkPlusDialogWindow xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:dialogs="clr-namespace:ForkPlus.Avalonia.Dialogs"
                              x:Class="ForkPlus.Avalonia.Dialogs.CreateBranchWindow"
                              Title="Create Branch"
                              Width="540"
                              SizeToContent="Height"
                              CanResize="False"
                              WindowStartupLocation="CenterOwner">
    <!--
        Phase 4.x：Avalonia 版 CreateBranchWindow（对照 WPF CreateBranchWindow.xaml 46 行 + .cs 419 行）。

        对照 WPF：
          - public partial class CreateBranchWindow : ForkPlusDialogWindow
          - 静态字段: string UnfinishedBranchName（保存上次未完成分支名）
          - 字段: RepositoryUserControl _repositoryUserControl / LocalBranch[] _localBranches
                  IGitPoint _gitPoint / bool _workingDirectoryIsDirty
          - 构造函数 (RepositoryUserControl, RepositoryReferences refs, IGitPoint gitPoint)
            * GitPointView.Value = gitPoint
            * CheckoutAfterCreateCheckBox.IsChecked = ForkPlusSettings.Default.CreateBranch_Checkout
            * StashAndReapply / DoNotChange RadioButton 默认根据 Checkout_StashAndReapply
            * RefreshUncommittedChangesOptionsVisibility()（仅 dirty + checkout 显示本地变更区）
            * ReferenceTextBox.SetAutocompleteProvider（spike 省略）
            * UnfinishedBranchName 不为空则预填，否则使用 RecentNewBranchPrefix
            * KeyDown/KeyUp 监听 Shift 切换 "Leave as stash"
          - IsSubmitAllowed: branchName 非空 + ReferenceNameValidator 通过 + 不与本地分支重名
          - GetCommandPreview: "git checkout -b <name> <gitPoint>" 或 "git branch <name> <gitPoint>"
            （checkout + dirty + StashAndReapply 时前置 "git stash\n"）
          - OnSubmit: 根据 RadioButtons 决定 StashAndReapply / Discard → PerformCreateBranch
            (可选 SaveStashGitCommand + CreateNewBranchGitCommand + 可选 ApplyStashGitCommand + UpdateSubmodulesGitCommand)
          - PerformCreateBranch: 递归处理 StashAndReapply.Possible → Required 转换

        Avalonia 版差异：
          1. spike 模式结构：根 Grid 4 行 = Header / Description / Content / Footer
          2. RepositoryUserControl 参数 → GitModule + RepositoryReferences? + IGitPoint? gitPoint
             + bool workingDirectoryIsDirty + SubmodulesToUpdate + Action<GitCommandResult>? onCompleted 回调
          3. GitPointView 自定义控件 → spike 版用 TextBlock 显示 gitPoint.FriendlyName 简化
          4. spike 基类不提供 GetCommandPreview/RefreshCommandPreview → 自行维护 CommandPreviewTextBox
          5. spike 基类不提供 DisableEditableControls → 手动禁用 TextBox + CheckBox + RadioButtons
          6. JobQueue + Dispatcher.Async → Task.Run + Dispatcher.UIThread.Post + JobMonitor
          7. KeyboardHelper.IsShiftDown shift 切换逻辑 → spike 版省略（"Leave as stash" UX 不迁移）
          8. ReferenceTextBox → 普通 TextBox（spike 不迁移 ReferenceNameAutocompleteProvider）
          9. CheckBox/RadioButton Checked/Unchecked 事件 → IsCheckedChanged 事件
         10. Image.Hide()/Show() → IsVisible = false/true
         11. DiscardWarningImage (PNG) → DiscardWarningText (emoji "⚠")
         12. PreferencesLocalization → ServiceLocator.Localization.Translate
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Row 0: Header -->
        <TextBlock Grid.Row="0"
                   Name="TitleTextBlock"
                   FontSize="14" FontWeight="Medium"
                   Margin="0,0,0,4" />
        <!-- Row 1: Description -->
        <TextBlock Grid.Row="1"
                   Name="DescriptionTextBlock"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   Margin="0,0,0,8" />

        <!-- Row 2: Content -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Create branch at -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Create branch at:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Name="GitPointTextBlock"
                       Margin="8,0,0,4"
                       FontSize="13"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- Row 1: Branch name -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Branch name:"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,8,4" />
            <TextBox Grid.Row="1" Grid.Column="1"
                     Name="BranchNameTextBox"
                     Watermark="Enter branch name"
                     Margin="8,4,0,4"
                     TextChanged="BranchName_TextChanged" />

            <!-- Row 2: Checkout checkbox -->
            <CheckBox Grid.Row="2" Grid.Column="1"
                      Name="CheckoutAfterCreateCheckBox"
                      Content="Check out after create"
                      Margin="8,5,0,0"
                      HorizontalAlignment="Left"
                      IsCheckedChanged="CheckoutAfterCreateCheckBox_Changed" />

            <!-- Row 3: Local changes label + RadioButtons -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Name="LocalChangesTextBlock"
                       Text="Local changes:"
                       FontSize="13"
                       Margin="0,10,0,0"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <StackPanel Grid.Row="3" Grid.Column="1"
                        Name="LocalChangesOptionsContainer"
                        Margin="8,5,0,0">
                <RadioButton Name="DoNotChangeRadioButton"
                             Content="Don't change"
                             FontSize="13"
                             Margin="0,6,0,0"
                             IsCheckedChanged="LocalChangesOption_Changed" />
                <RadioButton Name="StashAndReapplyRadioButton"
                             Content="Stash and reapply"
                             FontSize="13"
                             Margin="0,6,0,0"
                             IsCheckedChanged="LocalChangesOption_Changed" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Name="DiscardWarningText"
                               Text="⚠"
                               FontSize="14"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               IsVisible="False" />
                    <RadioButton Name="DiscardRadioButton"
                                 Content="Discard"
                                 FontSize="13"
                                 IsCheckedChanged="LocalChangesOption_Changed" />
                </StackPanel>
            </StackPanel>

            <!-- Row 4: Command preview -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Command:"
                       FontSize="13"
                       Margin="0,8,0,4"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Right" />
            <TextBox Grid.Row="4" Grid.Column="1"
                     Name="CommandPreviewTextBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="8,8,0,4"
                     Padding="6" />
        </Grid>

        <!-- Row 3: Footer -->
        <dialogs:ForkPlusDialogFooter Grid.Row="3" Name="Footer" />
    </Grid>
</dialogs:ForkPlusDialogWindow>
