<!-- Migrated from WPF to Avalonia: root xmlns updated to https://github.com/avaloniaui; redundant child xmlns/x declarations removed; MouseUp renamed to PointerReleased (matching code-behind RepositoriesListBox_MouseUp with PointerReleasedEventArgs); DataTemplate DataType simplified (removed {x:Type}); SnapsToDevicePixels attributes removed; LayoutTransform kept as-is for later migration; DataTemplate.Triggers kept as-is for later Selector migration. -->
<ui:CustomWindow Width="620" Height="370" ShowHeader="False" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1" Background="{DynamicResource BackgroundBrush}" xmlns="https://github.com/avaloniaui" xmlns:local="clr-namespace:ForkPlus.UI.QuickLaunch" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.QuickLaunch.QuickLaunchWindow" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <ui:CustomWindow.Resources>
    <ResourceDictionary>
      <Style x:Key="QuickLaunchListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="FrameworkElement.FocusVisualStyle">
          <Setter.Value>
            <x:Null />
          </Setter.Value>
        </Setter>
        <Setter Property="Control.Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ListBoxItem}">
              <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="0" Background="{TemplateBinding Panel.Background}" Padding="{TemplateBinding Control.Padding}" LayoutTransform="{DynamicResource LayoutScaleTransform}" Style="{DynamicResource ListItemRoundedBorderStyle}" x:Name="Bd">
                <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" />
              </Border>
              <ControlTemplate.Triggers>
                <MultiTrigger>
                  <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                    <Condition Property="ListBoxItem.IsSelected" Value="True" />
                  </MultiTrigger.Conditions>
                  <Setter TargetName="Bd" Value="{DynamicResource Item.SelectedActive.Background}" Property="Panel.Background" />
                  <Setter TargetName="Bd" Value="{DynamicResource Item.SelectedActive.Border}" Property="Border.BorderBrush" />
                  <Setter TargetName="Bd" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
                </MultiTrigger>
                <MultiTrigger>
                  <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="True" />
                    <Condition Property="ListBoxItem.IsSelected" Value="True" />
                  </MultiTrigger.Conditions>
                  <Setter TargetName="Bd" Value="{DynamicResource Item.SelectedActive.Background}" Property="Panel.Background" />
                  <Setter TargetName="Bd" Value="{DynamicResource Item.SelectedActive.Border}" Property="Border.BorderBrush" />
                  <Setter TargetName="Bd" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
                </MultiTrigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:CommandProviderItem}}" DataType="local:CommandProviderItem">
        <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
          <Image DockPanel.Dock="Left" Height="14" Width="14" VerticalAlignment="Bottom" Margin="0,0,4,4" x:Name="IconImage">
            <Image.Source>
              <Binding Path="Icon" />
            </Image.Source>
          </Image>
          <controls:FuzzyHighlightableTextBlock DockPanel.Dock="Left" FontSize="14" Margin="0,0,0,4" VerticalAlignment="Bottom" x:Name="NameTextBlock">
            <controls:FuzzyHighlightableTextBlock.Text>
              <Binding Path="Title" />
            </controls:FuzzyHighlightableTextBlock.Text>
            <controls:FuzzyHighlightableTextBlock.FuzzySearchString>
              <Binding Path="FuzzySearchString" />
            </controls:FuzzyHighlightableTextBlock.FuzzySearchString>
          </controls:FuzzyHighlightableTextBlock>
          <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="4,0,4,4" VerticalAlignment="Bottom" x:Name="DashTextBlock">
            <TextBlock.Visibility>
              <Binding Path="DescriptionVisibility" />
            </TextBlock.Visibility>
          </TextBlock>
          <controls:FuzzyHighlightableTextBlock FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Bottom" Margin="0,0,0,4" TextTrimming="CharacterEllipsis" x:Name="PathTextBlock">
            <controls:FuzzyHighlightableTextBlock.Text>
              <Binding Path="SecondaryTitle" />
            </controls:FuzzyHighlightableTextBlock.Text>
            <controls:FuzzyHighlightableTextBlock.FuzzySearchString>
              <Binding Path="FuzzySearchString" />
            </controls:FuzzyHighlightableTextBlock.FuzzySearchString>
          </controls:FuzzyHighlightableTextBlock>
        </DockPanel>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="PathTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="DashTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="IconImage" Property="Image.Source">
              <Setter.Value>
                <Binding Path="SelectedIcon" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:HeaderCommandProviderItem}}" DataType="local:HeaderCommandProviderItem">
        <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
          <TextBlock DockPanel.Dock="Left" FontSize="13.5" Margin="0,0,0,4" FontWeight="Medium" VerticalAlignment="Bottom" x:Name="NameTextBlock">
            <TextBlock.Text>
              <Binding Path="Title" />
            </TextBlock.Text>
          </TextBlock>
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:RepositoryInfoItem}}" DataType="local:RepositoryInfoItem">
        <DockPanel Height="25" LastChildFill="True" Margin="10,0,0,0">
          <Image DockPanel.Dock="Left" Height="14" Width="14" VerticalAlignment="Bottom" Margin="0,0,4,4" x:Name="IconImage">
            <Image.Source>
              <Binding Path="Icon" />
            </Image.Source>
          </Image>
          <controls:FuzzyHighlightableTextBlock DockPanel.Dock="Left" FontSize="14" Margin="0,0,0,4" VerticalAlignment="Bottom" x:Name="NameTextBlock">
            <controls:FuzzyHighlightableTextBlock.Text>
              <Binding Path="Title" />
            </controls:FuzzyHighlightableTextBlock.Text>
            <controls:FuzzyHighlightableTextBlock.FuzzySearchString>
              <Binding Path="FuzzySearchString" />
            </controls:FuzzyHighlightableTextBlock.FuzzySearchString>
          </controls:FuzzyHighlightableTextBlock>
          <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="4,0,4,4" VerticalAlignment="Bottom" x:Name="DashTextBlock">
            <TextBlock.Visibility>
              <Binding Path="DescriptionVisibility" />
            </TextBlock.Visibility>
          </TextBlock>
          <controls:FuzzyHighlightableTextBlock FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Bottom" Margin="0,0,0,4" TextTrimming="CharacterEllipsis" x:Name="PathTextBlock">
            <controls:FuzzyHighlightableTextBlock.Text>
              <Binding Path="SecondaryTitle" />
            </controls:FuzzyHighlightableTextBlock.Text>
            <controls:FuzzyHighlightableTextBlock.FuzzySearchString>
              <Binding Path="FuzzySearchString" />
            </controls:FuzzyHighlightableTextBlock.FuzzySearchString>
          </controls:FuzzyHighlightableTextBlock>
        </DockPanel>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="PathTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="DashTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="IconImage" Property="Image.Source">
              <Setter.Value>
                <Binding Path="SelectedIcon" />
              </Setter.Value>
            </Setter>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </ui:CustomWindow.Resources>
  <Grid Margin="0,10,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
      <StackPanel Orientation="Horizontal" Margin="10,0,0,7">
        <Image Source="{DynamicResource SearchIcon}" Margin="0,3,6,0" Width="16" />
        <controls:CommandTextBox FontSize="16" BorderThickness="0" x:Name="CommandTextBox" />
      </StackPanel>
    </Border>
    <ListBox Grid.Row="2" BorderThickness="0" SelectionMode="Single" Margin="0" ItemContainerStyle="{DynamicResource QuickLaunchListBoxItemStyle}" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.IsVirtualizing="True" PointerReleased="RepositoriesListBox_MouseUp" x:Name="RepositoriesListBox">
      <ListBox.FocusVisualStyle>
        <x:Null />
      </ListBox.FocusVisualStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <ContentControl>
            <ContentControl.Content>
              <Binding />
            </ContentControl.Content>
          </ContentControl>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</ui:CustomWindow>
