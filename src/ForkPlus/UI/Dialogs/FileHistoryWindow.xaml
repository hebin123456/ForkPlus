<ui:CustomWindow xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.FileHistoryWindow" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls">
  <ui:CustomWindow.Resources>
    <ResourceDictionary xmlns="https://github.com/avaloniaui">
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:HistoryEntryViewModel}}" DataType="{x:Type dialogs:HistoryEntryViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="57">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="52" />
            <ColumnDefinition Width="18" />
          </Grid.ColumnDefinitions>
          <Grid Grid.Row="0" Grid.Column="0" Width="14" Height="14" Margin="4,0,4,0" VerticalAlignment="Center">
            <controls:AvatarImage>
              <controls:AvatarImage.UserIdentity>
                <Binding Path="Author" />
              </controls:AvatarImage.UserIdentity>
            </controls:AvatarImage>
          </Grid>
          <TextBlock Grid.Row="0" Grid.Column="1" Margin="4,0,4,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="12">
            <TextBlock.Text>
              <Binding Path="AuthorName" />
            </TextBlock.Text>
          </TextBlock>
          <TextBlock Grid.Row="0" Grid.Column="2" Margin="4,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="AuthorDateTextBlock">
            <TextBlock.Text>
              <Binding Path="AuthorDate" />
            </TextBlock.Text>
            <TextBlock.ToolTip>
              <TextBlock>
                <TextBlock.Text>
                  <Binding Path="AuthorDate" />
                </TextBlock.Text>
              </TextBlock>
            </TextBlock.ToolTip>
          </TextBlock>
          <TextBlock Grid.Column="3" Margin="6,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="ShaTextBlock">
            <TextBlock.Text>
              <Binding Path="AbbreviatedSha" />
            </TextBlock.Text>
          </TextBlock>
          <Button Grid.Column="4" Width="14" Height="14" Padding="1" Margin="4,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" BorderThickness="0" Background="#00FFFFFF" Style="{DynamicResource IconButtonStyle}" Click="OpenRevisionInSeparateWindowButton_Click">
            <Button.ToolTip>
              <Binding Path="OpenInSeparateWindowButtonToolTip" />
            </Button.ToolTip>
            <Image Source="{DynamicResource OpenInSeparateWindowIcon}" Height="12" Width="12" />
          </Button>
          <controls:AutoTooltipTextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="4,0,2,0" FontSize="13" VerticalAlignment="Center" x:Name="RevisionSubjectTextBlock">
            <controls:AutoTooltipTextBlock.Text>
              <Binding Path="RevisionSubject" />
            </controls:AutoTooltipTextBlock.Text>
            <controls:AutoTooltipTextBlock.ToolTip>
              <Binding Path="RevisionSubject" />
            </controls:AutoTooltipTextBlock.ToolTip>
          </controls:AutoTooltipTextBlock>
          <Image Grid.Row="2" Grid.Column="0" Height="14" Width="14" Margin="4,0,4,0" VerticalAlignment="Center">
            <Image.Source>
              <Binding Path="StatusImage" />
            </Image.Source>
          </Image>
          <controls:AutoTooltipTextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="4,0,2,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="PathTextBlock">
            <controls:AutoTooltipTextBlock.Text>
              <Binding Path="Path" />
            </controls:AutoTooltipTextBlock.Text>
          </controls:AutoTooltipTextBlock>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type controls:TreeViewControlItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="PathTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="RevisionSubjectTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="AuthorDateTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="ShaTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:FolderHistoryEntryViewModel}}" DataType="{x:Type dialogs:FolderHistoryEntryViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="18">
          <Grid.ToolTip>
            <StackPanel Orientation="Horizontal">
              <TextBlock>
                <TextBlock.Text>
                  <Binding Path="AbbreviatedSha" />
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="" Margin="4,0,4,0" />
              <TextBlock>
                <TextBlock.Text>
                  <Binding Path="RevisionSubject" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </Grid.ToolTip>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="18" />
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0" Width="14" Height="14" Margin="4,0,4,0">
            <controls:AvatarImage x:Name="AuthorAvatarImage">
              <controls:AvatarImage.UserIdentity>
                <Binding Path="Author" />
              </controls:AvatarImage.UserIdentity>
            </controls:AvatarImage>
          </Grid>
          <TextBlock Grid.Column="1" Margin="4,0,2,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13" x:Name="RevisionSubjectTextBlock">
            <TextBlock.Text>
              <Binding Path="RevisionSubject" />
            </TextBlock.Text>
          </TextBlock>
          <TextBlock Grid.Column="2" Margin="2,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryLabelBrush}" FontSize="12" x:Name="AuthorDateTextBlock">
            <TextBlock.Text>
              <Binding Path="AuthorDate" />
            </TextBlock.Text>
            <TextBlock.ToolTip>
              <TextBlock>
                <TextBlock.Text>
                  <Binding Path="AuthorDate" />
                </TextBlock.Text>
              </TextBlock>
            </TextBlock.ToolTip>
          </TextBlock>
          <Button Grid.Column="4" Width="14" Height="14" Padding="1" Margin="4,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" BorderThickness="0" Background="#00FFFFFF" Style="{DynamicResource IconButtonStyle}" Click="OpenRevisionInSeparateWindowButton_Click">
            <Button.ToolTip>
              <Binding Path="OpenInSeparateWindowButtonToolTip" />
            </Button.ToolTip>
            <Image Source="{DynamicResource OpenInSeparateWindowIcon}" Height="12" Width="12" />
          </Button>
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:SubItemFileHistoryEntryViewModel}}" DataType="{x:Type dialogs:SubItemFileHistoryEntryViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Image Grid.Column="0" VerticalAlignment="Center" Margin="10,0,2,0" Width="12" Height="12">
            <Image.Source>
              <Binding Path="StatusImage" />
            </Image.Source>
          </Image>
          <Image Grid.Column="1" VerticalAlignment="Center" Margin="2" Width="12" Height="12">
            <Image.Source>
              <Binding Path="FileTypeIcon" />
            </Image.Source>
          </Image>
          <controls:AutoTooltipTextBlock Grid.Column="2" FontSize="12" x:Name="PathTextBlock">
            <controls:AutoTooltipTextBlock.Text>
              <Binding Path="Path" />
            </controls:AutoTooltipTextBlock.Text>
          </controls:AutoTooltipTextBlock>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type controls:TreeViewControlItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="PathTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </ui:CustomWindow.Resources>
  <Grid Margin="20,0,20,20" xmlns="https://github.com/avaloniaui">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <DockPanel>
      <TextBlock DockPanel.Dock="Left" Text="History" Margin="4,0,0,2" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" x:Name="HistoryTitleTextBlock" />
      <Image DockPanel.Dock="Left" Width="14" Height="14" Margin="8,0,4,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FileIcon" />
      <controls:GitPointView DockPanel.Dock="Right" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="TargetReferenceGitPointView" />
      <ProgressBar DockPanel.Dock="Right" Margin="0,0,5,0" Style="{DynamicResource CircularProgressBar}" Visibility="Visible" Width="14" Height="14" Foreground="{DynamicResource ForegroundBrush.Gray}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="BusyIndicator" />
      <controls:FilePathTextBlock FontSize="14" VerticalAlignment="Center" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FileNameTextBlock" />
    </DockPanel>
    <Border Grid.Row="1" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderBrush}" Height="17" VerticalAlignment="Top" />
    <controls:RevisionTimeLine Grid.Row="1" Height="46" Margin="1,1,1,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RevisionTimeLine" />
    <Grid Grid.Row="2" Background="{DynamicResource BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="150" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <controls:MultiselectionTreeView SelectionChanged="TreeView_SelectionChanged" ContextMenuOpening="TreeView_ContextMenuOpening" MouseDoubleClick="TreeView_MouseDoubleClick" Grid.Column="0" Margin="0" Style="{DynamicResource FileHistoryMultiselectionTreeViewStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="TreeView">
        <controls:MultiselectionTreeView.ContextMenu>
          <ContextMenu />
        </controls:MultiselectionTreeView.ContextMenu>
      </controls:MultiselectionTreeView>
      <Border Grid.Column="2" BorderThickness="0,1,1,1" BorderBrush="{DynamicResource BorderBrush}" RenderOptions.ClearTypeHint="Enabled">
        <controls:FileDiffControl Target="History" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FileDiffControl" />
      </Border>
      <GridSplitter Grid.Column="1" Style="{DynamicResource VerticalGridSplitter}" />
      <userControls:FallbackUserControl BorderThickness="1" Grid.Column="0" Grid.ColumnSpan="3" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="CodeEditorFallbackUserControl" />
    </Grid>
  </Grid>
</ui:CustomWindow>