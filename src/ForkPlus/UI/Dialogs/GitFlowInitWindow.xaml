<dialogs:ForkPlusDialogWindow Width="540" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.GitFlowInitWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="24" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Production Branch:" />
      <controls:ReferenceTextBox TextChanged="MasterBranchTextBox_TextChanged" Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="master" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="MasterBranchTextBox" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Development Branch:" />
      <controls:ReferenceTextBox TextChanged="DevelopBranchTextBox_TextChanged" Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="develop" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="DevelopBranchTextBox" />
      <TextBlock Grid.Row="3" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Feature Prefix:" />
      <controls:ReferenceTextBox TextChanged="FeaturePrefixTextBox_TextChanged" Grid.Row="3" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="feature/" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FeaturePrefixTextBox" />
      <TextBlock Grid.Row="4" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Release Prefix:" />
      <controls:ReferenceTextBox TextChanged="ReleasePrefixTextBox_TextChanged" Grid.Row="4" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="release/" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ReleasePrefixTextBox" />
      <TextBlock Grid.Row="5" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Hotfix Prefix:" />
      <controls:ReferenceTextBox TextChanged="HotfixPrefixTextBox_TextChanged" Grid.Row="5" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="hotfix/" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="HotfixPrefixTextBox" />
      <TextBlock Grid.Row="6" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Version Tag Prefix:" />
      <controls:ReferenceTextBox TextChanged="VersionTagPrefixTextBox_TextChanged" Grid.Row="6" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="VersionTagPrefixTextBox" />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>