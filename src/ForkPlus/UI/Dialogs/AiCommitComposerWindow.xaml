<ui:CustomWindow ResizeMode="CanResizeWithGrip" Height="640" Width="1024" MinHeight="420" MinWidth="720" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" x:Class="ForkPlus.UI.Dialogs.AiCommitComposerWindow">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <!-- Title bar: title + model + retry + stop -->
    <DockPanel Grid.Row="0" Margin="12,8,12,4" LastChildFill="True">
      <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" x:Name="TitleTextBlock" Text="AI Commit Composer" />
      <Button DockPanel.Dock="Right" MinWidth="64" Padding="10,2" Margin="6,0,0,0" Content="Stop" x:Name="StopButton" Visibility="Collapsed" Click="StopButton_Click" ToolTip="Stop the current AI task" />
      <Button DockPanel.Dock="Right" MinWidth="64" Padding="10,2" Margin="6,0,0,0" Content="Retry" x:Name="RetryButton" Click="RetryButton_Click" ToolTip="Retry" />
      <ComboBox DockPanel.Dock="Right" x:Name="ModelComboBox" FontSize="11" MinWidth="160" MaxWidth="280" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" ToolTip="Select AI model" SelectionChanged="ModelComboBox_SelectionChanged">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </DockPanel>
    <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="0" />
    <!-- Status bar -->
    <DockPanel Grid.Row="1" Margin="12,4,12,6" LastChildFill="True">
      <ProgressBar DockPanel.Dock="Left" Width="140" Height="3" IsIndeterminate="True" Visibility="Collapsed" x:Name="StatusProgressBar" Foreground="{DynamicResource AccentColorBrush}" />
      <TextBlock DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" x:Name="StatusTextBlock" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}" />
    </DockPanel>
    <!-- Main content: 3 columns (groups / files / commit message) -->
    <Grid Grid.Row="2" Margin="12,4,12,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="180" />
        <ColumnDefinition Width="6" />
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition Width="6" />
        <ColumnDefinition Width="380" MinWidth="240" />
      </Grid.ColumnDefinitions>
      <!-- Column 1: Commit groups -->
      <DockPanel Grid.Column="0">
        <TextBlock DockPanel.Dock="Top" FontSize="12" FontWeight="Medium" Margin="0,0,0,4" x:Name="GroupsHeaderLabel" Text="Commit Groups" />
        <ListBox x:Name="GroupsListBox" SelectionChanged="GroupsListBox_SelectionChanged" />
      </DockPanel>
      <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />
      <!-- Column 2: Files in selected group -->
      <DockPanel Grid.Column="2">
        <TextBlock DockPanel.Dock="Top" FontSize="12" FontWeight="Medium" Margin="0,0,0,4" x:Name="FilesHeaderLabel" Text="Files in this group" />
        <ListBox x:Name="FilesListBox" FontFamily="Consolas" FontSize="12" />
      </DockPanel>
      <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />
      <!-- Column 3: Commit message editor -->
      <DockPanel Grid.Column="4">
        <TextBlock DockPanel.Dock="Top" FontSize="12" FontWeight="Medium" Margin="0,0,0,4" x:Name="MessageHeaderLabel" Text="Commit Message" />
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <controls:PlaceholderTextBox Grid.Row="0" x:Name="SubjectTextBox" Placeholder="Subject" Padding="6,4" FontSize="13" TextChanged="SubjectTextBox_TextChanged" />
          <controls:PlaceholderTextBox Grid.Row="1" x:Name="BodyTextBox" Margin="0,4,0,0" Placeholder="Body (optional)" Padding="6,4" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" TextChanged="BodyTextBox_TextChanged" />
          <TextBlock Grid.Row="2" x:Name="ReasonTextBlock" FontSize="11" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
        </Grid>
      </DockPanel>
    </Grid>
    <!-- Bottom: hint + apply / cancel -->
    <DockPanel Grid.Row="3" Margin="12,4,12,12" LastChildFill="False">
      <TextBlock DockPanel.Dock="Left" x:Name="UnassignedFilesHint" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush.WindowsInfo}" TextTrimming="CharacterEllipsis" />
      <Button DockPanel.Dock="Right" MinWidth="96" Padding="12,4" Margin="6,0,0,0" x:Name="ApplyAllButton" Content="Apply All" Click="ApplyAllButton_Click" />
      <Button DockPanel.Dock="Right" MinWidth="96" Padding="12,4" Margin="6,0,0,0" x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" />
    </DockPanel>
  </Grid>
</ui:CustomWindow>
