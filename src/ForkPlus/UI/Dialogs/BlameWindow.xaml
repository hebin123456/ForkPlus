<ui:CustomWindow xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.BlameWindow" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:diff="clr-namespace:ForkPlus.UI.Controls.Editor.Diff">
  <ui:CustomWindow.Resources>
    <ResourceDictionary xmlns="https://github.com/avaloniaui">
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:DummyBlameItemViewModel}}" DataType="{x:Type dialogs:DummyBlameItemViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="16.393333333333334">
          <Border Margin="-4,0,-4,0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" />
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:BlameItemViewModel}}" DataType="{x:Type dialogs:BlameItemViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="16.393333333333334">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="46" />
            <ColumnDefinition Width="18" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Grid.ColumnSpan="5" Margin="-4,-1,-4,0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" />
          <controls:AvatarImage Grid.Column="0" Margin="4,2,6,1" VerticalAlignment="Top" Height="12" Width="12">
            <controls:AvatarImage.UserIdentity>
              <Binding Path="Author" />
            </controls:AvatarImage.UserIdentity>
            <controls:AvatarImage.ToolTip>
              <Binding Path="FullCredentials" />
            </controls:AvatarImage.ToolTip>
          </controls:AvatarImage>
          <controls:AutoTooltipTextBlock Grid.Column="1" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" Padding="0,-2,0,0" FontSize="12">
            <controls:AutoTooltipTextBlock.Text>
              <Binding Path="RevisionSubject" />
            </controls:AutoTooltipTextBlock.Text>
          </controls:AutoTooltipTextBlock>
          <TextBlock Grid.Column="2" Margin="2,1,0,0" Padding="0,-2,0,0" FontSize="12" HorizontalAlignment="Right">
            <TextBlock.Text>
              <Binding Path="AuthorDate" />
            </TextBlock.Text>
            <TextBlock.ToolTip>
              <Binding Path="AuthorDate" />
            </TextBlock.ToolTip>
          </TextBlock>
          <Button Grid.Column="3" Margin="0,-2,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="12" Height="20" IsTabStop="False" Foreground="{DynamicResource ForegroundBrush.Gray}" Style="{DynamicResource TextButtonStyle}" Click="ShaButton_Click">
            <Button.Content>
              <Binding Path="AbbreviatedSha" />
            </Button.Content>
            <Button.ToolTip>
              <Binding Path="ShaToolTip" />
            </Button.ToolTip>
          </Button>
          <Button Grid.Column="4" Width="14" Height="14" Padding="1" Margin="4,0,0,1" HorizontalAlignment="Right" VerticalAlignment="Center" BorderThickness="0" Background="#00FFFFFF" Style="{DynamicResource IconButtonStyle}" Click="OpenRevisionInSeparateWindowButton_Click">
            <Button.ToolTip>
              <Binding Path="OpenInSeparateWindowButtonToolTip" />
            </Button.ToolTip>
            <Image Source="{DynamicResource OpenInSeparateWindowIcon}" Height="12" Width="12" />
          </Button>
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type dialogs:BlameItemBodyViewModel}}" DataType="{x:Type dialogs:BlameItemBodyViewModel}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="16.393333333333334" />
      </DataTemplate>
    </ResourceDictionary>
  </ui:CustomWindow.Resources>
  <Grid Margin="20,2,20,20" xmlns="https://github.com/avaloniaui">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <DockPanel>
      <ComboBox DockPanel.Dock="Right" HorizontalAlignment="Right" Height="22" Width="570" Padding="4,0,4,0" HorizontalContentAlignment="Stretch" Focusable="False" BorderBrush="{DynamicResource BorderBrush}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" SelectionChanged="RevisionsComboBox_SelectionChanged" x:Name="RevisionsComboBox">
        <ComboBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ComboBox.ItemsPanel>
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <Grid Width="530">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
              </Grid.ColumnDefinitions>
              <controls:AvatarImage Margin="4,0,4,0" VerticalAlignment="Center" Height="14" Width="14" x:Name="AuthorAvatarImage">
                <controls:AvatarImage.UserIdentity>
                  <Binding Path="Author" />
                </controls:AvatarImage.UserIdentity>
              </controls:AvatarImage>
              <TextBlock Grid.Column="1" Margin="0,2,0,2" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush.Gray}">
                <TextBlock.Text>
                  <Binding Path="AbbreviatedSha" />
                </TextBlock.Text>
              </TextBlock>
              <controls:AutoTooltipTextBlock Grid.Column="2" Margin="4,2,0,2" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13">
                <controls:AutoTooltipTextBlock.Text>
                  <Binding Path="RevisionSubject" />
                </controls:AutoTooltipTextBlock.Text>
              </controls:AutoTooltipTextBlock>
              <TextBlock Grid.Column="3" Margin="2,2,2,2" Foreground="{DynamicResource ForegroundBrush.Gray}" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock.Text>
                  <Binding Path="AuthorDate" />
                </TextBlock.Text>
              </TextBlock>
            </Grid>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button DockPanel.Dock="Right" Margin="0,0,2,0" IsEnabled="False" Style="{DynamicResource IconButtonStyle}" ToolTip="Go Forward" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="RedoButton_Click" x:Name="RedoButton">
        <Image Source="{DynamicResource NextIcon}" Width="16" Height="16" VerticalAlignment="Center" />
      </Button>
      <Button DockPanel.Dock="Right" Style="{DynamicResource IconButtonStyle}" ToolTip="Go Back" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="UndoButton_Click" x:Name="UndoButton">
        <Image Source="{DynamicResource PrevIcon}" Width="16" Height="16" VerticalAlignment="Center" />
      </Button>
      <ProgressBar DockPanel.Dock="Right" Margin="0,0,5,0" Style="{DynamicResource CircularProgressBar}" Visibility="Visible" Width="14" Height="14" Foreground="{DynamicResource ForegroundBrush.Gray}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="BusyIndicator" />
      <TextBlock Text="Blame" DockPanel.Dock="Left" Margin="4,0,0,2" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display" x:Name="BlameTitleTextBlock" />
      <Image DockPanel.Dock="Left" Width="14" Height="14" Margin="8,0,4,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FileIcon" />
      <controls:FilePathTextBlock FontSize="14" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FileNameTextBlock" />
    </DockPanel>
    <Border Grid.Row="2" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderBrush}" Height="17" VerticalAlignment="Top" />
    <controls:RevisionTimeLine Grid.Row="2" Height="46" Margin="1,1,1,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RevisionTimeLine" />
    <Grid Grid.Row="3" Background="{DynamicResource BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="330" MinWidth="150" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,1" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RevisionListFallbackBorder">
        <userControls:FallbackUserControl Grid.Column="0" x:Name="RevisionListFallbackUserControl" />
      </Border>
      <ListBox Grid.Column="0" SelectionMode="Single" BorderThickness="1,1,0,1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" HorizontalContentAlignment="Stretch" Style="{DynamicResource NoSelectionListBoxStyle}" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.IsVirtualizing="True" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" ContextMenuOpening="BlameListBox_ContextMenuOpening" x:Name="BlameListBox">
        <ListBox.ContextMenu>
          <ContextMenu />
        </ListBox.ContextMenu>
        <ListBox.ItemContainerStyle>
          <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="UIElement.Focusable" Value="False" />
            <Setter Property="FrameworkElement.FocusVisualStyle">
              <Setter.Value>
                <x:Null />
              </Setter.Value>
            </Setter>
            <Setter Property="Border.BorderThickness" Value="0" />
            <Setter Property="Control.Padding" Value="0" />
            <Setter Property="Panel.Background" Value="{DynamicResource Item.Static.Background}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                  <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="true" x:Name="Bd">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" />
                  </Border>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <ContentControl>
              <ContentControl.Content>
                <Binding />
              </ContentControl.Content>
            </ContentControl>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Border Grid.Column="2" BorderThickness="0,1,1,1" BorderBrush="{DynamicResource BorderBrush}">
        <diff:SplitTextDiffControl Visibility="Collapsed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="TextDiffControl" />
      </Border>
      <GridSplitter Grid.Column="1" Style="{DynamicResource VerticalGridSplitter}" />
      <userControls:FallbackUserControl BorderThickness="1" Grid.Column="0" Grid.ColumnSpan="3" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="CodeEditorFallbackUserControl" />
    </Grid>
  </Grid>
</ui:CustomWindow>