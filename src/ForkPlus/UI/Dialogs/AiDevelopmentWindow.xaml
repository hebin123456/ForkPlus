<ui:CustomWindow ResizeMode="CanResizeWithGrip" Height="720" Width="1080" MinHeight="400" MinWidth="560" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.AiDevelopmentWindow">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <!-- Title bar -->
    <DockPanel Grid.Row="0" Margin="12,8,12,4" LastChildFill="True">
      <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" x:Name="TitleTextBlock" Text="AI-Assisted Development" />
      <!-- 右上角模型下拉选择：从 /v1/models 拉取列表，选中项保存到 AiReviewSelectedModel -->
      <ComboBox DockPanel.Dock="Right" x:Name="ModelComboBox" FontSize="11" MinWidth="160" MaxWidth="320" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" ToolTip="Select AI model" SelectionChanged="ModelComboBox_SelectionChanged">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </DockPanel>
    <Separator Grid.Row="1" HorizontalAlignment="Stretch" Margin="0" />
    <!-- Main content area: message list -->
    <ScrollViewer Grid.Row="2" x:Name="MainScrollViewer" Margin="4,4,8,0" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="MessagePanel" Margin="8,4,8,8" />
    </ScrollViewer>
    <!-- Bottom area: progress + input -->
    <Grid Grid.Row="3" Margin="8,4,12,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <!-- Progress bar + Stop button: 处理中显示，点击 Stop 取消当前任务及后台 HTTP 请求 -->
      <Grid Grid.Row="0" Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressBar Grid.Column="0" x:Name="ProgressBar" Height="3" IsIndeterminate="True" Visibility="Collapsed" Foreground="{DynamicResource AccentColorBrush}" />
        <Button Grid.Column="1" x:Name="StopButton" Content="Stop" FontSize="11" Padding="8,1" Margin="6,0,0,0" Visibility="Collapsed" Click="StopButton_Click" MinHeight="22" ToolTip="Stop the current AI task and abort its request" />
      </Grid>
      <!-- Input area -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <controls:PlaceholderTextBox Grid.Column="0" x:Name="InputTextBox" FontSize="13" Padding="6,4" TextWrapping="Wrap" AcceptsReturn="True" MaxLines="4" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch" MinHeight="28" MaxHeight="80" Placeholder="Enter your development requirement..." />
        <Button Grid.Column="1" x:Name="ClearConversationButton" Content="Clear" FontSize="13" Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Bottom" Click="ClearConversationButton_Click" MinHeight="28" ToolTip="Clear conversation history" />
        <Button Grid.Column="2" x:Name="SendButton" Content="Send (Enter)" FontSize="13" Padding="10,4" Margin="4,0,0,0" VerticalAlignment="Bottom" IsEnabled="False" Click="SendButton_Click" MinHeight="28" />
        <controls:DropDownButton Grid.Column="3" x:Name="SendModeButton" Padding="2,0" MinHeight="28" VerticalAlignment="Bottom" BorderThickness="1" Background="Transparent" FontSize="8" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
          <controls:DropDownButton.ContextMenu>
            <ContextMenu x:Name="SendModeContextMenu">
              <MenuItem x:Name="SendModeEnter" Header="Send on Enter" IsCheckable="True" Click="SendModeMenuItem_Click" />
              <MenuItem x:Name="SendModeCtrlEnter" Header="Send on Ctrl+Enter" IsCheckable="True" Click="SendModeMenuItem_Click" />
            </ContextMenu>
          </controls:DropDownButton.ContextMenu>
          <TextBlock Text="▼" FontSize="8" />
        </controls:DropDownButton>
      </Grid>
      <!-- Hint text -->
      <TextBlock Grid.Row="2" x:Name="HintTextBlock" FontSize="11" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
    </Grid>
  </Grid>
</ui:CustomWindow>
