<dialogs:ForkPlusDialogWindow Width="570" MinWidth="500" xmlns="https://github.com/avaloniaui" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RemoveLocalBranchWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2,0,2" FontSize="13" VerticalAlignment="Top" HorizontalAlignment="Right" x:Name="StartPointTextBlock" />
      <controls:GitPointView Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" x:Name="GitPointView" />
      <Border Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" BorderThickness="1" BorderBrush="{DynamicResource TextBox.Static.Border}" x:Name="BranchesContainer">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
          <ItemsControl Background="{DynamicResource TextBox.Static.Background}" x:Name="BranchesItemsControl">
            <ItemsControl.FocusVisualStyle>
              <x:Null />
            </ItemsControl.FocusVisualStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Height="20">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Image Grid.Column="0" Source="{DynamicResource BranchIcon}" Height="16" Width="16" Margin="0,0,4,0" />
                  <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">
                    <TextBlock.Text>
                      <Binding Path="BranchName" />
                    </TextBlock.Text>
                  </TextBlock>
                  <DockPanel Grid.Column="2" VerticalAlignment="Center">
                    <DockPanel.Visibility>
                      <Binding Path="UpstreamVisibility" />
                    </DockPanel.Visibility>
                    <TextBlock Text="&#x2192;" Margin="4,0,0,0">
                      <TextBlock.Visibility>
                        <Binding Path="UpstreamName"><Binding.Converter><controls:NullToVisibilityConverter /></Binding.Converter></Binding>
                      </TextBlock.Visibility>
                    </TextBlock>
                    <Image Height="16" Width="16" Margin="4,0,0,0">
                      <Image.Source>
                        <Binding Path="RemoteIcon" />
                      </Image.Source>
                    </Image>
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13">
                      <TextBlock.Text>
                        <Binding Path="UpstreamName" />
                      </TextBlock.Text>
                    </TextBlock>
                  </DockPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
      <Image Grid.Row="1" Grid.Column="0" Height="14" Width="14" Margin="0,6,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed" Source="avares://ForkPlus/Assets/Warning.png" x:Name="WarningImage" />
      <DockPanel Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" VerticalAlignment="Center">
        <CheckBox DockPanel.Dock="Left" Margin="0" Checked="DeleteRemoteBranchCheckBox_Changed" Unchecked="DeleteRemoteBranchCheckBox_Changed" x:Name="DeleteRemoteBranchCheckBox">
          <CheckBox.FocusVisualStyle>
            <x:Null />
          </CheckBox.FocusVisualStyle>
        </CheckBox>
        <Image Height="16" Width="16" Margin="6,0,0,0" x:Name="DeleteRemoteBranchCheckBoxUpstreamIcon" />
        <controls:AutoTooltipTextBlock Margin="2,0,0,2" FontSize="13" x:Name="DeleteRemoteBranchCheckBoxUpstream" />
      </DockPanel>
      <Image Grid.Row="2" Grid.Column="0" Height="14" Width="14" Margin="0,6,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed" Source="avares://ForkPlus/Assets/Warning.png" x:Name="WorktreeWarningImage" />
      <DockPanel Grid.Row="2" Grid.Column="1" Margin="8,6,0,0" VerticalAlignment="Center" Visibility="Collapsed" x:Name="DeleteWorktreeContainer">
        <CheckBox DockPanel.Dock="Left" Margin="0" Content="Also delete worktree" Checked="DeleteWorktreeCheckBox_Changed" Unchecked="DeleteWorktreeCheckBox_Changed" x:Name="DeleteWorktreeCheckBox">
          <CheckBox.FocusVisualStyle>
            <x:Null />
          </CheckBox.FocusVisualStyle>
        </CheckBox>
        <Image Source="{DynamicResource WorktreeIcon}" Height="16" Width="16" Margin="6,0,0,0" />
        <controls:AutoTooltipTextBlock Margin="2,0,0,2" FontSize="13" x:Name="DeleteWorktreeLabel" />
      </DockPanel>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
