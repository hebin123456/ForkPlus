<dialogs:ForkPlusDialogWindow Width="640" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.ConfigureGitInstanceWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Column="0" Grid.Row="0" Text="Git executable:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <Grid Grid.Column="1" Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <controls:PlaceholderTextBox TextChanged="GitPathTextBox_TextChanged" Grid.Column="0" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Path to git.exe" x:Name="GitPathTextBox" />
        <Button Grid.Column="1" Style="{DynamicResource BrowseButtonStyle}" Click="BrowseButton_Click" />
      </Grid>
      <TextBlock Grid.Column="1" Grid.Row="1" Margin="8,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" Text="ForkPlus requires a valid Git executable to continue." />
      <TextBlock Grid.Column="0" Grid.Row="2" Text="Detected Git:" FontSize="13" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,0,0" />
      <ListBox Grid.Column="1" Grid.Row="2" Margin="8,8,0,0" MinHeight="70" MaxHeight="160" BorderThickness="1" SelectionChanged="GitCandidatesListBox_SelectionChanged" x:Name="GitCandidatesListBox">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid Margin="4,2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" FontSize="13" FontWeight="Medium" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="1" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <TextBlock Grid.Column="1" Grid.Row="3" Margin="8,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" Text="Select a detected Git executable or browse for another git.exe." />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
