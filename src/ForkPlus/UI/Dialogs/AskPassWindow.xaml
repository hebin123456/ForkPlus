<dialogs:ForkPlusDialogWindow MinHeight="170" Width="520" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.AskPassWindow">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Password:" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="InputTextBlock" />
      <TextBox Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="InputTextBox" />
      <PasswordBox Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="InputPasswordBox" />
      <CheckBox Grid.Column="1" Grid.Row="1" Margin="8,6,0,0" HorizontalAlignment="Left" Content="Remember in Credential Manager" ToolTip="Remember in Windows Credential Manager" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RememberCheckBox" />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>