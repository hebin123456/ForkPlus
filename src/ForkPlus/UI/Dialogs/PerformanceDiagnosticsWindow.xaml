<dialogs:ForkPlusDialogWindow ResizeMode="CanResizeWithGrip" Height="520" Width="760" MinHeight="320" MinWidth="520" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.PerformanceDiagnosticsWindow">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,6">
      <Button DockPanel.Dock="Right" Margin="6,0,0,0" Content="Copy" Style="{DynamicResource TextButtonStyle}" Click="CopyButton_Click" x:Name="CopyButton" />
      <Button DockPanel.Dock="Right" Content="Refresh" Style="{DynamicResource TextButtonStyle}" Click="RefreshButton_Click" x:Name="RefreshButton" />
      <TextBlock Text="Recent samples" FontWeight="Medium" VerticalAlignment="Center" />
    </DockPanel>
    <TextBox Grid.Row="2" Grid.Column="1" FontFamily="Consolas" FontSize="12" IsReadOnly="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" x:Name="SamplesTextBox" />
  </Grid>
</dialogs:ForkPlusDialogWindow>
