<dialogs:ForkPlusDialogWindow Title="Add Account" Height="350" Width="450" xmlns="https://github.com/avaloniaui" xmlns:Accounts="clr-namespace:ForkPlus.UI.Dialogs.Accounts" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.Accounts.AddAccountWindow" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Grid.Column="1" Text="Add Account" Margin="4,0,0,4" FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
    <ListBox Grid.Column="1" Grid.Row="1" Padding="4,5,5,0" VerticalAlignment="Stretch" BorderBrush="{DynamicResource BorderBrush}" ItemContainerStyle="{DynamicResource NoVisibleSelectionListBoxItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ServicesListBox_SelectionChanged" MouseDoubleClick="ServicesListBox_MouseDoubleClick" x:Name="ServicesListBox">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="5,5,5,5" BorderThickness="3" CornerRadius="3" BorderBrush="{DynamicResource Item.Static.Background}" x:Name="Border">
            <StackPanel Height="85" Width="75">
              <Image Height="24" Width="24" Margin="4,6,4,0" HorizontalAlignment="Center">
                <Image.Source>
                  <Binding Path="Icon" />
                </Image.Source>
              </Image>
              <TextBlock FontSize="12" HorizontalAlignment="Center" Margin="4,2,4,2" TextWrapping="Wrap" TextAlignment="Center" x:Name="ServiceTextBlock">
                <TextBlock.Text>
                  <Binding Path="ServiceName" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </Border>
          <DataTemplate.Triggers>
            <DataTrigger Value="True">
              <DataTrigger.Binding>
                <Binding Path="IsSelected">
                  <Binding.RelativeSource>
                    <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                  </Binding.RelativeSource>
                </Binding>
              </DataTrigger.Binding>
              <Setter TargetName="Border" Value="{DynamicResource Item.SelectedActive.Background}" Property="Border.BorderBrush" />
              <Setter TargetName="Border" Value="{DynamicResource Item.SelectedInactive.Background}" Property="Border.Background" />
            </DataTrigger>
          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</dialogs:ForkPlusDialogWindow>
