<dialogs:ForkPlusDialogWindow Title="Login to GitHub" Width="450" SizeToContent="Height" xmlns="https://github.com/avaloniaui" xmlns:Accounts="clr-namespace:ForkPlus.UI.Dialogs.Accounts" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.Accounts.GitHubLoginWindow" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <StackPanel Orientation="Horizontal">
        <Image Width="24" Height="24" Source="avares://ForkPlus/Assets/GitHub.png" />
        <TextBlock Text="Log in to GitHub" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,4,0" />
      </StackPanel>
      <Separator Grid.Row="1" Margin="0,8,0,8" />
      <ComboBox Grid.Row="2" Margin="95,4,0,6" HorizontalAlignment="Stretch" SelectionChanged="AuthenticationTypeComboBox_SelectionChanged" x:Name="AuthenticationTypeComboBox">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Margin="0,0,4,0">
              <TextBlock.Text>
                <Binding Path="Title" />
              </TextBlock.Text>
            </TextBlock>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Grid Grid.Row="3" x:Name="TokenContainer">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="24" />
          <RowDefinition Height="16" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="0" Text="Access Token:" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
        <controls:PlaceholderTextBox TextChanged="TokenTextBox_TextChanged" Grid.Column="1" Margin="0" Padding="4,2,4,2" FontSize="13" Placeholder="Token" x:Name="TokenTextBox" />
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" x:Name="PersonalAccessTokenHint">
          <TextBlock Margin="0" FontSize="12" Text="Manage" x:Name="StatusTextBlock" />
          <Button Content="personal access tokens" Margin="2,-3,0,0" HorizontalAlignment="Left" Style="{DynamicResource TextButtonStyle}" Click="OpenPersonalAccessTokenConfigurationUrlButton_Click" x:Name="OpenPersonalAccessTokenConfigurationUrlButton" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
