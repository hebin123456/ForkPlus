<dialogs:ForkPlusDialogWindow MinHeight="220" Width="630" SizeToContent="Height" xmlns="https://github.com/avaloniaui" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.EditRemoteWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <!-- TODO: Separator 项需要用 DataTemplate Selector 实现（原 WPF DataTrigger+ControlTemplate for ItemType=="Separator"） -->
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="32" />
        <RowDefinition Height="32" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Remote:" />
      <controls:ReferenceTextBox TextChanged="RemoteNameTextBox_TextChanged" Grid.Row="0" Grid.Column="1" Height="24" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Remote name" x:Name="RemoteNameTextBox" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Repository Url:" />
      <controls:PlaceholderTextBox TextChanged="RepositoryUrlTextBox_TextChanged" Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,53,2" Placeholder="Git Repository Url" Icon="{DynamicResource SubmoduleIcon}" x:Name="RepositoryUrlTextBox" />
      <controls:DropDownButton Grid.Row="1" Grid.Column="1" Margin="1,1,3,1" Background="#00FFFFFF" Height="18" BorderThickness="0" HorizontalAlignment="Right" Focusable="False" x:Name="NetworkProtocolDropDownButton">
        <controls:DropDownButton.FocusVisualStyle>
          <x:Null />
        </controls:DropDownButton.FocusVisualStyle>
        <controls:DropDownButton.ContextMenu>
          <ContextMenu Opened="NetworkProtocolContextMenu_Opened" />
        </controls:DropDownButton.ContextMenu>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="HTTPS" Margin="2,0,2,0" FontWeight="Medium" Foreground="{DynamicResource AccentBrush}" x:Name="NetworkProtocolTextBlock" />
          <Path Data="F1M0,0L2.667,2.66665 5.3334,0 5.3334,-1.78168 2.6667,0.88501 0,-1.78168 0,0z" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="2,2,2,2" VerticalAlignment="Center" x:Name="arrow" />
        </StackPanel>
      </controls:DropDownButton>
      <CheckBox Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" IsChecked="True" Content="Sync submodule URL with parent repository" x:Name="SyncCheckBox" />
      <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Account:" FontSize="13" x:Name="AccountsTextBlock" />
      <!-- TODO: TextSearch.TextPath="Title" 已移除（Avalonia 不支持），需在 code-behind 或自定义 SelectionBoxItem 处理 -->
      <!-- TODO: ItemContainerStyle 已移除（原 AccountComboBoxItemStyle 用于 Separator 项），需用 DataTemplate Selector 替代 -->
      <ComboBox Grid.Row="3" Grid.Column="1" Margin="8,4,0,4" SelectionChanged="AccountsComboBox_SelectionChanged" x:Name="AccountsComboBox">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <DockPanel>
              <Image DockPanel.Dock="Left" Height="16" Width="16" Margin="0,0,4,0">
                <Image.Source>
                  <Binding Path="Icon" />
                </Image.Source>
              </Image>
              <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Margin="0,0,4,0">
                <TextBlock.Text>
                  <Binding Path="Title" />
                </TextBlock.Text>
              </TextBlock>
              <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}">
                <TextBlock.Text>
                  <Binding Path="Description" />
                </TextBlock.Text>
              </TextBlock>
            </DockPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <ProgressBar Grid.Row="4" Grid.Column="0" Margin="0,0,0,0" Style="{DynamicResource CircularProgressBar}" Visibility="Hidden" Width="14" Height="14" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrush.Gray}" x:Name="BusyIndicator" />
      <Image Grid.Row="4" Grid.Column="0" Margin="0,0,0,0" Width="18" Height="Auto" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed" Source="/ForkPlus;component/Assets/Warning.png" x:Name="StatusImage" />
      <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
        <TextBlock Visibility="Collapsed" Margin="8,3,0,0" FontSize="13" x:Name="StatusTextBlock" />
        <Button Content="Test Connection" Margin="4,0,0,0" HorizontalAlignment="Left" Style="{DynamicResource TextButtonStyle}" Visibility="Collapsed" Click="TestButton_Click" x:Name="TestButton" />
        <Button Content="Configure SSH Keys" Margin="4,0,0,0" HorizontalAlignment="Left" Style="{DynamicResource TextButtonStyle}" Visibility="Collapsed" Click="ConfigureSSHKeyButton_Click" x:Name="ConfigureSSHKeyButton" />
      </StackPanel>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
