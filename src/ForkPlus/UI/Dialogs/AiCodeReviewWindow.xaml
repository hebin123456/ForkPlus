<ui:CustomWindow CanResize="True" Height="720" Width="1080" MinHeight="400" MinWidth="560" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fud="clr-namespace:ForkPlus.UI.Dialogs" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.AiCodeReviewWindow" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls">
  <Grid x:Name="AiResultGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" MinWidth="365" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition MinWidth="120" Width="350" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.Children>
      <!-- 标题栏：标题 + 模型下拉 + Stop + Retry -->
      <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="10,0,10,6" LastChildFill="True">
        <Button DockPanel.Dock="Right" MinWidth="64" Padding="10,2,10,2" Content="Retry" ToolTip="Retry AI Review" Click="RetryButton_Click" x:Name="RetryButton" />
        <Button DockPanel.Dock="Right" MinWidth="64" Padding="10,2,10,2" Margin="6,0,0,0" Content="Stop" ToolTip="Stop the current AI task and abort its request" Click="StopButton_Click" x:Name="StopButton" Visibility="Collapsed" />
        <ComboBox DockPanel.Dock="Right" x:Name="ModelComboBox" FontSize="11" MinWidth="160" MaxWidth="320" Margin="6,0,6,0" SelectionChanged="ModelComboBox_SelectionChanged">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock FontSize="16" FontWeight="Medium" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" x:Name="TitleTextBlock" />
      </DockPanel>
      <Separator HorizontalAlignment="Stretch" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0" VerticalAlignment="Bottom" />
      <!-- 状态栏：进度条 + 状态文字（排队/请求中/收集 diff/生成中/完成） -->
      <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="10,4,10,6" LastChildFill="True">
        <ProgressBar DockPanel.Dock="Left" Width="120" Height="3" IsIndeterminate="True" Visibility="Collapsed" Foreground="{DynamicResource AccentColorBrush}" x:Name="StatusProgressBar" />
        <TextBlock FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="StatusTextBlock" />
      </DockPanel>
      <userControls:RevisionDetailsUserControl Grid.Row="2" Grid.Column="0" x:Name="RevisionDetails" />
      <Grid Grid.Row="2" Grid.Column="0" Visibility="Collapsed" x:Name="FileReviewGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="320" MinWidth="160" />
          <ColumnDefinition Width="5" />
          <ColumnDefinition Width="*" MinWidth="200" />
        </Grid.ColumnDefinitions>
        <userControls:FileListUserControl Grid.Column="0" EnableMultiSelection="True" ContextMenuOpening="FileReviewFileListUserControl_ContextMenuOpening" x:Name="FileReviewFileListUserControl">
          <userControls:FileListUserControl.ContextMenu>
            <ContextMenu />
          </userControls:FileListUserControl.ContextMenu>
        </userControls:FileListUserControl>
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext" Style="{DynamicResource VerticalGridSplitter}" x:Name="FileReviewGridSplitter" />
        <controls:CommitFileDiffControl Grid.Column="2" x:Name="FileReviewDiffControl" />
      </Grid>
      <Grid Grid.Row="2" Grid.Column="2">
        <Grid.Children>
          <wv2:WebView2 x:Name="AiResponseWebView" />
          <ProgressBar Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="BusyIndicator">
            <ProgressBar.Foreground>
              <DynamicResource ResourceKey="ForegroundBrush.Gray" xmlns="https://github.com/avaloniaui" />
            </ProgressBar.Foreground>
            <ProgressBar.Style>
              <DynamicResource ResourceKey="CircularProgressBar" xmlns="https://github.com/avaloniaui" />
            </ProgressBar.Style>
          </ProgressBar>
          <userControls:FallbackUserControl x:Name="AiResponseFallback">
            <UserControl.Background>
              <SolidColorBrush xmlns="https://github.com/avaloniaui">#00FFFFFF</SolidColorBrush>
            </UserControl.Background>
          </userControls:FallbackUserControl>
        </Grid.Children>
      </Grid>
      <GridSplitter Grid.Row="2" Grid.Column="1" x:Name="GridSplitter">
        <GridSplitter.Style>
          <DynamicResource ResourceKey="VerticalGridSplitter" xmlns="https://github.com/avaloniaui" />
        </GridSplitter.Style>
      </GridSplitter>
    </Grid.Children>
  </Grid>
</ui:CustomWindow>
