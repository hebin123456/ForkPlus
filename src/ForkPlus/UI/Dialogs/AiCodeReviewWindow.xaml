<ui:CustomWindow xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:fud="clr-namespace:ForkPlus.UI.Dialogs" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.AiCodeReviewWindow" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls">
  <Grid x:Name="AiResultGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition MinWidth="120" Width="350" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid.Children>
      <TextBlock Grid.Row="0" Margin="10,0,0,6" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display" TextTrimming="CharacterEllipsis" x:Name="TitleTextBlock" />
      <Separator HorizontalAlignment="Stretch" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0" VerticalAlignment="Bottom" />
      <userControls:RevisionDetailsUserControl Grid.Row="1" Grid.Column="0" x:Name="RevisionDetails" />
      <Grid Grid.Row="1" Grid.Column="2">
        <Grid.Children>
          <wv2:WebView2 x:Name="AiResponseWebView" />
          <ProgressBar Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="BusyIndicator">
            <ProgressBar.Foreground>
              <DynamicResource ResourceKey="ForegroundBrush.Gray" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </ProgressBar.Foreground>
            <ProgressBar.Style>
              <DynamicResource ResourceKey="CircularProgressBar" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </ProgressBar.Style>
          </ProgressBar>
          <userControls:FallbackUserControl x:Name="AiResponseFallback">
            <UserControl.Background>
              <SolidColorBrush xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">#00FFFFFF</SolidColorBrush>
            </UserControl.Background>
          </userControls:FallbackUserControl>
        </Grid.Children>
      </Grid>
      <GridSplitter Grid.Row="1" Grid.Column="1" x:Name="GridSplitter">
        <GridSplitter.Style>
          <DynamicResource ResourceKey="VerticalGridSplitter" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
        </GridSplitter.Style>
      </GridSplitter>
    </Grid.Children>
  </Grid>
</ui:CustomWindow>