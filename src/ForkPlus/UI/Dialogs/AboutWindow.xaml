<dialogs:ForkPlusDialogWindow MinHeight="348" Width="240" SizeToContent="Height" Title="About" xmlns="https://github.com/avaloniaui" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.AboutWindow">
  <dialogs:ForkPlusDialogWindow.Resources>
    <ResourceDictionary>
      <Style x:Key="HyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource {x:Type Hyperlink}}">
        <Setter Property="FrameworkContentElement.FocusVisualStyle">
          <Setter.Value>
            <x:Null />
          </Setter.Value>
        </Setter>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
        <Style.Triggers>
          <Trigger Property="ContentElement.IsMouseOver" Value="True">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </dialogs:ForkPlusDialogWindow.Resources>
  <Grid Margin="20,0,20,20">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="0" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Image Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Source="/Assets/ForkPlusIcon.png" Width="90" Height="90" />
    <DockPanel Grid.Row="2" Grid.Column="1" LastChildFill="False">
      <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,10,0,8" Text="ForkPlus" FontSize="32" Foreground="{DynamicResource ForegroundBrush.WindowsInfo}" />
      <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" x:Name="VersionTextBlock" />
      <Label DockPanel.Dock="Top" HorizontalAlignment="Center" FontSize="13">
        <Hyperlink NavigateUri="https://hebin.me" Style="{DynamicResource HyperlinkStyle}" RequestNavigate="Hyperlink_RequestNavigate">
          <TextBlock HorizontalAlignment="Center" Text="hebin.me" Margin="0" />
        </Hyperlink>
      </Label>
      <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,8,0,0" Text="Designed and implemented by" Foreground="{DynamicResource ForegroundBrush.Gray}" />
      <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,4,0,4" Text="Hebin" />
      <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0" x:Name="CopyrightTextBlock" />
    </DockPanel>
  </Grid>
</dialogs:ForkPlusDialogWindow>
