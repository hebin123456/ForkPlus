<dialogs:ForkPlusDialogWindow Width="520" MinHeight="160" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.UpdateCheckWindow">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4,0,0">
      <!-- 检查中：进度条 + 状态文本 -->
      <DockPanel x:Name="CheckingPanel" Margin="0,4,0,8">
        <ProgressBar IsIndeterminate="True" Height="3" DockPanel.Dock="Top" Foreground="{DynamicResource AccentColorBrush}" />
        <TextBlock x:Name="StatusTextBlock" Text="Checking for updates..." FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap" />
      </DockPanel>
      <!-- 结果区：版本信息 + Release Notes + 跳过勾选（默认隐藏，检测完成后再显示） -->
      <StackPanel x:Name="ResultPanel" Visibility="Collapsed">
        <TextBlock x:Name="VersionInfoTextBlock" FontSize="13" FontWeight="Medium" Margin="0,0,0,6" TextWrapping="Wrap" />
        <TextBlock x:Name="ReleaseNotesLabel" Text="Release Notes" FontWeight="Medium" FontSize="13" Margin="0,4,0,4" />
        <TextBox x:Name="ReleaseNotesTextBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" MaxHeight="220" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" BorderBrush="{DynamicResource BorderBrush}" Padding="6" />
        <CheckBox x:Name="SkipVersionCheckBox" Content="Don't remind me for this version" Margin="0,8,0,0" FontSize="13" />
      </StackPanel>
    </StackPanel>
  </Grid>
</dialogs:ForkPlusDialogWindow>
