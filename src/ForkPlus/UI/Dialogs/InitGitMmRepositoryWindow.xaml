<dialogs:ForkPlusDialogWindow MinHeight="260" Width="590" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.InitGitMmRepositoryWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Column="0" Grid.Row="0" Text="Manifest Repository Url:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Manifest repository URL" Icon="{DynamicResource SubmoduleIcon}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ManifestUrlTextBox" />
      <TextBlock Grid.Column="0" Grid.Row="1" Text="Parent Folder:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <Grid Grid.Column="1" Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Column="0" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Parent folder path" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ParentDirectoryTextBox" />
        <Button Grid.Column="1" Style="{DynamicResource BrowseButtonStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="BrowseButton_Click" />
      </Grid>
      <TextBlock Grid.Column="0" Grid.Row="2" Text="Name:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Repository name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RepositoryNameTextBox" />
      <TextBlock Grid.Column="0" Grid.Row="3" Text="Manifest File:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Row="3" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Manifest file" Text="dependency.xml" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ManifestFileTextBox" />
      <TextBlock Grid.Column="0" Grid.Row="4" Text="Manifest Branch:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Row="4" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Manifest branch" Text="master" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ManifestBranchTextBox" />
      <TextBlock Grid.Column="0" Grid.Row="5" Text="Manifest Group:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:PlaceholderTextBox TextChanged="TextBox_TextChanged" Grid.Row="5" Grid.Column="1" Margin="8,4,0,4" Padding="4,2,4,2" Placeholder="Manifest group" Text="default" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ManifestGroupTextBox" />
      <TextBlock Grid.Column="0" Grid.Row="6" Text="Command Preview:" FontSize="13" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,0,0" />
      <ScrollViewer Grid.Column="1" Grid.Row="6" MaxHeight="120" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8,8,0,0">
        <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="CommandPreviewTextBlock" />
      </ScrollViewer>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
