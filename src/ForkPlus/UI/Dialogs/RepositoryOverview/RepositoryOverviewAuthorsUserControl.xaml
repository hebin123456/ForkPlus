<UserControl xmlns:RepositoryOverview="clr-namespace:ForkPlus.UI.Dialogs.RepositoryOverview" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RepositoryOverview.RepositoryOverviewAuthorsUserControl" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="https://github.com/avaloniaui">
    <ListBox BorderThickness="1" HorizontalContentAlignment="Stretch" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.IsVirtualizing="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="AuthorsListBox">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid Height="30">
            <Grid.RowDefinitions>
              <RowDefinition Height="17" />
              <RowDefinition Height="13" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.Column="0" Width="14" Height="14" Margin="2,0,0,1" VerticalAlignment="Bottom">
              <controls:AvatarImage>
                <controls:AvatarImage.UserIdentity>
                  <Binding Path="Author" />
                </controls:AvatarImage.UserIdentity>
                <controls:AvatarImage.ToolTip>
                  <Binding Path="FullCredentialsString" />
                </controls:AvatarImage.ToolTip>
              </controls:AvatarImage>
            </Grid>
            <controls:AutoTooltipTextBlock Grid.Row="0" Grid.Column="1" Margin="4,0,2,0" FontSize="13" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis">
              <controls:AutoTooltipTextBlock.Text>
                <Binding Path="AuthorName" />
              </controls:AutoTooltipTextBlock.Text>
            </controls:AutoTooltipTextBlock>
            <TextBlock Grid.Row="0" Grid.Column="2" Margin="4,0,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="LastCommitTextBlock">
              <TextBlock.Text>
                <Binding Path="LastCommit" />
              </TextBlock.Text>
            </TextBlock>
            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="2,0,0,3" VerticalAlignment="Bottom" Visibility="Visible" Height="4" Foreground="{DynamicResource SystemAccentBrush}" BorderThickness="0" Background="{DynamicResource SecondaryBackgroundBrush}" Minimum="0">
              <ProgressBar.Value>
                <Binding Path="Progress" />
              </ProgressBar.Value>
              <ProgressBar.Maximum>
                <Binding Path="AllCommitsCount" />
              </ProgressBar.Maximum>
            </ProgressBar>
            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,0,0" FontSize="12" VerticalAlignment="Bottom" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis">
              <TextBlock.Text>
                <Binding Path="CommitsCount" />
              </TextBlock.Text>
            </TextBlock>
          </Grid>
          <DataTemplate.Triggers>
            <DataTrigger Value="True">
              <DataTrigger.Binding>
                <Binding Path="IsSelected"><Binding.RelativeSource><RelativeSource AncestorType="{x:Type ListBoxItem}" /></Binding.RelativeSource></Binding>
              </DataTrigger.Binding>
              <Setter TargetName="LastCommitTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            </DataTrigger>
          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>