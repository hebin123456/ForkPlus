<UserControl xmlns:RepositoryOverview="clr-namespace:ForkPlus.UI.Dialogs.RepositoryOverview" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RepositoryOverview.RepositoryOverviewCommitsUserControl" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid>
    <ListBox BorderThickness="1" HorizontalContentAlignment="Stretch" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.IsVirtualizing="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ContextMenuOpening="RevisionsListBox_ContextMenuOpening" x:Name="RevisionsListBox">
      <ListBox.ContextMenu>
        <ContextMenu />
      </ListBox.ContextMenu>
      <ListBox.ItemContainerStyle>
        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemStyle}" />
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <DockPanel Height="20">
            <Grid DockPanel.Dock="Left" Width="14" Height="14" Margin="2,0,0,0" VerticalAlignment="Center">
              <controls:AvatarImage>
                <controls:AvatarImage.UserIdentity>
                  <Binding Path="Author" />
                </controls:AvatarImage.UserIdentity>
                <controls:AvatarImage.ToolTip>
                  <Binding Path="FullCredentialsString" />
                </controls:AvatarImage.ToolTip>
              </controls:AvatarImage>
            </Grid>
            <TextBlock DockPanel.Dock="Right" Margin="4,0,0,2" VerticalAlignment="Bottom" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="AuthorDateTextBlock">
              <TextBlock.Text>
                <Binding Path="AuthorDate" />
              </TextBlock.Text>
            </TextBlock>
            <controls:AutoTooltipTextBlock Margin="4,0,2,2" FontSize="13" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis">
              <controls:AutoTooltipTextBlock.Text>
                <Binding Path="Subject" />
              </controls:AutoTooltipTextBlock.Text>
            </controls:AutoTooltipTextBlock>
          </DockPanel>
          <DataTemplate.Triggers>
            <DataTrigger Value="True">
              <DataTrigger.Binding>
                <Binding Path="IsSelected"><Binding.RelativeSource><RelativeSource AncestorType="{x:Type ListBoxItem}" /></Binding.RelativeSource></Binding>
              </DataTrigger.Binding>
              <Setter TargetName="AuthorDateTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            </DataTrigger>
          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
