<dialogs:ForkPlusDialogWindow Width="490" SizeToContent="Height" xmlns="https://github.com/avaloniaui" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.PushWindow">
  <dialogs:ForkPlusDialogWindow.Resources>
    <ResourceDictionary>
      <Style x:Key="RemoteBranchesComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
        <Style.Triggers>
          <DataTrigger>
            <DataTrigger.Binding>
              <Binding Path="ItemType" />
            </DataTrigger.Binding>
            <Setter Property="FrameworkElement.Height" Value="1" />
            <Setter Property="UIElement.IsEnabled" Value="False" />
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                  <Separator HorizontalAlignment="Stretch" Margin="0" />
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </dialogs:ForkPlusDialogWindow.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Column="0" Grid.Row="0" Text="Branch:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" TextSearch.TextPath="Name" SelectionChanged="LocalBranchesComboBox_SelectionChanged" x:Name="LocalBranchesComboBox">
        <ComboBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ComboBox.ItemsPanel>
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <Image Source="{DynamicResource BranchIcon}" Height="16" Width="16" Margin="0,0,4,0" />
              <TextBlock FontSize="13">
                <TextBlock.Text>
                  <Binding Path="Name" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock Grid.Column="0" Grid.Row="1" Text="Remote:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" x:Name="RemotesLabel" />
      <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" TextSearch.TextPath="Name" ItemContainerStyle="{DynamicResource ComboBoxItemContainerStyle}" SelectionChanged="RemotesComboBox_SelectionChanged" x:Name="RemotesComboBox">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <Image Height="16" Width="16" Margin="0,0,4,0">
                <Image.Source>
                  <Binding Path="RemoteIcon" />
                </Image.Source>
                <Image.Visibility>
                  <Binding Path="IconVisibility" />
                </Image.Visibility>
              </Image>
              <TextBlock VerticalAlignment="Center" FontSize="13">
                <TextBlock.Text>
                  <Binding Path="Title" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock Grid.Column="0" Grid.Row="2" Text="To:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" TextSearch.TextPath="ShortName" ItemContainerStyle="{DynamicResource RemoteBranchesComboBoxItemStyle}" SelectionChanged="RemoteBranchesComboBox_SelectionChanged" x:Name="RemoteBranchesComboBox">
        <ComboBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ComboBox.ItemsPanel>
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <Image Source="{DynamicResource BranchIcon}" Height="16" Width="16" Margin="0">
                <Image.Visibility>
                  <Binding Path="IconVisibility" />
                </Image.Visibility>
              </Image>
              <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13">
                <TextBlock.Text>
                  <Binding Path="Title" />
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <CheckBox Grid.Column="1" Grid.Row="3" Margin="8,4,0,4" HorizontalAlignment="Left" Content="Create tracking reference" IsChecked="True" ToolTip="-u" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed" x:Name="CreateTrackingReferenceCheckBox" />
      <CheckBox Grid.Column="1" Grid.Row="4" Margin="8,4,0,4" HorizontalAlignment="Left" Content="Push all tags" IsChecked="True" ToolTip="--tags" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed" x:Name="AllTagsCheckBox" />
      <Image Grid.Column="0" Grid.Row="5" Margin="0,4,0,0" Height="14" Width="14" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="Hidden" Source="avares://ForkPlus/Assets/Warning.png" x:Name="ForcePushWarningImage" />
      <CheckBox Grid.Column="1" Grid.Row="5" Margin="8,4,0,0" HorizontalAlignment="Left" Content="_Force push" ToolTip="--force-with-lease" Checked="ForcePushCheckBox_Changed" Unchecked="ForcePushCheckBox_Changed" x:Name="ForcePushCheckBox" />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>
