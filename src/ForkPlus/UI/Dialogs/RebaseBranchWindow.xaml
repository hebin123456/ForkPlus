<dialogs:ForkPlusDialogWindow Width="570" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RebaseBranchWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Rebase:" />
      <controls:GitPointView Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="SourceGitPointView" />
      <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Text="On:" />
      <controls:GitPointView Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="DestinationGitPointView" />
      <CheckBox Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Top" HorizontalAlignment="Left" Content="Update dependent branches" ToolTip="--update-refs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Checked="UpdateRefsCheckBox_Changed" Unchecked="UpdateRefsCheckBox_Changed" x:Name="UpdateRefsCheckBox" />
      <ListBox Grid.Row="3" Grid.Column="1" MaxHeight="72" Margin="30,0,0,2" Background="{DynamicResource TextBox.Static.Background}" Padding="0" Style="{DynamicResource NoSelectionListBoxStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="LocalBranchesListBox">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Image Grid.Column="0" VerticalAlignment="Center" Width="16" Margin="0" Source="{DynamicResource BranchIcon}" />
              <TextBlock Grid.Column="1" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" FontSize="13">
                <TextBlock.Text>
                  <Binding />
                </TextBlock.Text>
              </TextBlock>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <CheckBox Grid.Row="4" Grid.Column="1" Margin="8,4,0,4" HorizontalAlignment="Left" Content="Stash and reapply local changes" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="AutostashCheckBox" />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>