<dialogs:ForkPlusDialogWindow Width="560" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.ForkSyncCheckWindow">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <StackPanel Grid.Column="1" Margin="0,4,0,0">
      <DockPanel Margin="0,0,0,8">
        <Image x:Name="StatusIcon" DockPanel.Dock="Left" Width="28" Height="28" VerticalAlignment="Top" Margin="0,0,10,0" />
        <TextBlock x:Name="StatusText" FontSize="14" TextWrapping="Wrap" FontWeight="Medium" />
      </DockPanel>
      <TextBlock x:Name="DetailText" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="0,4,0,0" />
    </StackPanel>
  </Grid>
</dialogs:ForkPlusDialogWindow>
