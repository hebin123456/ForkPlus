<dialogs:ForkPlusDialogWindow Width="520" SizeToContent="Height" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RemoveRemoteBranchWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,0,2" FontSize="13" VerticalAlignment="top" HorizontalAlignment="Right" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="StartPointTextBlock" />
      <controls:GitPointView Grid.Row="0" Grid.Column="1" Margin="8,6,0,2" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="GitPointView" />
      <Border Grid.Row="0" Grid.Column="1" Margin="8,6,0,2" Height="80" BorderThickness="1" BorderBrush="{DynamicResource TextBox.Static.Border}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="GitPointsContainer">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl Background="{DynamicResource TextBox.Static.Background}" x:Name="GitPoints">
            <ItemsControl.FocusVisualStyle>
              <x:Null />
            </ItemsControl.FocusVisualStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <controls:BindableGitPointView>
                  <controls:BindableGitPointView.GitPoint>
                    <Binding />
                  </controls:BindableGitPointView.GitPoint>
                </controls:BindableGitPointView>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>