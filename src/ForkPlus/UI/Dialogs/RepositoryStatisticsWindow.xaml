<dialogs:ForkPlusDialogWindow Title="Repository Statistics" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RepositoryStatisticsWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:usercontrols="clr-namespace:ForkPlus.UI.UserControls">
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <DockPanel>
      <TextBlock Text="Statistics" DockPanel.Dock="Left" Margin="4,0,0,2" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" />
      <controls:AutoTooltipTextBlock Margin="8,0,0,0" FontSize="14" VerticalAlignment="Center" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RepositoryNameTextBlock" />
    </DockPanel>
    <Grid Grid.Row="1">
      <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <usercontrols:StatisticsUserControl HorizontalAlignment="Stretch" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="StatisticsUserControl" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>