<dialogs:ForkPlusDialogWindow ResizeMode="NoResize" MaxHeight="400" SizeToContent="Height" Width="650" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.ConfigureSshKeysWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:uc="clr-namespace:ForkPlus.UI.UserControls">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200" />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Separator Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,10" />
      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,10">
        <TextBlock Text="SSH configuration: " FontSize="13" FontWeight="Medium" VerticalAlignment="Center" />
        <Image Height="14" Width="14" Margin="2,0,4,0" VerticalAlignment="Center" Source="{DynamicResource KeyIcon}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="SshConfigurationIcon" />
        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="13" VerticalAlignment="Center" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="SshConfigurationTextBlock" />
      </StackPanel>
      <Grid Grid.Row="3" Grid.Column="0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="SshKeyListBoxContainer">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="23" />
        </Grid.RowDefinitions>
        <ListBox VerticalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="SshKeyListBox_SelectionChanged" x:Name="SshKeyListBox">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <DockPanel>
                <CheckBox Margin="2,2,4,2" VerticalAlignment="Center" Checked="SshKeyCheckBox_Changed" Unchecked="SshKeyCheckBox_Changed">
                  <CheckBox.IsChecked>
                    <Binding Path="IsActive" />
                  </CheckBox.IsChecked>
                  <CheckBox.FocusVisualStyle>
                    <x:Null />
                  </CheckBox.FocusVisualStyle>
                </CheckBox>
                <Image DockPanel.Dock="Left" Height="14" Width="14" Margin="2,0,4,0" Source="{DynamicResource KeyIcon}" VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Left" FontSize="13" Margin="2,0,4,0" VerticalAlignment="Center" x:Name="KeyNameTextBlock">
                  <TextBlock.Text>
                    <Binding Path="KeyFileName" />
                  </TextBlock.Text>
                </TextBlock>
              </DockPanel>
              <DataTemplate.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition>
                      <Condition.Binding>
                        <Binding Path="IsSelected">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                          </Binding.RelativeSource>
                        </Binding>
                      </Condition.Binding>
                    </Condition>
                    <Condition>
                      <Condition.Binding>
                        <Binding Path="IsFocused">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                          </Binding.RelativeSource>
                        </Binding>
                      </Condition.Binding>
                    </Condition>
                  </MultiDataTrigger.Conditions>
                  <MultiDataTrigger.Setters>
                    <Setter TargetName="KeyNameTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
                  </MultiDataTrigger.Setters>
                </MultiDataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <uc:FallbackUserControl Grid.Row="0" Visibility="Collapsed" VerticalAlignment="Stretch" FallbackMessage="No SSH keys" HideFallbackImage="True" x:Name="FallbackUserControl" />
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1">
          <StackPanel Orientation="Horizontal">
            <controls:DropDownButton Width="24" Height="24" Padding="0" Margin="-1" Style="{DynamicResource {x:Type ToggleButton}}" BorderBrush="{DynamicResource BorderBrush}" x:Name="AddSSHKeyDropDownButton">
              <Image Source="{DynamicResource AddIcon}" Width="16" Height="16" VerticalAlignment="Center" />
              <controls:DropDownButton.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="New SSH Key..." Click="GenerateNewSSHKeyMenuItem_Click" x:Name="RepositoryCustomCommandMenuItem" />
                  <MenuItem Header="Open Existing SSH Key..." Click="BrowseKeyMenuItem_Click" x:Name="BrowseKeyMenuItem" />
                </ContextMenu>
              </controls:DropDownButton.ContextMenu>
            </controls:DropDownButton>
          </StackPanel>
        </Border>
      </Grid>
      <Grid Grid.Row="3" Grid.Column="1" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="SshKeyDetailsContainer">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Margin="14,0,0,4" FontSize="13" HorizontalAlignment="Right" Text="Location:" />
          <controls:SelectableTextBlock Grid.Row="0" Grid.Column="1" FontSize="13" Margin="8,0,0,4" TextTrimming="CharacterEllipsis" x:Name="SshKeyPathTextBlock" />
          <TextBlock Grid.Row="1" Grid.Column="0" Margin="14,4,0,4" FontSize="13" HorizontalAlignment="Right" Text="SHA256:" />
          <controls:SelectableTextBlock Grid.Row="1" Grid.Column="1" Margin="8,4,1,4" FontSize="13" VerticalAlignment="Center" x:Name="SshKeySha256TextBox" />
          <TextBlock Grid.Row="2" Grid.Column="0" Margin="18,4,0,0" FontSize="13" Text="Public Key:" />
          <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="14,4,0,0" FontSize="13" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" x:Name="SshKeyPublicKeyTextBox" />
          <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" FontSize="13" Margin="14,2,0,0">
            <Hyperlink NavigateUri="dummy" Style="{StaticResource BlueUnderlineHyperlinkStyle}" RequestNavigate="CopyPublicKey_RequestNavigate">
              <TextBlock HorizontalAlignment="Center" Text="Copy to clipboard" Margin="0" />
            </Hyperlink>
          </TextBlock>
        </Grid>
        <uc:FallbackUserControl Grid.Row="0" Visibility="Collapsed" x:Name="DetailsFallbackUserControl" />
      </Grid>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>