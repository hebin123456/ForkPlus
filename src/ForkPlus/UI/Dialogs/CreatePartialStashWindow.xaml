<dialogs:ForkPlusDialogWindow Height="370" Width="590" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.CreatePartialStashWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <ListBox Grid.Row="0" Margin="0,0,0,2" Background="{DynamicResource TextBox.Static.Background}" Style="{DynamicResource NoSelectionListBoxStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="PartialStashListBox">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <CheckBox Margin="8,0,4,0" VerticalAlignment="Center" Checked="FileCheckBox_Changed" Unchecked="FileCheckBox_Changed">
                <CheckBox.IsChecked>
                  <Binding Path="Selected" />
                </CheckBox.IsChecked>
                <CheckBox.FocusVisualStyle>
                  <x:Null />
                </CheckBox.FocusVisualStyle>
              </CheckBox>
              <Image Grid.Column="1" VerticalAlignment="Center" Width="16" Margin="4,0,4,0">
                <Image.Source>
                  <Binding Path="FileTypeIcon" />
                </Image.Source>
              </Image>
              <TextBlock Grid.Column="2" Margin="4,0,4,0" TextTrimming="CharacterEllipsis" FontSize="13">
                <TextBlock.Text>
                  <Binding Path="FilePath" />
                </TextBlock.Text>
              </TextBlock>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <controls:PlaceholderTextBox Grid.Row="1" Margin="0,4,0,4" Padding="4,2,4,2" Placeholder="Stash message (optional)" Icon="{DynamicResource SidebarStashIcon}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="StashMessageTextBox" />
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>