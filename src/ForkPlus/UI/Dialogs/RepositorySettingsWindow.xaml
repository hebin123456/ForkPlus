<dialogs:ForkPlusDialogWindow Title="Repository Settings" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.RepositorySettingsWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:repositorySettings="clr-namespace:ForkPlus.UI.UserControls.RepositorySettings" xmlns:preferences="clr-namespace:ForkPlus.UI.UserControls.Preferences">
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.RowDefinitions>
      <RowDefinition Height="0" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <controls:ModernTabControl Grid.Row="1" Background="#00FFFFFF">
      <TabItem Header="General" IsSelected="True">
        <repositorySettings:GeneralUserControl Margin="0,10,0,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="GeneralUserControl" />
      </TabItem>
      <TabItem Header="Commit">
        <repositorySettings:CommitTemplateUserControl Margin="0,10,0,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="CommitTemplateUserControl" />
      </TabItem>
      <TabItem Header="Issue Tracker">
        <repositorySettings:IssueTrackerUserControl Margin="0,10,0,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="IssueTrackerUserControl" />
      </TabItem>
      <TabItem Header="Custom Commands" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="CustomCommandsTab">
        <preferences:CustomCommandsUserControl Margin="0,10,0,0" x:Name="CustomCommandsUserControl" />
      </TabItem>
    </controls:ModernTabControl>
  </Grid>
</dialogs:ForkPlusDialogWindow>