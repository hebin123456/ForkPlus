<ui:CustomWindow xmlns="https://github.com/avaloniaui" xmlns:fud="clr-namespace:ForkPlus.UI.Dialogs" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.DiffPopupWindow">
  <Grid Margin="20,0,20,4">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.Children>
      <Border x:Name="FileDiffControlContainer">
        <Border.BorderBrush>
          <DynamicResource ResourceKey="BorderBrush" xmlns="https://github.com/avaloniaui" />
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Background>
          <DynamicResource ResourceKey="BackgroundBrush" xmlns="https://github.com/avaloniaui" />
        </Border.Background>
      </Border>
      <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="Space bar: close, Up/Down: move file selection">
        <TextBlock.Foreground>
          <DynamicResource ResourceKey="SecondaryLabelBrush" xmlns="https://github.com/avaloniaui" />
        </TextBlock.Foreground>
      </TextBlock>
    </Grid.Children>
  </Grid>
</ui:CustomWindow>