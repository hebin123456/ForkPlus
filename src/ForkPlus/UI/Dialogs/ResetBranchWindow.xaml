<dialogs:ForkPlusDialogWindow Width="590" SizeToContent="Height" xmlns="https://github.com/avaloniaui" xmlns:commands="clr-namespace:ForkPlus.Git.Commands" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.Dialogs.ResetBranchWindow" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="80" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Branch:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:GitPointView Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ActiveBranchGitPointView" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Move to:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <controls:GitPointView Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="DestinationGitPointView" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Reset type:" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" />
      <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" SelectionChanged="ResetTypeCombobox_SelectionChanged" x:Name="ResetTypeCombobox">
        <ComboBoxItem Tag="{x:Static commands:BranchResetType.Soft}">
          <DockPanel Width="420">
            <Ellipse DockPanel.Dock="Left" Width="12" Height="12" Fill="#FF34C84A" Margin="0,0,4,0" />
            <TextBlock DockPanel.Dock="Left" Text="Soft" Width="70" />
            <TextBlock DockPanel.Dock="Right" Text="S" Width="20" HorizontalAlignment="Left" />
            <TextBlock Text="Keep all changes. Stage differences" VerticalAlignment="Center" FontSize="13" />
          </DockPanel>
        </ComboBoxItem>
        <ComboBoxItem Tag="{x:Static commands:BranchResetType.Mixed}" IsSelected="True">
          <DockPanel Width="420">
            <Ellipse DockPanel.Dock="Left" Width="12" Height="12" Fill="#FFFDBE41" Margin="0,0,4,0" />
            <TextBlock DockPanel.Dock="Left" Text="Mixed" Width="70" />
            <TextBlock DockPanel.Dock="Right" Text="M" Width="20" HorizontalAlignment="Left" />
            <TextBlock Text="Keep all changes. Unstage differences" VerticalAlignment="Center" FontSize="13" />
          </DockPanel>
        </ComboBoxItem>
        <ComboBoxItem Tag="{x:Static commands:BranchResetType.Hard}">
          <DockPanel Width="420">
            <Ellipse DockPanel.Dock="Left" Width="12" Height="12" Fill="#FFFA4B49" Margin="0,0,4,0" />
            <TextBlock DockPanel.Dock="Left" Text="Hard" Width="70" />
            <TextBlock DockPanel.Dock="Right" Text="H" Width="20" HorizontalAlignment="Left" />
            <TextBlock Text="Discard all local changes" VerticalAlignment="Center" FontSize="13" />
          </DockPanel>
        </ComboBoxItem>
      </ComboBox>
    </Grid>
  </Grid>
</dialogs:ForkPlusDialogWindow>