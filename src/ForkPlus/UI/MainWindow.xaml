<ui:CustomWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="clr-namespace:ForkPlus.UI"
                 xmlns:controls="clr-namespace:ForkPlus.UI.Controls"
                 xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls"
                 x:Class="ForkPlus.UI.MainWindow"
                 Loaded="ForkWindow_Loaded"
                 Closing="Window_Closing"
                 Activated="Window_Activated"
                 Height="600" Width="1000" MinWidth="650" MinHeight="400">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <userControls:ToolbarUserControl Grid.Row="0" x:Name="Toolbar" />
    <controls:ClosableTabControl Grid.Row="1" x:Name="TabControl" />
  </Grid>
</ui:CustomWindow>
