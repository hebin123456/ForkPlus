<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.Preferences.AiReviewPreferencesUserControl">
  <Grid Width="560">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="170" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Grid.Column="0" Text="AI Model Configuration" Style="{DynamicResource SettingsHeaderTextBlockStyle}" />
    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Inference service URL:" />
    <controls:PlaceholderTextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="10,8,0,0" Padding="4,2,4,2" Placeholder="https://api.openai.com" TextChanged="ServiceUrlTextBox_TextChanged" x:Name="ServiceUrlTextBox" />
    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="API Key:" />
    <controls:PlaceholderTextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="10,8,0,0" Padding="4,2,4,2" Placeholder="API key" TextChanged="ApiKeyTextBox_TextChanged" x:Name="ApiKeyTextBox" />
    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Model:" />
    <ComboBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" Height="26" VerticalContentAlignment="Center" IsEditable="True" SelectionChanged="ModelComboBox_SelectionChanged" LostFocus="ModelComboBox_LostFocus" x:Name="ModelComboBox" />
    <Button Grid.Row="3" Grid.Column="2" Margin="6,8,0,0" Width="26" Height="26" Padding="4" ToolTip="Refresh models" Click="RefreshModelsButton_Click" x:Name="RefreshModelsButton">
      <Image Source="{DynamicResource RefreshIcon}" />
    </Button>
    <CheckBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="10,8,0,0" Content="Automatically fetch mounted models from URL and API key" Checked="AutoFetchModelsCheckBox_Changed" Unchecked="AutoFetchModelsCheckBox_Changed" x:Name="AutoFetchModelsCheckBox" />
    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Retry count:" />
    <TextBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" Width="48" HorizontalAlignment="Left" TextChanged="RetryCountTextBox_TextChanged" x:Name="RetryCountTextBox" />
    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Max timeout (seconds):" />
    <TextBox Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" Width="48" HorizontalAlignment="Left" TextChanged="TimeoutTextBox_TextChanged" x:Name="TimeoutTextBox" />
    <DockPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="10,8,0,0" x:Name="StatusContainer">
      <ProgressBar DockPanel.Dock="Left" Margin="0,0,6,0" Width="14" Height="14" Visibility="Collapsed" x:Name="BusyIndicator">
        <ProgressBar.Style>
          <DynamicResource ResourceKey="CircularProgressBar" />
        </ProgressBar.Style>
      </ProgressBar>
      <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="StatusTextBlock" />
    </DockPanel>
  </Grid>
</UserControl>
