<UserControl xmlns:local="clr-namespace:ForkPlus.UI.UserControls.Preferences" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.Preferences.CustomCommandsUserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:uc="clr-namespace:ForkPlus.UI.UserControls">
  <UserControl.Resources>
    <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
      <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
      <Style x:Key="QuestionmarkTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HintTextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Setter Property="FrameworkElement.ToolTip">
          <Setter.Value>
            <ToolTip>
              <ToolTip.DataContext>
                <Binding Path="PlacementTarget" RelativeSource="{x:Static RelativeSource.Self}" />
              </ToolTip.DataContext>
              <StackPanel>
                <TextBlock Text="Available variables:" />
                <TextBlock>
                  <TextBlock.Text>
                    <Binding Path="Tag" />
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </ToolTip>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="NameQuestionmarkTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HintTextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Setter Property="FrameworkElement.ToolTip">
          <Setter.Value>
            <ToolTip>
              <ToolTip.DataContext>
                <Binding Path="PlacementTarget" RelativeSource="{x:Static RelativeSource.Self}" />
              </ToolTip.DataContext>
              <StackPanel>
                <TextBlock Text="Use '/' for nesting" />
                <TextBlock Text="Available variables:" />
                <TextBlock>
                  <TextBlock.Text>
                    <Binding Path="Tag" />
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </ToolTip>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Width="900" Height="360" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="23" />
      </Grid.RowDefinitions>
      <ListBox VerticalAlignment="Stretch" MinHeight="250" BorderBrush="{DynamicResource BorderBrush}" ItemContainerStyle="{DynamicResource ListBoxItemWithBorderStyle}" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" SelectionChanged="CustomCommandsListBox_SelectionChanged" x:Name="CustomCommandsListBox">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <DockPanel>
                <Image DockPanel.Dock="Right" Width="16" Height="16" Margin="4,0,0,0" VerticalAlignment="Center" Source="{DynamicResource ShareIcon}">
                  <Image.Visibility>
                    <Binding Path="Shared" Converter="{StaticResource BooleanToVisibilityConverter}" />
                  </Image.Visibility>
                </Image>
                <TextBlock FontSize="13" Margin="4,0,4,0" TextTrimming="CharacterEllipsis">
                  <TextBlock.Text>
                    <Binding Path="Name" />
                  </TextBlock.Text>
                </TextBlock>
              </DockPanel>
              <TextBlock FontSize="13" Margin="4,0,4,0" Foreground="{DynamicResource SecondaryLabelBrush}" TextTrimming="CharacterEllipsis" x:Name="DetailsTextBlock">
                <TextBlock.Text>
                  <Binding Path="Details" />
                </TextBlock.Text>
              </TextBlock>
              <TextBlock FontSize="13" Margin="4,0,4,0" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="TargetTextBlock">
                <TextBlock.Text>
                  <Binding Path="Target"><Binding.Converter><local:CustomCommandTargetToDescriptionConverter /></Binding.Converter></Binding>
                </TextBlock.Text>
              </TextBlock>
            </StackPanel>
            <DataTemplate.Triggers>
              <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                  <Condition>
                    <Condition.Binding>
                      <Binding Path="IsSelected">
                        <Binding.RelativeSource>
                          <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                        </Binding.RelativeSource>
                      </Binding>
                    </Condition.Binding>
                  </Condition>
                  <Condition>
                    <Condition.Binding>
                      <Binding Path="IsFocused">
                        <Binding.RelativeSource>
                          <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListBoxItem}" />
                        </Binding.RelativeSource>
                      </Binding>
                    </Condition.Binding>
                  </Condition>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                  <Setter TargetName="DetailsTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
                  <Setter TargetName="TargetTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
                </MultiDataTrigger.Setters>
              </MultiDataTrigger>
            </DataTemplate.Triggers>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource BackgroundBrush}" BorderThickness="1,0,1,1">
        <StackPanel Orientation="Horizontal">
          <controls:DropDownButton Margin="-1,-1,0,-1" Style="{DynamicResource InlineToggleButton}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="AddCustomCommandDropDownButton">
            <Image Source="{DynamicResource AddIcon}" Width="16" Height="16" VerticalAlignment="Center" />
            <controls:DropDownButton.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Add Commit Custom Command" Click="RevisionCustomCommandMenuItem_Click" x:Name="RevisionCustomCommandMenuItem" />
                <MenuItem Header="Add Repository Custom Command" Click="RepositoryCustomCommandMenuItem_Click" x:Name="RepositoryCustomCommandMenuItem" />
                <MenuItem Header="Add File Custom Command" Click="FileCustomCommandMenuItem_Click" x:Name="FileCustomCommandMenuItem" />
                <MenuItem Header="Add Branch Custom Command" Click="ReferenceCustomCommandMenuItem_Click" x:Name="ReferenceCustomCommandMenuItem" />
                <MenuItem Header="Add Submodule Custom Command" Click="SubmoduleCustomCommandMenuItem_Click" x:Name="SubmoduleCustomCommandMenuItem" />
              </ContextMenu>
            </controls:DropDownButton.ContextMenu>
          </controls:DropDownButton>
          <Button Style="{DynamicResource InlineButton}" Margin="0,-1,0,-1" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="RemoveCustomCommandButton_Click" x:Name="RemoveCustomCommandButton">
            <Image Source="{DynamicResource RemoveIcon}" Width="16" Height="16" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
      </Border>
    </Grid>
    <Border Grid.Column="1" CornerRadius="4" Margin="10,0,2,0" BorderThickness="1" RenderOptions.ClearTypeHint="Enabled" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource GroupBoxBackgroundBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition />
          <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>
        <Grid Margin="0,16,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Grid.Column="1" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="LocationRadioButtonContainer">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
              <RadioButton Margin="10,0,0,0" Content="Local" Checked="LocationRadioButton_Changed" x:Name="LocalRadioButton" />
              <RadioButton Margin="15,0,0,0" Content="Shared" Checked="LocationRadioButton_Changed" x:Name="SharedRadioButton" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
              <Image Source="{DynamicResource ShareIcon}" Width="16" Height="16" Margin="-10,0,0,0" VerticalAlignment="Center" x:Name="ShareIcon" />
              <TextBlock Margin="4,0,0,10" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="LocationTextBlock" />
            </StackPanel>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="OS:" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" x:Name="OSTextBlock" />
            <ComboBox Grid.Row="0" Grid.Column="2" Margin="10,0,0,0" Width="80" HorizontalAlignment="Right" SelectionChanged="OSComboBox_SelectionChanged" x:Name="OSComboBox">
              <ComboBoxItem Content="Any" x:Name="AnyComboBoxItem" />
              <ComboBoxItem Content="Windows" x:Name="WindowsComboBoxItem" />
              <ComboBoxItem Content="MacOS" x:Name="MacComboBoxItem" />
            </ComboBox>
          </Grid>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Target:" FontSize="13" Margin="10,4,0,4" VerticalAlignment="Center" HorizontalAlignment="Right" />
          <ComboBox Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" Width="100" HorizontalAlignment="Left" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" SelectionChanged="TargetsComboBox_SelectionChanged" x:Name="TargetsComboBox">
            <ComboBoxItem x:Name="CommitComboBoxItem">
              <DockPanel Width="280">
                <TextBlock DockPanel.Dock="Left" Text="Commit" Width="80" FontSize="13" />
                <TextBlock Text="visible in commit context menu" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" />
              </DockPanel>
            </ComboBoxItem>
            <ComboBoxItem x:Name="RepositoryComboBoxItem">
              <DockPanel Width="280">
                <TextBlock DockPanel.Dock="Left" Text="Repository" Width="80" FontSize="13" />
                <TextBlock Text="visible in 'Open In' dropdown" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" />
              </DockPanel>
            </ComboBoxItem>
            <ComboBoxItem x:Name="FileComboBoxItem">
              <DockPanel Width="280">
                <TextBlock DockPanel.Dock="Left" Text="File" Width="80" FontSize="13" />
                <TextBlock Text="visible in file context menu" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" />
              </DockPanel>
            </ComboBoxItem>
            <ComboBoxItem x:Name="BranchComboBoxItem">
              <DockPanel Width="280">
                <TextBlock DockPanel.Dock="Left" Text="Branch" Width="80" FontSize="13" />
                <TextBlock Text="visible in branch context menu" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" />
              </DockPanel>
            </ComboBoxItem>
            <ComboBoxItem x:Name="SubmoduleComboBoxItem">
              <DockPanel Width="280">
                <TextBlock DockPanel.Dock="Left" Text="Submodule" Width="80" FontSize="13" />
                <TextBlock Text="visible in submodule context menu" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource SecondaryLabelBrush}" />
              </DockPanel>
            </ComboBoxItem>
          </ComboBox>
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="6,2,0,4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ReferenceTargetsContainer">
            <CheckBox Margin="4,2,2,2" Content="Local Branch">
              <CheckBox.IsChecked>
                <Binding Path="SelectedItem.LocalBranchReferenceTarget" />
              </CheckBox.IsChecked>
            </CheckBox>
            <CheckBox Margin="4,2,2,2" Content="Remote Branch">
              <CheckBox.IsChecked>
                <Binding Path="SelectedItem.RemoteBranchReferenceTarget" />
              </CheckBox.IsChecked>
            </CheckBox>
            <CheckBox Margin="4,2,2,2" Content="Tag">
              <CheckBox.IsChecked>
                <Binding Path="SelectedItem.TagReferenceTarget" />
              </CheckBox.IsChecked>
            </CheckBox>
          </StackPanel>
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Name:" FontSize="13" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" />
          <Grid Grid.Row="3" Grid.Column="1" Margin="10,4,0,4">
            <controls:PlaceholderTextBox Padding="4,2,14,2" Placeholder="e.g. '${repo:name}' status" FontSize="13">
              <controls:PlaceholderTextBox.Text>
                <Binding Path="SelectedItem.Name" />
              </controls:PlaceholderTextBox.Text>
            </controls:PlaceholderTextBox>
            <TextBlock Style="{DynamicResource NameQuestionmarkTextBlock}">
              <TextBlock.Tag>
                <Binding Path="SelectedItem.VariablesString" />
              </TextBlock.Tag>
            </TextBlock>
          </Grid>
          <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="6,4,0,4">
            <RadioButton Margin="4,0,0,0" Content="UI" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Checked="UIMode_Changed" x:Name="UiRadioButton" />
            <RadioButton Margin="15,0,0,0" Content="Action" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Checked="UIMode_Changed" x:Name="ProcessRadioButton" />
          </StackPanel>
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Action:" FontSize="13" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="ProcessActionTypeTextBlock" />
          <Button Grid.Row="5" Grid.Column="1" Margin="10,4,0,4" Padding="4,2,4,3" HorizontalContentAlignment="Stretch" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="ProcessActionButton_Click" x:Name="ProcessActionButton">
            <Button.ToolTip>
              <Binding Path="SelectedItem.ActionViewModel.ToolTip" />
            </Button.ToolTip>
            <DockPanel>
              <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Medium" Text="..." Margin="4,0,4,0" VerticalAlignment="Bottom" />
              <TextBlock DockPanel.Dock="Left" Margin="4,0,4,0" FontSize="13" FontWeight="Medium" x:Name="ProcessActionButtonTitleTextBlock">
                <TextBlock.Text>
                  <Binding Path="SelectedItem.ActionViewModel.Title" />
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Margin="4,0,4,0" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="ProcessActionButtonDetailsTextBlock">
                <TextBlock.Text>
                  <Binding Path="SelectedItem.ActionViewModel.Details" />
                </TextBlock.Text>
              </TextBlock>
            </DockPanel>
          </Button>
          <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="UiActionDetailsContainer">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text=" Title:" FontSize="13" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" />
            <Grid Grid.Row="0" Grid.Column="1" Margin="10,4,0,4">
              <controls:PlaceholderTextBox Padding="4,2,14,2" FontSize="13" Placeholder="Dialog title" x:Name="DialogTitleTextBox">
                <controls:PlaceholderTextBox.Text>
                  <Binding Path="SelectedItem.UIViewModel.DialogTitle" />
                </controls:PlaceholderTextBox.Text>
              </controls:PlaceholderTextBox>
              <TextBlock Style="{DynamicResource QuestionmarkTextBlock}">
                <TextBlock.Tag>
                  <Binding Path="SelectedItem.VariablesString" />
                </TextBlock.Tag>
              </TextBlock>
            </Grid>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontSize="13" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" />
            <Grid Grid.Row="1" Grid.Column="1" Margin="10,4,0,4">
              <controls:PlaceholderTextBox Padding="4,2,14,2" FontSize="13" Placeholder="Dialog description">
                <controls:PlaceholderTextBox.Text>
                  <Binding Path="SelectedItem.UIViewModel.DialogDescription" />
                </controls:PlaceholderTextBox.Text>
              </controls:PlaceholderTextBox>
              <TextBlock Style="{DynamicResource QuestionmarkTextBlock}">
                <TextBlock.Tag>
                  <Binding Path="SelectedItem.VariablesString" />
                </TextBlock.Tag>
              </TextBlock>
            </Grid>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Controls:" FontSize="13" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" />
            <Button Grid.Row="2" Grid.Column="1" HorizontalContentAlignment="Stretch" Margin="10,4,0,4" Padding="4,2,4,3" Click="UiControlsButton_Click" x:Name="UiControlsButton">
              <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Medium" Text="..." Margin="4,0,4,0" VerticalAlignment="Bottom" />
                <controls:AutoTooltipTextBlock DockPanel.Dock="Left" Margin="4,0,4,0" FontSize="13" FontWeight="Medium">
                  <controls:AutoTooltipTextBlock.Text>
                    <Binding Path="SelectedItem.UIViewModel.ControlsButtonTitle" />
                  </controls:AutoTooltipTextBlock.Text>
                </controls:AutoTooltipTextBlock>
              </DockPanel>
            </Button>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Buttons:" FontSize="13" Margin="0,4,0,4" VerticalAlignment="Center" HorizontalAlignment="Right" />
            <DockPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,0">
              <CheckBox DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,4,0" x:Name="UiActionButton1CheckBox">
                <CheckBox.IsChecked>
                  <Binding Path="SelectedItem.UIViewModel.Button1Enabled" />
                </CheckBox.IsChecked>
              </CheckBox>
              <Grid DockPanel.Dock="Left" Margin="0,4,0,4">
                <controls:PlaceholderTextBox Padding="4,2,14,2" Width="100" FontSize="13" Placeholder="Button Title">
                  <controls:PlaceholderTextBox.IsEnabled>
                    <Binding Path="IsChecked" />
                  </controls:PlaceholderTextBox.IsEnabled>
                  <controls:PlaceholderTextBox.Text>
                    <Binding Path="SelectedItem.UIViewModel.Button1Title" />
                  </controls:PlaceholderTextBox.Text>
                </controls:PlaceholderTextBox>
                <TextBlock Style="{DynamicResource QuestionmarkTextBlock}">
                  <TextBlock.Tag>
                    <Binding Path="SelectedItem.VariablesString" />
                  </TextBlock.Tag>
                </TextBlock>
              </Grid>
              <Button HorizontalContentAlignment="Stretch" Margin="4,0,0,0" Padding="4,2,4,3" Click="UiActionButton1_Click" x:Name="UiActionButton1">
                <Button.IsEnabled>
                  <Binding Path="IsChecked" />
                </Button.IsEnabled>
                <Button.ToolTip>
                  <Binding Path="SelectedItem.UIViewModel.Button1ActionViewModel.ToolTip" />
                </Button.ToolTip>
                <DockPanel>
                  <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Medium" Text="..." Margin="4,0,4,0" VerticalAlignment="Bottom" />
                  <TextBlock DockPanel.Dock="Left" Margin="4,0,4,0" FontSize="13" FontWeight="Medium">
                    <TextBlock.Text>
                      <Binding Path="SelectedItem.UIViewModel.Button1ActionViewModel.Title" />
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock Margin="4,0,4,0" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}">
                    <TextBlock.Text>
                      <Binding Path="SelectedItem.UIViewModel.Button1ActionViewModel.Details" />
                    </TextBlock.Text>
                  </TextBlock>
                </DockPanel>
              </Button>
            </DockPanel>
            <DockPanel Grid.Row="4" Grid.Column="1" Margin="10,0,0,0">
              <CheckBox DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,4,0" x:Name="UiActionButton2CheckBox">
                <CheckBox.IsChecked>
                  <Binding Path="SelectedItem.UIViewModel.Button2Enabled" />
                </CheckBox.IsChecked>
              </CheckBox>
              <Grid DockPanel.Dock="Left" Margin="0,4,0,4">
                <controls:PlaceholderTextBox Padding="4,2,14,2" Width="100" FontSize="13" Placeholder="Button Title" x:Name="UiActionButton2TitleTextBox">
                  <controls:PlaceholderTextBox.IsEnabled>
                    <Binding Path="IsChecked" />
                  </controls:PlaceholderTextBox.IsEnabled>
                  <controls:PlaceholderTextBox.Text>
                    <Binding Path="SelectedItem.UIViewModel.Button2Title" />
                  </controls:PlaceholderTextBox.Text>
                </controls:PlaceholderTextBox>
                <TextBlock Style="{DynamicResource QuestionmarkTextBlock}">
                  <TextBlock.Tag>
                    <Binding Path="SelectedItem.VariablesString" />
                  </TextBlock.Tag>
                </TextBlock>
              </Grid>
              <Button HorizontalContentAlignment="Stretch" Margin="4,0,0,0" Padding="4,2,4,3" Click="UiActionButton2_Click" x:Name="UiActionButton2">
                <Button.IsEnabled>
                  <Binding Path="IsChecked" />
                </Button.IsEnabled>
                <Button.ToolTip>
                  <Binding Path="SelectedItem.UIViewModel.Button2ActionViewModel.ToolTip" />
                </Button.ToolTip>
                <DockPanel>
                  <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Medium" Text="..." Margin="4,0,4,0" VerticalAlignment="Bottom" />
                  <TextBlock DockPanel.Dock="Left" Margin="4,0,4,0" FontSize="13" FontWeight="Medium">
                    <TextBlock.Text>
                      <Binding Path="SelectedItem.UIViewModel.Button2ActionViewModel.Title" />
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock Margin="4,0,4,0" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}">
                    <TextBlock.Text>
                      <Binding Path="SelectedItem.UIViewModel.Button2ActionViewModel.Details" />
                    </TextBlock.Text>
                  </TextBlock>
                </DockPanel>
              </Button>
            </DockPanel>
          </Grid>
        </Grid>
        <Border Grid.Column="1" Margin="16,0,0,0" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource BorderBrush}">
          <ScrollViewer Padding="6,6,2,0" Background="#00FFFFFF" VerticalScrollBarVisibility="Auto">
            <controls:SelectableTextBlock VerticalAlignment="Stretch" FontSize="12" TextWrapping="Wrap" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="DescriptionTextBlock" />
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>
    <uc:FallbackUserControl Margin="10,0,2,0" Grid.Column="1" Visibility="Collapsed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FallbackUserControl" />
  </Grid>
</UserControl>