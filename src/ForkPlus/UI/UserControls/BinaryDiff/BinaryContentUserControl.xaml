<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fuub="clr-namespace:ForkPlus.UI.UserControls.BinaryDiff" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.BinaryDiff.BinaryContentUserControl" xmlns:fuc="clr-namespace:ForkPlus.UI.Controls">
  <Grid Margin="0,0,0,22" MinHeight="20" HorizontalAlignment="Center" VerticalAlignment="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="35" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid.Children>
      <Grid Margin="0,10,0,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="42" />
          <ColumnDefinition />
          <ColumnDefinition Width="42" />
        </Grid.ColumnDefinitions>
        <Grid.Children>
          <Label Grid.Column="0" x:Name="LfsLabel">
            <Label.Style>
              <DynamicResource ResourceKey="LfsLabel" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </Label.Style>
            <Label.HorizontalAlignment>Left</Label.HorizontalAlignment>
          </Label>
          <Label Grid.Column="0" x:Name="NotLfsLabel">
            <Label.Style>
              <DynamicResource ResourceKey="NotLfsLabel" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </Label.Style>
          </Label>
          <TextBlock Grid.Column="1" Margin="4,0,4,0" HorizontalAlignment="Center" FontSize="13" FontWeight="Medium" x:Name="TitleTextBlock" />
        </Grid.Children>
      </Grid>
      <Grid Grid.Row="1">
        <Grid.Children>
          <Border>
            <Border.Style>
              <DynamicResource ResourceKey="BinaryDiffShadowBorder" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </Border.Style>
            <Border.Child>
              <Grid>
                <Grid.Children>
                  <Border BorderThickness="8,8,8,8" x:Name="ImageContainer">
                    <Border.BorderBrush>
                      <DynamicResource ResourceKey="BinaryDiffBackground" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                    </Border.BorderBrush>
                    <Border.Child>
                      <Border>
                        <Border.BorderBrush>
                          <DynamicResource ResourceKey="BinaryDiffBorder" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Border.Background>
                          <DynamicResource ResourceKey="TransparentVisualBrush" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                        </Border.Background>
                        <Border.Child>
                          <Grid>
                            <Grid.Children>
                              <Viewbox x:Name="ImageViewBox">
                                <Grid>
                                  <Grid.Children>
                                    <Image x:Name="Image" />
                                    <Image x:Name="DiffImage" />
                                  </Grid.Children>
                                </Grid>
                              </Viewbox>
                            </Grid.Children>
                          </Grid>
                        </Border.Child>
                      </Border>
                    </Border.Child>
                  </Border>
                  <Border BorderThickness="0" Height="130" Width="110" CornerRadius="3" x:Name="FileContainer">
                    <Border.Background>
                      <DynamicResource ResourceKey="BinaryDiffBackground" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                    </Border.Background>
                    <Border.Child>
                      <Grid Height="130" Width="110" VerticalAlignment="Center">
                        <Grid.Children>
                          <Grid Margin="0,30,0,0">
                            <Grid.RowDefinitions>
                              <RowDefinition Height="44" />
                              <RowDefinition Height="22" />
                              <RowDefinition Height="14" />
                              <RowDefinition Height="20" />
                            </Grid.RowDefinitions>
                            <Grid.Children>
                              <Image Grid.Row="0" Width="32" Height="32" Margin="0" VerticalAlignment="Center" x:Name="FileIcon" />
                              <Button Grid.Row="0" Margin="0" Click="ShowLfsImageButton_Click" x:Name="ShowLfsImageButton">
                                <Button.Style>
                                  <DynamicResource ResourceKey="LfsImageButtonStyle" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                </Button.Style>
                                <Image>
                                  <Image.Source>
                                    <DynamicResource ResourceKey="SearchIcon" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                  </Image.Source>
                                  <Image.Width>24</Image.Width>
                                  <Image.Height>24</Image.Height>
                                  <Image.VerticalAlignment>Center</Image.VerticalAlignment>
                                  <Image.HorizontalAlignment>Center</Image.HorizontalAlignment>
                                </Image>
                              </Button>
                              <Button Grid.Row="0" Margin="0" Click="CancelButton_Click" x:Name="CancelLfsButton">
                                <Button.Style>
                                  <DynamicResource ResourceKey="LfsImageButtonStyle" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                </Button.Style>
                                <Image>
                                  <Image.Source>
                                    <DynamicResource ResourceKey="CancelJobIcon" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                  </Image.Source>
                                  <Image.Width>24</Image.Width>
                                  <Image.Height>24</Image.Height>
                                  <Image.VerticalAlignment>Center</Image.VerticalAlignment>
                                  <Image.HorizontalAlignment>Center</Image.HorizontalAlignment>
                                </Image>
                              </Button>
                              <TextBlock Grid.Row="1" Margin="2,2,2,2" FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" x:Name="FileExtensionTextBlock">
                                <TextBlock.Foreground>
                                  <DynamicResource ResourceKey="ForegroundBrush.Gray" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                </TextBlock.Foreground>
                              </TextBlock>
                              <ProgressBar Grid.Row="2" Margin="2,4,2,0" VerticalAlignment="Center" x:Name="LfsProgressBar">
                                <ProgressBar.Style>
                                  <DynamicResource ResourceKey="LfsProgressBar" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
                                </ProgressBar.Style>
                              </ProgressBar>
                            </Grid.Children>
                          </Grid>
                        </Grid.Children>
                      </Grid>
                    </Border.Child>
                  </Border>
                </Grid.Children>
              </Grid>
            </Border.Child>
          </Border>
        </Grid.Children>
      </Grid>
      <StackPanel Grid.Row="1" Margin="0,0,0,-22" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
        <StackPanel.Children>
          <TextBlock VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="13" x:Name="DescriprionTextBlock">
            <TextBlock.Foreground>
              <DynamicResource ResourceKey="ForegroundBrush.Gray" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </TextBlock.Foreground>
          </TextBlock>
          <DropDownButton Margin="2,3,0,1" Padding="0,2,0,0" Height="14" Width="12" BorderThickness="0" xmlns="clr-namespace:ForkPlus.UI.Controls" x:Name="DropDownButton">
            <DropDownButton.Background>
              <SolidColorBrush xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">#00FFFFFF</SolidColorBrush>
            </DropDownButton.Background>
            <DropDownButton.Focusable>False</DropDownButton.Focusable>
            <DropDownButton.FocusVisualStyle>
              <x:Null />
            </DropDownButton.FocusVisualStyle>
            <DropDownButton.ContextMenu>
              <ContextMenu xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
                <ContextMenu.Items>
                  <MenuItem Header="Save As..." Click="SaveAsMenuItem_Click" x:Name="SaveAsMenuItem" />
                </ContextMenu.Items>
              </ContextMenu>
            </DropDownButton.ContextMenu>
            <Path HorizontalAlignment="Center" Margin="0" VerticalAlignment="Center" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
              <Path.Fill>
                <DynamicResource ResourceKey="ComboBox.Static.Glyph" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
              </Path.Fill>
              <Path.Data>
                <DynamicResource ResourceKey="ArrowGeometry" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
              </Path.Data>
            </Path>
          </DropDownButton>
        </StackPanel.Children>
      </StackPanel>
    </Grid.Children>
  </Grid>
</UserControl>