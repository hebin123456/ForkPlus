<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.GitMmUserControl">
  <UserControl.Resources>
    <DropShadowEffect x:Key="GitMmSubrepoTabShadow" BlurRadius="8" Color="Black" ShadowDepth="2" Direction="270" Opacity="{DynamicResource ClosableTabItem.ShadowOpacity}" />
    <Style x:Key="GitMmSubrepoTabItemStyle" TargetType="{x:Type TabItem}" BasedOn="{StaticResource ModernTabControlTabItemStyle}">
      <Setter Property="FrameworkElement.Height" Value="28" />
      <Setter Property="FrameworkElement.MinWidth" Value="140" />
      <Setter Property="Control.Padding" Value="14,2" />
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TabItem}">
            <Grid Margin="0,0,2,0" SnapsToDevicePixels="true" Background="{DynamicResource ClosableTabItem.Static.Background}" x:Name="templateRoot">
              <Border CornerRadius="4,4,0,0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource ClosableTabItem.Static.Border}" Background="{DynamicResource ClosableTabItem.Static.Background}" x:Name="Bd" />
              <ContentPresenter ContentSource="Header" Focusable="False" Margin="{TemplateBinding Control.Padding}" RecognizesAccessKey="True" TextElement.FontWeight="Medium" TextElement.Foreground="{DynamicResource TabItem.Static.Foreground}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" VerticalAlignment="Center" x:Name="contentPresenter" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="UIElement.IsMouseOver" Value="true">
                <Setter TargetName="Bd" Property="Panel.Background" Value="{DynamicResource ClosableTabItem.MouseOver.Background}" />
                <Setter TargetName="Bd" Property="Border.BorderBrush" Value="{DynamicResource ClosableTabItem.MouseOver.Border}" />
              </Trigger>
              <Trigger Property="TabItem.IsSelected" Value="true">
                <Setter Property="Panel.ZIndex" Value="1" />
                <Setter TargetName="Bd" Property="Panel.Background" Value="{DynamicResource ClosableTabItem.Selected.Background}" />
                <Setter TargetName="Bd" Property="Border.BorderBrush" Value="{DynamicResource ClosableTabItem.Selected.Border}" />
                <Setter TargetName="Bd" Property="UIElement.Effect" Value="{StaticResource GitMmSubrepoTabShadow}" />
                <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TabItem.Selected.Foreground}" />
              </Trigger>
              <Trigger Property="UIElement.IsEnabled" Value="false">
                <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="{DynamicResource TabItem.Disabled.Foreground}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="GitMmSubrepoTabControlStyle" TargetType="{x:Type controls:ModernTabControl}" BasedOn="{StaticResource {x:Type controls:ModernTabControl}}">
      <Style.Resources>
        <ResourceDictionary>
          <Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}" BasedOn="{StaticResource GitMmSubrepoTabItemStyle}" />
        </ResourceDictionary>
      </Style.Resources>
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type controls:ModernTabControl}">
            <Grid ClipToBounds="true" SnapsToDevicePixels="true" KeyboardNavigation.TabNavigation="Local" Background="{DynamicResource ClosableTabItem.Static.Background}" x:Name="templateRoot">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <ScrollViewer Grid.Row="0" Background="{DynamicResource ClosableTabItem.Static.Background}" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False" PanningMode="HorizontalOnly" PreviewMouseWheel="SubreposTabControl_PreviewMouseWheel">
                <Grid Background="{DynamicResource ClosableTabItem.Static.Background}">
                  <TabPanel IsItemsHost="true" Margin="0" KeyboardNavigation.TabIndex="1" Panel.ZIndex="1" x:Name="headerPanel" />
                  <Canvas>
                    <Border Height="1.5" Margin="0" Canvas.Left="0" Canvas.Bottom="0" BorderThickness="0" HorizontalAlignment="Left" Background="{DynamicResource SystemAccentBrush}" x:Name="PART_IndicatorBorder" />
                  </Canvas>
                </Grid>
              </ScrollViewer>
              <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" Grid.Row="1" KeyboardNavigation.DirectionalNavigation="Contained" KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local" x:Name="contentPanel">
                <ContentPresenter ContentSource="SelectedContent" Margin="{TemplateBinding Control.Padding}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" x:Name="PART_SelectedContentHost" />
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <Grid Margin="10" x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" MinHeight="160" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="150" MinHeight="80" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource BackgroundBrush}">
      <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="8,6,8,4">
          <Button DockPanel.Dock="Right" Margin="4,-2,0,-2" Padding="6,0" Width="24" Height="24" Foreground="{DynamicResource SecondaryLabelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource BackgroundBrush}" Style="{DynamicResource TransparentButtonStyle}" Content="?" FontWeight="SemiBold" ToolTip="git mm help" Click="GitMmHelpButton_Click" x:Name="GitMmHelpButton" />
          <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="8,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Click="SubrepoFilterButton_Click" x:Name="SubrepoFilterButton" />
          <TextBlock Text="Sub repositories" FontWeight="Medium" VerticalAlignment="Center" x:Name="SubreposTitleTextBlock" />
          <WrapPanel Margin="10,0,0,0" VerticalAlignment="Center" x:Name="SubrepoSummaryPanel" />
        </DockPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="8,0,8,6" Orientation="Horizontal">
          <controls:ToolbarButton Margin="0,3,0,3" Title="Start" Click="StartButton_Click" x:Name="StartButton">
            <controls:ToolbarButton.Style>
              <DynamicResource ResourceKey="ToolbarButton" />
            </controls:ToolbarButton.Style>
            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{DynamicResource BranchIcon}" />
          </controls:ToolbarButton>
          <controls:ToolbarButton Margin="0,3,0,3" Title="Sync" Click="SyncButton_Click" x:Name="SyncButton">
            <controls:ToolbarButton.Style>
              <DynamicResource ResourceKey="ToolbarButton" />
            </controls:ToolbarButton.Style>
            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{DynamicResource PullIcon}" />
          </controls:ToolbarButton>
          <controls:ToolbarButton Margin="0,3,0,3" Title="Upload" Click="UploadButton_Click" x:Name="UploadButton">
            <controls:ToolbarButton.Style>
              <DynamicResource ResourceKey="ToolbarButton" />
            </controls:ToolbarButton.Style>
            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{DynamicResource PushIcon}" />
          </controls:ToolbarButton>
        </WrapPanel>
        <controls:ModernTabControl BorderThickness="0" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{StaticResource GitMmSubrepoTabControlStyle}" x:Name="SubreposTabControl" />
      </DockPanel>
    </Border>

    <GridSplitter Grid.Row="1" Height="6" Margin="0,4,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Center" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Background="#00FFFFFF" x:Name="CommandOutputGridSplitter" />

    <Grid Grid.Row="2" Margin="0,4,0,0" x:Name="CommandOutputPanel">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <ProgressBar Grid.Row="0" Height="4" IsIndeterminate="True" Visibility="Collapsed" x:Name="BusyProgressBar" />
      <DockPanel Grid.Row="1" Margin="0,6,0,4">
        <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="8,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="Collapse" Click="ToggleCommandOutputButton_Click" x:Name="ToggleCommandOutputButton" />
        <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="8,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="Cancel" Visibility="Collapsed" Click="CancelCommandButton_Click" x:Name="CancelCommandButton" />
        <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="8,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="Uploads" Visibility="Collapsed" Click="ShowUploadLinksButton_Click" x:Name="ShowUploadLinksButton" />
        <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="8,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="History" Click="CommandHistoryButton_Click" x:Name="CommandHistoryButton" />
        <TextBlock Text="Command Output" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
      </DockPanel>
      <Border Grid.Row="2" Margin="0,0,0,4" Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource Item.SelectedInactive.Background}" CornerRadius="3" Visibility="Collapsed" x:Name="UploadLinksContainer">
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Margin="8,-2,0,-2" Padding="6,1" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="Hide" Click="HideUploadLinksButton_Click" x:Name="HideUploadLinksButton" />
          <TextBlock DockPanel.Dock="Left" Text="Recent Uploads:" Margin="0,1,10,1" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Center" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="UploadLinksPanel" />
          </ScrollViewer>
        </DockPanel>
      </Border>
      <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource BackgroundBrush}">
        <RichTextBox BorderThickness="0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource ForegroundBrush}" Background="{DynamicResource BackgroundBrush}" IsReadOnly="True" IsDocumentEnabled="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" x:Name="OutputTextBox" />
      </Border>
      <TextBlock Grid.Row="4" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryLabelBrush}" VerticalAlignment="Center" x:Name="StatusTextBlock" />
    </Grid>
    <Button Grid.Row="1" Margin="0,0,0,0" Padding="8,1" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryLabelBrush}" Style="{DynamicResource TextButtonStyle}" Content="Expand Command Output" Visibility="Collapsed" Click="ToggleCommandOutputButton_Click" x:Name="ExpandCommandOutputButton" />
  </Grid>
</UserControl>
