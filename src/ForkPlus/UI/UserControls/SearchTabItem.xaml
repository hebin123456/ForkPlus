<!-- 阶段 4.5：WPF→Avalonia XAML 迁移。
     - xmlns schemas.microsoft.com → https://github.com/avaloniaui
     - 删除子元素重复 xmlns（presentation / x）
     - DataTemplate DataType="{x:Type local:Foo}" → DataType="local:Foo"
     - TODO：DataTemplate.Triggers/DataTrigger 是 WPF 特有语法，Avalonia 需用 Selector 重写，此处保留原样待后续迁移
     -->
<TabItem Margin="10" Padding="0" xmlns:local="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.SearchTabItem" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <TabItem.Resources>
    <ResourceDictionary>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:SidebarSearchItem}}" DataType="local:SidebarSearchItem">
        <Grid Height="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0" Width="14" Height="14" Margin="4,0,4,0">
            <controls:AvatarImage x:Name="AuthorAvatarImage">
              <controls:AvatarImage.UserIdentity>
                <Binding Path="Author" />
              </controls:AvatarImage.UserIdentity>
            </controls:AvatarImage>
          </Grid>
          <controls:RevisionSubjectTextField Grid.Column="1" Margin="4,0,2,0" VerticalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI Variable Display" x:Name="RevisionSubjectTextBlock">
            <controls:RevisionSubjectTextField.StringValue>
              <Binding Path="Title" />
            </controls:RevisionSubjectTextField.StringValue>
            <controls:RevisionSubjectTextField.HighlightString>
              <Binding Path="SearchString" />
            </controls:RevisionSubjectTextField.HighlightString>
          </controls:RevisionSubjectTextField>
          <TextBlock Grid.Column="2" Margin="2,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush.Gray}" FontSize="12" x:Name="AuthorDateTextBlock">
            <TextBlock.Text>
              <Binding Path="AuthorDate" />
            </TextBlock.Text>
          </TextBlock>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type controls:TreeViewControlItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="RevisionSubjectTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
            <Setter TargetName="AuthorDateTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:SidebarSearchFileItem}}" DataType="local:SidebarSearchFileItem">
        <Grid Height="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Image Grid.Column="0" VerticalAlignment="Center" Margin="10,2,2,2" Width="12" Height="12">
            <Image.Source>
              <Binding Path="StatusImage" />
            </Image.Source>
          </Image>
          <Image Grid.Column="1" VerticalAlignment="Center" Margin="2" Width="12" Height="12">
            <Image.Source>
              <Binding Path="FileTypeIcon" />
            </Image.Source>
          </Image>
          <controls:HighlightableTextBlock Grid.Column="2" HorizontalAlignment="Stretch" FontSize="12" TextTrimming="CharacterEllipsis" x:Name="FilePathTextBlock">
            <controls:HighlightableTextBlock.Text>
              <Binding Path="Title" />
            </controls:HighlightableTextBlock.Text>
            <controls:HighlightableTextBlock.HighlightString>
              <Binding Path="SearchString" />
            </controls:HighlightableTextBlock.HighlightString>
          </controls:HighlightableTextBlock>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger Value="True">
            <DataTrigger.Binding>
              <Binding Path="IsSelected">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type controls:TreeViewControlItem}" />
                </Binding.RelativeSource>
              </Binding>
            </DataTrigger.Binding>
            <Setter TargetName="FilePathTextBlock" Value="{DynamicResource ForegroundBrush.Light}" Property="TextElement.Foreground" />
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </TabItem.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="26" />
        <RowDefinition Height="26" />
        <RowDefinition Height="26" />
      </Grid.RowDefinitions>
      <TextBlock Margin="10,2,0,2" FontSize="15" FontWeight="Medium" Text="Search Commits" Foreground="{DynamicResource ForegroundBrush}" />
      <Grid Grid.Row="1" Margin="4,4,4,0">
        <controls:FilterTextBox UseSecondaryTextBoxBackground="True" ShowDropdown="True" x:Name="FilterTextBox" />
        <ProgressBar Margin="0,0,20,1" Style="{DynamicResource CircularProgressBar}" Visibility="Collapsed" Width="12" Height="12" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrush.Gray}" x:Name="BusyIndicator" />
      </Grid>
      <DockPanel Grid.Row="2" Margin="6,3,6,3">
        <controls:DropDownButton DockPanel.Dock="Left" Height="20" Padding="4,0,4,0" VerticalAlignment="Center" Style="{DynamicResource ArrowDropDownButtonStyle}" BorderBrush="#00FFFFFF" Background="#00FFFFFF" x:Name="SearchDropdownButton">
          <controls:DropDownButton.ContextMenu>
            <ContextMenu MaxWidth="500" Opened="SearchDropdownButtonContextMenu_Opened" />
          </controls:DropDownButton.ContextMenu>
        </controls:DropDownButton>
        <TextBlock DockPanel.Dock="Right" Margin="0,0,0,2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="FoundCommitsTextBlock" />
      </DockPanel>
    </Grid>
    <Grid Grid.Row="1">
      <controls:MultiselectionTreeView Grid.Row="1" SelectionMode="Extended" Margin="0" Style="{DynamicResource SideBarSearchMultiselectionTreeViewStyle}" x:Name="TreeView">
        <controls:MultiselectionTreeView.ItemTemplate>
          <DataTemplate>
            <ContentControl>
              <ContentControl.Content>
                <Binding />
              </ContentControl.Content>
            </ContentControl>
          </DataTemplate>
        </controls:MultiselectionTreeView.ItemTemplate>
      </controls:MultiselectionTreeView>
    </Grid>
  </Grid>
</TabItem>
