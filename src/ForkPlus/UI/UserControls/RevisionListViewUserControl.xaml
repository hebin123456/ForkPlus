                          </Binding.RelativeSource>
                        </Binding>
                      </Condition.Binding>
                    </Condition>
                  </MultiDataTrigger.Conditions>
                  <Setter TargetName="AuthorTextBlock" Value="{DynamicResource SecondaryLabelBrush}" Property="TextElement.Foreground" />
                  <Setter TargetName="AuthorDateTextBlock" Value="{DynamicResource SecondaryLabelBrush}" Property="TextElement.Foreground" />
