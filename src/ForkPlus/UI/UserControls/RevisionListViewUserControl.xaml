                      </Condition.Binding>
                    </Condition>
                    <Condition Value="True">
                      <Condition.Binding>
                        <Binding Path="IsSelected">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="FindAncestor" AncestorType="{x:Type ListViewItem}" />
