      <Geometry x:Key="OptionMarkGeomentry" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">F1 M 9.97498,1.22334L 4.6983,9.09834L 4.52164,9.09834L 0,5.19331L 1.27664,3.52165L 4.255,6.08833L 8.33331,1.52588e-005L 9.97498,1.22334 Z</Geometry>
      <Style x:Key="ItemContainerStyle" TargetType="{x:Type controls:DragAndDropListViewItem}" BasedOn="{StaticResource ListViewItemGridViewStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
