                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </GridViewColumn.CellTemplate>
        </GridViewColumn>
      </GridView>
      <GridView x:Key="DoubleRowGridView" ColumnHeaderContainerStyle="{DynamicResource GridViewColumnHeaderStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
