<UserControl Background="{DynamicResource Sidebar.Static.Background}" xmlns:userControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RepositoryManagerUserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <UserControl.Resources>
    <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
      <Style x:Key="{x:Type controls:RepositoryManagerEditableTextBlock}" TargetType="{x:Type controls:RepositoryManagerEditableTextBlock}" BasedOn="{StaticResource {x:Type controls:EditableTextBlock}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
      <DataTemplate x:Key="{DataTemplateKey {x:Type userControls:RepositoryManagerSectionItem}}" DataType="{x:Type userControls:RepositoryManagerSectionItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="22">
          <TextBlock VerticalAlignment="Center" Margin="2,0,0,0" FontSize="13" TextTrimming="CharacterEllipsis" HorizontalAlignment="Stretch" FontWeight="Medium">
            <TextBlock.Text>
              <Binding Path="Title" />
            </TextBlock.Text>
          </TextBlock>
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type userControls:RepositoryManagerSourceDirectoryItem}}" DataType="{x:Type userControls:RepositoryManagerSourceDirectoryItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="22">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Image Grid.Column="0" Margin="2,2,4,2" Width="14" Height="14" VerticalAlignment="Center" Source="pack://application:,,,/ForkPlus;component/Assets/Folder.png" />
          <TextBlock Grid.Column="1" FontSize="14" Height="22" Margin="0,2,0,0" VerticalAlignment="Center">
            <TextBlock.Text>
              <Binding Path="Title" />
            </TextBlock.Text>
            <TextBlock.ToolTip>
              <Binding Path="SourceDir" />
            </TextBlock.ToolTip>
          </TextBlock>
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type userControls:RepositoryManagerRepositoryFolderItem}}" DataType="{x:Type userControls:RepositoryManagerRepositoryFolderItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="22">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Image Grid.Column="0" Margin="2,2,4,2" Width="14" Height="14" VerticalAlignment="Center" Source="pack://application:,,,/ForkPlus;component/Assets/Folder.png" />
          <TextBlock Grid.Column="1" FontSize="14" Height="22" Margin="0,2,0,0" VerticalAlignment="Center">
            <TextBlock.Text>
              <Binding Path="Title" />
            </TextBlock.Text>
          </TextBlock>
        </Grid>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type userControls:RepositoryManagerRepositoryItem}}" DataType="{x:Type userControls:RepositoryManagerRepositoryItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="22">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="17" />
          </Grid.ColumnDefinitions>
          <Image Grid.Column="0" Margin="-1,2,3,0" Width="16" Height="16">
            <Image.Source>
              <Binding Path="RepositoryIcon" />
            </Image.Source>
          </Image>
          <controls:RepositoryManagerEditableTextBlock Grid.Column="1" FontSize="14" Height="22">
            <controls:RepositoryManagerEditableTextBlock.Value>
              <Binding Path="Name" />
            </controls:RepositoryManagerEditableTextBlock.Value>
            <controls:RepositoryManagerEditableTextBlock.IsInEditMode>
              <Binding Path="IsInEditMode" />
            </controls:RepositoryManagerEditableTextBlock.IsInEditMode>
          </controls:RepositoryManagerEditableTextBlock>
          <Ellipse Grid.Column="2" Width="9" Height="9" Margin="4,2,4,2" HorizontalAlignment="Right" StrokeThickness="2">
            <Ellipse.Visibility>
              <Binding Path="RepositoryColor"><Binding.Converter><controls:NullToVisibilityConverter /></Binding.Converter></Binding>
            </Ellipse.Visibility>
            <Ellipse.Stroke>
              <Binding Path="RepositoryColor" />
            </Ellipse.Stroke>
          </Ellipse>
        </Grid>
      </DataTemplate>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" x:Name="RepositoryManagerGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" MinWidth="200" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="* " />
    </Grid.ColumnDefinitions>
    <TextBlock Text="Repository Manager" FontSize="22" VerticalAlignment="Center" Margin="20,10,10,10" FontWeight="Medium" Foreground="{DynamicResource ForegroundBrush}" x:Name="RepositoryManagerTitleTextBlock" />
    <Grid Grid.Row="2" Grid.Column="0" Background="{DynamicResource FallbackBackgroundBrush}" x:Name="FallbackView">
      <TextBlock Margin="40,0,40,200" TextAlignment="Center" HorizontalAlignment="Center" MinWidth="300" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="16" Foreground="{DynamicResource ForegroundBrush.Gray}" Text="Drop repository here to add" x:Name="FallbackMessage" />
      <Image Source="{DynamicResource FallbackIcon}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="128" MaxWidth="128" />
    </Grid>
    <controls:MultiselectionTreeView MouseDoubleClick="RepositoriesListBox_MouseDoubleClick" SelectionChanged="RepositoriesListBox_SelectionChanged" Grid.Row="2" Grid.Column="0" Visibility="Hidden" ItemContainerStyle="{DynamicResource RepositoryManagerTreeViewControlItemStyle}" TextSearch.TextPath="Name" Background="{DynamicResource Sidebar.Static.Background}" x:Name="RepositoriesTreeView">
      <controls:MultiselectionTreeView.ContextMenu>
        <ContextMenu />
      </controls:MultiselectionTreeView.ContextMenu>
      <controls:MultiselectionTreeView.ItemTemplate>
        <DataTemplate>
          <ContentControl RenderOptions.ClearTypeHint="Enabled">
            <ContentControl.Content>
              <Binding />
            </ContentControl.Content>
            <ContentControl.FocusVisualStyle>
              <x:Null />
            </ContentControl.FocusVisualStyle>
          </ContentControl>
        </DataTemplate>
      </controls:MultiselectionTreeView.ItemTemplate>
    </controls:MultiselectionTreeView>
    <userControls:RepositoryDetailsUserControl Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" x:Name="RepositoryDetailsUserControl" />
    <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Style="{DynamicResource VerticalGridSplitter}" x:Name="GridSplitter" />
  </Grid>
</UserControl>
