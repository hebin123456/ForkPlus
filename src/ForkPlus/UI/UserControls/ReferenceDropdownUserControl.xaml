<!-- 阶段 4.5：WPF→Avalonia XAML 迁移。
     - xmlns schemas.microsoft.com → https://github.com/avaloniaui
     - <StackPanel.Children> 展开为直接子元素
     -->
<UserControl xmlns="https://github.com/avaloniaui" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.ReferenceDropdownUserControl">
  <ComboBox Margin="0" x:Name="ReferenceComboBox">
    <ComboBox.ItemsPanel>
      <ItemsPanelTemplate>
        <VirtualizingStackPanel />
      </ItemsPanelTemplate>
    </ComboBox.ItemsPanel>
    <ComboBox.ItemTemplate>
      <DataTemplate>
        <StackPanel Orientation="Horizontal">
          <Image Height="16" Width="16" Margin="0" Source="{Binding Icon}" />
          <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="13" Text="{Binding Title}" />
        </StackPanel>
      </DataTemplate>
    </ComboBox.ItemTemplate>
  </ComboBox>
</UserControl>
