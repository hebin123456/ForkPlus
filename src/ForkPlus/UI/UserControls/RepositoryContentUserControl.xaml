<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:local="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RepositoryContentUserControl">
  <Grid>
    <Grid.Children>
      <Grid Visibility="Collapsed" x:Name="CommitView">
        <Grid.Children>
          <local:CommitUserControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="CommitUserControl" />
        </Grid.Children>
      </Grid>
      <Grid x:Name="RevisionView">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition MinHeight="110" />
          <RowDefinition MinHeight="110" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="400" MinWidth="300" />
          <ColumnDefinition />
          <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>
        <Grid.Children>
          <local:RevisionListStatusBarUserControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Visibility="Collapsed" x:Name="RevisionListStatusBarUserControl" />
          <local:RevisionListViewUserControl Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" FocusVisualStyle="{x:Null}" x:Name="RevisionListViewUserControl" />
          <local:RevisionDetailsUserControl Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" BorderThickness="0" x:Name="RevisionDetails" />
          <GridSplitter Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" x:Name="FirstColumnHorizontalGridSplitter">
            <GridSplitter.Style>
              <DynamicResource ResourceKey="HorizontalGridSplitter" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </GridSplitter.Style>
          </GridSplitter>
          <GridSplitter Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="32" Margin="260,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top" x:Name="SecondColumnHorizontalGridSplitter">
            <GridSplitter.Background>
              <SolidColorBrush xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">#00FFFFFF</SolidColorBrush>
            </GridSplitter.Background>
            <GridSplitter.BorderBrush>
              <DynamicResource ResourceKey="BorderBrush" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </GridSplitter.BorderBrush>
            <GridSplitter.BorderThickness>0,1,0,0</GridSplitter.BorderThickness>
            <GridSplitter.FocusVisualStyle>
              <x:Null />
            </GridSplitter.FocusVisualStyle>
          </GridSplitter>
          <GridSplitter Grid.Row="2" Grid.Column="2" VerticalAlignment="Top" x:Name="ThirdColumnHorizontalGridSplitter">
            <GridSplitter.Style>
              <DynamicResource ResourceKey="HorizontalGridSplitter" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </GridSplitter.Style>
          </GridSplitter>
          <GridSplitter Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" HorizontalAlignment="Right" x:Name="VerticalGridSplitter">
            <GridSplitter.Style>
              <DynamicResource ResourceKey="VerticalGridSplitter" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
            </GridSplitter.Style>
          </GridSplitter>
        </Grid.Children>
      </Grid>
    </Grid.Children>
  </Grid>
</UserControl>