<TabItem xmlns:local="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.PullRequestsTabItem" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <TabItem.Resources>
    <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:PullRequestItem}}" DataType="{x:Type local:PullRequestItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="50">
          <Grid.RowDefinitions>
            <RowDefinition Height="16" />
            <RowDefinition Height="17" />
            <RowDefinition Height="17" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
          </Grid.ColumnDefinitions>
          <Ellipse Grid.Column="0" Grid.Row="0" Width="6" Height="6" Margin="6,1,2,0" VerticalAlignment="Center">
            <Ellipse.Fill>
              <Binding Path="State"><Binding.Converter><local:PullRequestStateToColorConverter /></Binding.Converter></Binding>
            </Ellipse.Fill>
          </Ellipse>
          <DockPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2">
            <TextBlock DockPanel.Dock="Left" Margin="2,0,4,0" VerticalAlignment="Center" FontWeight="Medium">
              <TextBlock.Text>
                <Binding Path="PullRequestNumber" />
              </TextBlock.Text>
            </TextBlock>
            <controls:AvatarImage DockPanel.Dock="Right" Height="16" Width="16" Margin="2,1,2,0" VerticalAlignment="Center">
              <controls:AvatarImage.Url>
                <Binding Path="AvatarUrl" />
              </controls:AvatarImage.Url>
              <controls:AvatarImage.ToolTip>
                <Binding Path="AvatarTooltip" />
              </controls:AvatarImage.ToolTip>
            </controls:AvatarImage>
            <DockPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
              <Image DockPanel.Dock="Left" Margin="4,1,1,0" Width="12" Height="12" Source="{DynamicResource BranchIcon}" x:Name="SourceBranchIcon" />
              <Button Margin="0,0,2,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Style="{DynamicResource TextButtonStyle}" Foreground="{DynamicResource ForegroundBrush.Gray}" Click="SourceBranchButton_Click" x:Name="SourceBranchButton">
                <Button.ToolTip>
                  <Binding Path="SourceBranch" />
                </Button.ToolTip>
                <Button.Content>
                  <Binding Path="SourceBranch" />
                </Button.Content>
              </Button>
            </DockPanel>
          </DockPanel>
          <Button Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Grid.RowSpan="2" Height="34" Margin="2,0,0,0" FontSize="12" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" VerticalAlignment="Top" VerticalContentAlignment="Stretch" Foreground="{DynamicResource ForegroundBrush}" Style="{DynamicResource MultilineTextButtonStyle}" Click="PullRequestButton_Click">
            <Button.Content>
              <Binding Path="Title" />
            </Button.Content>
            <Button.ToolTip>
              <Binding Path="Title" />
            </Button.ToolTip>
          </Button>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger>
            <DataTrigger.Binding>
              <Binding Path="SourceBranch" />
            </DataTrigger.Binding>
            <DataTrigger.Value>
              <x:Null />
            </DataTrigger.Value>
            <Setter TargetName="SourceBranchIcon" Property="UIElement.Visibility" Value="Collapsed" />
            <Setter TargetName="SourceBranchButton" Property="UIElement.Visibility" Value="Collapsed" />
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </TabItem.Resources>
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,0">
      <DockPanel LastChildFill="False">
        <controls:DropDownButton DockPanel.Dock="Left" Height="20" Margin="6,0,6,0" Padding="4,0,0,0" VerticalAlignment="Center" Style="{DynamicResource ArrowDropDownButtonStyle}" BorderBrush="#00FFFFFF" Background="#00FFFFFF" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RemoteDropdownButton">
          <controls:DropDownButton.ContextMenu>
            <ContextMenu MaxWidth="500" Opened="RemoteDropdownButtonContextMenu_Opened" />
          </controls:DropDownButton.ContextMenu>
          <DockPanel>
            <Image DockPanel.Dock="Left" Height="13" Width="13" Margin="0,0,0,0" x:Name="RemoteDropdownButtonImage" />
            <TextBlock Margin="4,0,0,2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="RemoteDropdownButtonTitle" />
          </DockPanel>
        </controls:DropDownButton>
        <Button DockPanel.Dock="Right" IsTabStop="False" Style="{DynamicResource CodeEditorHeaderButtonStyle}" ToolTip="New Pull Request" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="NewPullRequestButton_Click">
          <Image Source="{DynamicResource AddIcon}" />
        </Button>
        <Grid DockPanel.Dock="Right">
          <Button IsTabStop="False" Style="{DynamicResource CodeEditorHeaderButtonStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Click="RefreshButton_Click" x:Name="RefreshButton">
            <Image Source="{DynamicResource RefreshIcon}" />
          </Button>
          <ProgressBar Margin="2,0,2,0" Style="{DynamicResource CircularProgressBar}" Visibility="Visible" Width="12" Height="12" HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundBrush.Gray}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="BusyIndicator" />
        </Grid>
      </DockPanel>
      <controls:FilterTextBox Margin="4,0,4,4" UseSecondaryTextBoxBackground="True" ShowDropdown="True" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FilterTextBox" />
    </StackPanel>
    <Grid Grid.Row="1">
      <controls:MultiselectionTreeView SelectionMode="Extended" Margin="0" Style="{DynamicResource SideBarIssuesMultiselectionTreeViewStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="TreeView">
        <controls:MultiselectionTreeView.ItemTemplate>
          <DataTemplate>
            <ContentControl>
              <ContentControl.Content>
                <Binding />
              </ContentControl.Content>
            </ContentControl>
          </DataTemplate>
        </controls:MultiselectionTreeView.ItemTemplate>
      </controls:MultiselectionTreeView>
      <local:FallbackUserControl xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FallbackUserControl" />
    </Grid>
  </Grid>
</TabItem>