<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.PathTextBoxUserControl">
  <DockPanel>
    <DockPanel.Children>
      <Button DockPanel.Dock="Right" Margin="2,0,0,0" Click="BrowseButton_Click">
        <Button.Style>
          <DynamicResource ResourceKey="BrowseButtonStyle" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" />
        </Button.Style>
      </Button>
      <TextBox Margin="0" Padding="4,2,4,2" x:Name="PathTextBox" />
    </DockPanel.Children>
  </DockPanel>
</UserControl>