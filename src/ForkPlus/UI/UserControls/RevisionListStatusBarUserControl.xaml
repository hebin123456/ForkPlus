<!-- Migrated from WPF to Avalonia: root xmlns updated to https://github.com/avaloniaui; redundant child xmlns declarations removed; Border.Child and StackPanel.Children property elements expanded into direct content. -->
<UserControl xmlns="https://github.com/avaloniaui" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RevisionListStatusBarUserControl">
  <Border Height="22" BorderThickness="0,0,0,1" x:Name="Container">
    <Border.BorderBrush>
      <DynamicResource ResourceKey="BorderBrush" />
    </Border.BorderBrush>
    <Border.Background>
      <DynamicResource ResourceKey="BackgroundBrush" />
    </Border.Background>
    <StackPanel Orientation="Horizontal">
      <TextBlock Margin="10,0,6,0" VerticalAlignment="Center" x:Name="HeaderTextBlock">
        <TextBlock.Foreground>
          <DynamicResource ResourceKey="ForegroundBrush.Gray" />
        </TextBlock.Foreground>
      </TextBlock>
      <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" x:Name="ReferencesTextBlock">
        <TextBlock.Foreground>
          <DynamicResource ResourceKey="ForegroundBrush" />
        </TextBlock.Foreground>
      </TextBlock>
      <Button Margin="0,0,0,0" VerticalAlignment="Center" FontSize="12" Click="StatusBarButton_Click" x:Name="StatusBarButton">
        <Button.Style>
          <DynamicResource ResourceKey="TextButtonStyle" />
        </Button.Style>
      </Button>
    </StackPanel>
  </Border>
</UserControl>
