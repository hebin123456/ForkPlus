<!-- Migrated from WPF to Avalonia: root xmlns updated to https://github.com/avaloniaui; redundant child xmlns declarations removed; Border.Child/Grid.Children/StackPanel.Children property elements expanded into direct content; RenderOptions.ClearTypeHint removed. -->
<UserControl FontFamily="Segoe UI Variable Display" MaxWidth="700" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.TooltipRevisionDetailsUserControl">
  <Border>
    <Border.Style>
      <DynamicResource ResourceKey="MenuShadowBorderStyle" />
    </Border.Style>
    <Border BorderThickness="1">
      <Border.BorderBrush>
        <DynamicResource ResourceKey="BorderBrush" />
      </Border.BorderBrush>
      <Border.Background>
        <DynamicResource ResourceKey="BackgroundBrush" />
      </Border.Background>
      <Border.CornerRadius>6</Border.CornerRadius>
      <Border.Padding>15,13,15,13</Border.Padding>
      <Grid>
        <Grid x:Name="DetailsContainer">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:AvatarImage Grid.Column="0" HorizontalAlignment="Left" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" x:Name="AuthorAvatarImage" />
            <controls:SelectableTextBlock Grid.Column="1" Margin="0,0,5,0" FontSize="13" FontWeight="Medium" x:Name="AuthorTextBlock">
              <TextBlock.Foreground>
                <DynamicResource ResourceKey="LabelBrush" />
              </TextBlock.Foreground>
            </controls:SelectableTextBlock>
            <controls:SelectableTextBlock Grid.Column="2" Margin="0,1,10,0" FontSize="12" x:Name="AuthorDateTextBlock">
              <TextBlock.Foreground>
                <DynamicResource ResourceKey="SecondaryLabelBrush" />
              </TextBlock.Foreground>
            </controls:SelectableTextBlock>
            <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Right">
              <controls:SelectableTextBlock Margin="0,1,4,0" FontSize="12" x:Name="ShaTextBlock">
                <TextBlock.Foreground>
                  <DynamicResource ResourceKey="SecondaryLabelBrush" />
                </TextBlock.Foreground>
              </controls:SelectableTextBlock>
              <Button Width="16" Height="16" Padding="0" Margin="0,0,0,0" VerticalAlignment="Center" BorderThickness="0" Click="ShowRevisionInSeparateWindowButton_Click" x:Name="ShowRevisionInSeparateWindowButton">
                <Button.Background>
                  <SolidColorBrush>#00FFFFFF</SolidColorBrush>
                </Button.Background>
                <ToolTipService.ToolTip>Open in separate window</ToolTipService.ToolTip>
                <Button.Style>
                  <DynamicResource ResourceKey="RevisionDetailsSwapButtonStyle" />
                </Button.Style>
                <Image>
                  <Image.Source>
                    <DynamicResource ResourceKey="OpenInSeparateWindowIcon" />
                  </Image.Source>
                  <Image.Height>14</Image.Height>
                  <Image.Width>14</Image.Width>
                </Image>
              </Button>
            </StackPanel>
          </Grid>
          <controls:ReferencePanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" FontSize="12" x:Name="ReferencePanel">
            <controls:ReferencePanel.Style>
              <DynamicResource ResourceKey="MultilineReferencePanelStyle" />
            </controls:ReferencePanel.Style>
          </controls:ReferencePanel>
          <controls:SelectableTextBlock Grid.Row="2" Margin="0,6,0,0" FontSize="14" FontWeight="Medium" x:Name="SubjectTextBlock">
            <TextBlock.Foreground>
              <DynamicResource ResourceKey="LabelBrush" />
            </TextBlock.Foreground>
            <TextBlock.TextTrimming>CharacterEllipsis</TextBlock.TextTrimming>
          </controls:SelectableTextBlock>
        </Grid>
        <TextBlock TextAlignment="Center" Text="Not available" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="FallbackMessageTextBlock">
          <TextBlock.Foreground>
            <DynamicResource ResourceKey="SecondaryLabelBrush" />
          </TextBlock.Foreground>
        </TextBlock>
      </Grid>
    </Border>
  </Border>
</UserControl>
