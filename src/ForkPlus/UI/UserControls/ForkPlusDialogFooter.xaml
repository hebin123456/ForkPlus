<!-- 阶段 4.5：WPF→Avalonia XAML 迁移。
     - xmlns schemas.microsoft.com → https://github.com/avaloniaui
     - 删除子元素重复 xmlns（presentation）
     - <DockPanel.Children>/<StackPanel.Children> 展开为直接子元素
     -->
<UserControl xmlns="https://github.com/avaloniaui" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.ForkPlusDialogFooter">
  <DockPanel Margin="0,10,0,0">
    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
      <Button Click="SubmitButton_Click" x:Name="SubmitButton">Submit<Button.Margin>4,0,4,0</Button.Margin><Button.IsDefault>True</Button.IsDefault></Button>
      <Button Click="CancelButton_Click" x:Name="CancelButton">Cancel<Button.Margin>4,0,0,0</Button.Margin></Button>
    </StackPanel>
    <ContentControl DockPanel.Dock="Left" x:Name="CustomSection" />
    <ProgressBar DockPanel.Dock="Left" Margin="0,0,5,0" x:Name="BusyIndicator">
      <ProgressBar.Style>
        <DynamicResource ResourceKey="CircularProgressBar" />
      </ProgressBar.Style>
      <ProgressBar.Visibility>Hidden</ProgressBar.Visibility>
      <ProgressBar.Width>14</ProgressBar.Width>
      <ProgressBar.Height>14</ProgressBar.Height>
      <ProgressBar.Foreground>
        <DynamicResource ResourceKey="ForegroundBrush.Gray" />
      </ProgressBar.Foreground>
    </ProgressBar>
    <Image DockPanel.Dock="Left" Margin="0,0,5,0" Width="18" Height="Auto" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" Source="/ForkPlus;component/Assets/Warning.png" x:Name="StatusImage" />
    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" Visibility="Collapsed" x:Name="StatusMessageTextBlock" />
  </DockPanel>
</UserControl>
