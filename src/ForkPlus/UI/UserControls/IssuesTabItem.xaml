<!-- 阶段 4.5：WPF→Avalonia XAML 迁移。
     - xmlns schemas.microsoft.com → https://github.com/avaloniaui
     - 删除子元素重复 xmlns（presentation / x）
     - DataTemplate DataType="{x:Type local:Foo}" → DataType="local:Foo"
     -->
<TabItem xmlns:local="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.IssuesTabItem" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <TabItem.Resources>
    <ResourceDictionary>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:IssueItem}}" DataType="local:IssueItem">
        <Grid Height="50">
          <Grid.RowDefinitions>
            <RowDefinition Height="16" />
            <RowDefinition Height="17" />
            <RowDefinition Height="17" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
          </Grid.ColumnDefinitions>
          <Ellipse Grid.Column="0" Width="6" Height="6" Margin="6,1,2,0" VerticalAlignment="Center">
            <Ellipse.Fill>
              <Binding Path="State"><Binding.Converter><local:IssueStateToColorConverter /></Binding.Converter></Binding>
            </Ellipse.Fill>
          </Ellipse>
          <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Margin="2,0,4,0" VerticalAlignment="Center" FontWeight="Medium">
            <TextBlock.Text>
              <Binding Path="IssueNumber" />
            </TextBlock.Text>
          </TextBlock>
          <controls:AvatarImage Grid.Column="2" Height="16" Width="16" Margin="2,1,2,0" VerticalAlignment="Center">
            <controls:AvatarImage.Url>
              <Binding Path="AvatarUrl" />
            </controls:AvatarImage.Url>
            <controls:AvatarImage.ToolTip>
              <Binding Path="AvatarTooltip" />
            </controls:AvatarImage.ToolTip>
          </controls:AvatarImage>
          <Button Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Grid.RowSpan="2" Height="34" Margin="2,0,0,0" FontSize="12" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" VerticalAlignment="Top" VerticalContentAlignment="Stretch" Foreground="{DynamicResource ForegroundBrush}" Style="{DynamicResource MultilineTextButtonStyle}" Click="IssueButton_Click">
            <Button.Content>
              <Binding Path="Title" />
            </Button.Content>
            <Button.ToolTip>
              <Binding Path="Title" />
            </Button.ToolTip>
          </Button>
        </Grid>
      </DataTemplate>
    </ResourceDictionary>
  </TabItem.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,0">
      <DockPanel LastChildFill="False">
        <controls:DropDownButton DockPanel.Dock="Left" Height="20" Margin="6,0,6,0" Padding="4,0,0,0" VerticalAlignment="Center" Style="{DynamicResource ArrowDropDownButtonStyle}" BorderBrush="#00FFFFFF" Background="#00FFFFFF" x:Name="RemoteDropdownButton">
          <controls:DropDownButton.ContextMenu>
            <ContextMenu MaxWidth="500" Opened="RemoteDropdownButtonContextMenu_Opened" />
          </controls:DropDownButton.ContextMenu>
          <DockPanel>
            <Image DockPanel.Dock="Left" Height="13" Width="13" Margin="0,0,0,0" x:Name="RemoteDropdownButtonImage" />
            <TextBlock Margin="4,0,0,2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryLabelBrush}" x:Name="RemoteDropdownButtonTitle" />
          </DockPanel>
        </controls:DropDownButton>
        <Button DockPanel.Dock="Right" IsTabStop="False" Style="{DynamicResource CodeEditorHeaderButtonStyle}" ToolTip="New Issue" Click="NewIssueButton_Click">
          <Image Source="{DynamicResource AddIcon}" />
        </Button>
        <Grid DockPanel.Dock="Right">
          <Button IsTabStop="False" Style="{DynamicResource CodeEditorHeaderButtonStyle}" Click="RefreshButton_Click" x:Name="RefreshButton">
            <Image Source="{DynamicResource RefreshIcon}" />
          </Button>
          <ProgressBar Margin="2,0,2,0" Style="{DynamicResource CircularProgressBar}" Visibility="Visible" Width="12" Height="12" HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundBrush.Gray}" x:Name="BusyIndicator" />
        </Grid>
      </DockPanel>
      <controls:FilterTextBox Margin="4,0,4,4" UseSecondaryTextBoxBackground="True" ShowDropdown="True" x:Name="FilterTextBox" />
    </StackPanel>
    <Grid Grid.Row="1">
      <controls:MultiselectionTreeView SelectionMode="Extended" Margin="0" Style="{DynamicResource SideBarIssuesMultiselectionTreeViewStyle}" x:Name="TreeView">
        <controls:MultiselectionTreeView.ItemTemplate>
          <DataTemplate>
            <ContentControl>
              <ContentControl.Content>
                <Binding />
              </ContentControl.Content>
            </ContentControl>
          </DataTemplate>
        </controls:MultiselectionTreeView.ItemTemplate>
      </controls:MultiselectionTreeView>
      <local:FallbackUserControl x:Name="FallbackUserControl" />
    </Grid>
  </Grid>
</TabItem>
