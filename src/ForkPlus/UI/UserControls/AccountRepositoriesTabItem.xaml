<TabItem xmlns:usercontrols="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.AccountRepositoriesTabItem" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:local="clr-namespace:ForkPlus.UI.UserControls" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <TabItem.Resources>
    <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:AccountRepositoryItem}}" DataType="{x:Type local:AccountRepositoryItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <DockPanel Height="20" Margin="10,0,0,0" x:Name="TestDockPanel">
          <Image DockPanel.Dock="Left" Height="14" Width="14" VerticalAlignment="Center" Margin="0,0,4,0" x:Name="IconImage">
            <Image.Source>
              <Binding Path="Icon" />
            </Image.Source>
          </Image>
          <Button DockPanel.Dock="Right" VerticalAlignment="Center" Style="{DynamicResource CodeEditorHeaderButtonStyle}" Click="CloneButton_Click" x:Name="CloneButton">
            <Button.ToolTip>
              <Binding Path="Tooltip" />
            </Button.ToolTip>
            <Image Source="{DynamicResource DownloadIcon}" x:Name="StarButtonImage" />
          </Button>
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" x:Name="NameTextBlock">
            <TextBlock.Text>
              <Binding Path="Title" />
            </TextBlock.Text>
          </TextBlock>
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="{DataTemplateKey {x:Type local:AccountHeaderItem}}" DataType="{x:Type local:AccountHeaderItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid Height="20">
          <Border HorizontalAlignment="Stretch" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0">
            <TextBlock Margin="2,0,0,0" FontSize="13.5" FontWeight="Medium" VerticalAlignment="Center" x:Name="NameTextBlock">
              <TextBlock.Text>
                <Binding Path="Title" />
              </TextBlock.Text>
            </TextBlock>
          </Border>
        </Grid>
      </DataTemplate>
    </ResourceDictionary>
  </TabItem.Resources>
  <Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Grid.RowDefinitions>
      <RowDefinition Height="30" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <controls:FilterTextBox Grid.Row="0" Margin="4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FilterTextBox" />
    <ListBox Grid.Row="1" BorderThickness="0" Margin="0,0,0,0" HorizontalContentAlignment="Stretch" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RepositoriesListBox">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <ContentControl>
            <ContentControl.Content>
              <Binding />
            </ContentControl.Content>
          </ContentControl>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <local:FallbackUserControl Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FallbackUserControl" />
  </Grid>
</TabItem>