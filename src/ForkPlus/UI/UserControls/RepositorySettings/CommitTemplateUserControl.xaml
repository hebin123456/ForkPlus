<!-- 已从 WPF 迁移到 Avalonia：xmlns 替换为 https://github.com/avaloniaui；删除子元素重复 xmlns；展开 Grid.Children 属性元素语法。 -->
<UserControl xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fuur="clr-namespace:ForkPlus.UI.UserControls.RepositorySettings" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RepositorySettings.CommitTemplateUserControl" xmlns:fuc="clr-namespace:ForkPlus.UI.Controls">
  <Grid Width="400">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Text="Commit Template">
      <TextBlock.Style>
        <DynamicResource ResourceKey="SettingsHeaderTextBlockStyle" />
      </TextBlock.Style>
    </TextBlock>
    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Checked="UseGlobalCommitTemplateCheckbox_Changed" Unchecked="UseGlobalCommitTemplateCheckbox_Changed" x:Name="UseGlobalCommitTemplateCheckBox">Use global git configuration file</CheckBox>
    <controls:AutoTooltipTextBlock Grid.Row="2" Grid.Column="1" Margin="4,0,0,4" HorizontalAlignment="Right" VerticalAlignment="Bottom" FontSize="11" x:Name="CommitTemplatePathTextBlock">
      <TextBlock.Foreground>
        <DynamicResource ResourceKey="SecondaryLabelBrush" />
      </TextBlock.Foreground>
    </controls:AutoTooltipTextBlock>
    <controls:PlaceholderTextBox TextChanged="CommitTemplateTextBox_TextChanged" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4" HorizontalAlignment="Stretch" Height="120" VerticalAlignment="Stretch" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" x:Name="CommitTemplateTextBox" />
    <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,8" />
    <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Checked="AddSignedOffMessageCheckBox_Changed" Unchecked="AddSignedOffMessageCheckBox_Changed" x:Name="AddSignedOffMessageCheckBox">Add Signed-off-by line at the end of the commit message</CheckBox>
    <Separator Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,8" />
    <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Checked="SkipCommitMessageCheckBox_Changed" Unchecked="SkipCommitMessageCheckBox_Changed" x:Name="SkipCommitMessageCheckBox">Do not require commit message</CheckBox>
    <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Text="Commit message regex:" x:Name="CommitMessageRegexLabel" />
    <TextBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0" HorizontalAlignment="Stretch" Height="64" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextChanged="CommitMessageRegexTextBox_TextChanged" x:Name="CommitMessageRegexTextBox" />
  </Grid>
</UserControl>
