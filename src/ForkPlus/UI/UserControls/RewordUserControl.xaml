<!-- Migrated from WPF to Avalonia: root xmlns updated to https://github.com/avaloniaui; redundant child xmlns declarations removed; Grid.Children/Border.Child/StackPanel.Children property elements expanded into direct content; PreviewKeyDown events renamed to KeyDown; SnapsToDevicePixels attribute removed. -->
<UserControl Height="180" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RewordUserControl" KeyDown="UserControl_PreviewKeyDown" xmlns:fuc="clr-namespace:ForkPlus.UI.Controls">
  <Grid>
    <Border Margin="8">
      <Border.Background>
        <DynamicResource ResourceKey="Menu.MenuItem.Static.Background" />
      </Border.Background>
      <Border.CornerRadius>6</Border.CornerRadius>
      <Border.Effect>
        <DropShadowEffect BlurRadius="10">
          <DropShadowEffect.Color>
            <DynamicResource ResourceKey="DropShadowColor" />
          </DropShadowEffect.Color>
          <DropShadowEffect.Opacity>0.2</DropShadowEffect.Opacity>
          <DropShadowEffect.ShadowDepth>1</DropShadowEffect.ShadowDepth>
        </DropShadowEffect>
      </Border.Effect>
    </Border>
    <Border Padding="10" Margin="7" BorderThickness="1" CornerRadius="6">
      <Border.BorderBrush>
        <DynamicResource ResourceKey="Menu.MenuItem.Static.Border" />
      </Border.BorderBrush>
      <Border.Background>
        <DynamicResource ResourceKey="Menu.MenuItem.Static.Background" />
      </Border.Background>
      <Grid Width="600">
        <Grid.RowDefinitions>
          <RowDefinition Height="24" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:SpellingPlaceholderTextBox TextChanged="CommitSubjectTextBox_TextChanged" KeyDown="CommitSubjectTextBox_PreviewKeyDown" Grid.Row="0" HorizontalAlignment="Stretch" Padding="4,1,32,1" BorderThickness="1,1,1,0" Placeholder="Commit subject" x:Name="CommitSubjectTextBox">
          <controls:SpellingPlaceholderTextBox.Style>
            <DynamicResource ResourceKey="CommitPlaceholderTextBox" />
          </controls:SpellingPlaceholderTextBox.Style>
        </controls:SpellingPlaceholderTextBox>
        <TextBlock Grid.Row="0" Margin="0,4,6,1" HorizontalAlignment="Right" FontSize="12" x:Name="SubjectLengthLimitTextBlock" />
        <Border Grid.Row="0">
          <Border.BorderBrush>
            <DynamicResource ResourceKey="BorderBrush" />
          </Border.BorderBrush>
          <Border.BorderThickness>1</Border.BorderThickness>
          <Border.Height>1</Border.Height>
          <Border.VerticalAlignment>Bottom</Border.VerticalAlignment>
          <Border.Margin>1,0,1,0</Border.Margin>
        </Border>
        <controls:CommitDescriptionTextBox KeyDown="CommitDescriptionTextBox_PreviewKeyDown" Grid.Row="1" Margin="0" Padding="4,2,4,3" HorizontalAlignment="Stretch" BorderThickness="1,0,1,1" TextWrapping="Wrap" AcceptsReturn="True" Placeholder="Description" x:Name="CommitDescriptionTextBox" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Click="CommitMessageCancelButton_Click">Cancel<Button.Margin>2,6,5,-3</Button.Margin><Button.Padding>10,2</Button.Padding></Button>
          <Button Click="CommitMessageOkButton_Click">OK<Button.Margin>2,6,0,-3</Button.Margin><Button.Padding>10,2</Button.Padding></Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
