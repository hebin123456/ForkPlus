<UserControl xmlns:usercontrols="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.StatisticsUserControl" xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <UserControl.Resources>
    <ResourceDictionary xmlns="https://github.com/avaloniaui">
      <ControlTemplate x:Key="TrackerControlDataTemplate" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <oxy:TrackerControl VerticalLineVisibility="Collapsed" HorizontalLineVisibility="Collapsed" Background="#FFF1F2F7" BorderBrush="#FF767676" xmlns:oxy="http://oxyplot.org/avalonia">
          <oxy:TrackerControl.Position>
            <Binding Path="Position" />
          </oxy:TrackerControl.Position>
          <oxy:TrackerControl.LineExtents>
            <Binding Path="PlotModel.PlotArea" />
          </oxy:TrackerControl.LineExtents>
          <oxy:TrackerControl.Content>
            <TextBlock Margin="7" Foreground="#FF575757">
              <TextBlock.Text>
                <Binding />
              </TextBlock.Text>
            </TextBlock>
          </oxy:TrackerControl.Content>
        </oxy:TrackerControl>
      </ControlTemplate>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid xmlns="https://github.com/avaloniaui">
    <Grid MinWidth="900" Margin="30,15,20,15" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="StatsContainer">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <controls:DateRangeButton Grid.Row="0" Margin="0,10,0,10" HorizontalAlignment="Left" x:Name="DateRangeButton" />
      <TextBlock Grid.Row="1" Text="Commits per month" Margin="10,0,0,0" FontSize="16" FontWeight="Medium" />
      <oxy:PlotView Grid.Row="2" Height="350" Margin="4,10,0,0" HorizontalAlignment="Stretch" DefaultTrackerTemplate="{DynamicResource TrackerControlDataTemplate}" xmlns:oxy="http://oxyplot.org/avalonia" x:Name="LinePlot" />
      <TextBlock Grid.Row="3" Text="Contributions" Margin="10,20,0,0" FontSize="16" FontWeight="Medium" />
      <controls:ContributionHeatmap Grid.Row="4" Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" x:Name="Heatmap" />
      <Grid Grid.Row="5">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,20,0,0">
          <TextBlock Text="All contributors" Margin="10,0,0,10" FontSize="16" FontWeight="Medium" />
          <ListBox Width="350" Margin="35,0,0,0" BorderThickness="1,1,1,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" HorizontalContentAlignment="Stretch" VerticalAlignment="Top" Style="{DynamicResource NoSelectionListBoxStyle}" x:Name="AuthorStatListBox">
            <ListBox.ItemContainerStyle>
              <Style Selector="ListBoxItem">
                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Height="18">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="45" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Margin="4,0,4,0" TextTrimming="CharacterEllipsis">
                    <TextBlock.Text>
                      <Binding Path="Name" />
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock.Text>
                      <Binding Path="TotalCommits" />
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="50,20,0,0">
          <TextBlock Text="Top contributors" FontSize="16" Margin="10,0,0,0" FontWeight="Medium" />
          <oxy:PlotView Height="450" Width="450" HorizontalAlignment="Left" VerticalAlignment="Top" DefaultTrackerTemplate="{DynamicResource TrackerControlDataTemplate}" xmlns:oxy="http://oxyplot.org/avalonia" x:Name="PiePlot" />
          <TextBlock Text="Commits per weekday" FontSize="16" Margin="10,0,0,0" FontWeight="Medium" />
          <oxy:PlotView Height="300" HorizontalAlignment="Stretch" DefaultTrackerTemplate="{DynamicResource TrackerControlDataTemplate}" xmlns:oxy="http://oxyplot.org/avalonia" x:Name="WeekDayPlot" />
          <TextBlock Text="Commits per day hour" FontSize="16" Margin="10,10,0,0" FontWeight="Medium" />
          <oxy:PlotView Height="300" HorizontalAlignment="Stretch" DefaultTrackerTemplate="{DynamicResource TrackerControlDataTemplate}" xmlns:oxy="http://oxyplot.org/avalonia" x:Name="DayHourPlot" />
        </StackPanel>
      </Grid>
      <!-- Row 6: 代码行数统计（tokei）—— 标题行 + 模式切换 + 摘要 + 饼图 + 列表 -->
      <StackPanel Grid.Row="6" Margin="0,30,0,0" x:Name="CodeLinesSection">
        <Grid Margin="10,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Code lines" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="Ref:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <Grid Width="220" Margin="0,0,8,0">
              <Button HorizontalAlignment="Stretch" x:Name="CodeLinesRefButton" Click="CodeLinesRefButton_Click">
                <DockPanel LastChildFill="True">
                  <Path DockPanel.Dock="Right" Data="M9.041,1.657L5,5.698 0.959,1.657 1.638,0.98 5,4.342 8.362,0.98 9.041,1.657z" Fill="{DynamicResource ComboBox.Static.Glyph}" HorizontalAlignment="Center" Margin="6,0,4,0" VerticalAlignment="Center" />
                  <TextBlock x:Name="CodeLinesRefButtonText" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </DockPanel>
              </Button>
              <Popup StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade" x:Name="CodeLinesRefPopup" Opened="CodeLinesRefPopup_Opened" Closed="CodeLinesRefPopup_Closed">
                <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource BackgroundBrush}" BorderThickness="1" CornerRadius="6" Padding="2" MinWidth="220" MaxHeight="400">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <controls:PlaceholderTextBox Grid.Row="0" Margin="4,4,4,2" Style="{DynamicResource SearchPanelPlaceholderTextBox}" Placeholder="{DynamicResource Search}" controls:PlaceholderTextBox.Icon="{DynamicResource SearchOnIcon}" x:Name="CodeLinesRefSearchBox" TextChanged="CodeLinesRefSearchBox_TextChanged" />
                    <ListBox Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" HorizontalContentAlignment="Stretch" x:Name="CodeLinesRefListBox" SelectionChanged="CodeLinesRefListBox_SelectionChanged" />
                  </Grid>
                </Border>
              </Popup>
            </Grid>
            <Button Content="Refresh" Padding="10,2" x:Name="CodeLinesRefreshButton" Click="CodeLinesRefreshButton_Click" />
          </StackPanel>
        </Grid>
        <!-- 临时排除输入：每行一个 glob（语义同 .gitignore，如 tests/、**/*.Tests/、bin/）。
             不持久化，关闭窗口/换仓库即清空。点"重新统计"按当前输入重跑 tokei。 -->
        <Grid Margin="10,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Exclude:" VerticalAlignment="Center" Margin="0,0,6,0" />
          <controls:PlaceholderTextBox Grid.Column="1" x:Name="CodeLinesExcludeBox" AcceptsReturn="True" Height="50" VerticalContentAlignment="Top" TextWrapping="Wrap" Placeholder="One glob per line, e.g. tests/  **/*.Tests/  bin/" />
          <Button Grid.Column="2" Content="Recount with excludes" Padding="10,2" Margin="6,0,0,0" VerticalAlignment="Bottom" x:Name="CodeLinesRecountButton" Click="CodeLinesRecountButton_Click" />
        </Grid>
        <TextBlock Margin="10,8,0,0" x:Name="CodeLinesSummary" TextWrapping="Wrap" />
        <TextBlock Margin="10,8,0,0" x:Name="CodeLinesError" TextWrapping="Wrap" Foreground="#FFCC0000" Visibility="Collapsed" />
        <Grid Margin="10,10,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <oxy:PlotView Grid.Column="0" Height="350" Width="350" HorizontalAlignment="Left" VerticalAlignment="Top" DefaultTrackerTemplate="{DynamicResource TrackerControlDataTemplate}" xmlns:oxy="http://oxyplot.org/avalonia" x:Name="CodeLinesPiePlot" />
          <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="70" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="1" Text="Language" FontWeight="Medium" />
              <TextBlock Grid.Column="2" Text="Files" FontWeight="Medium" TextAlignment="Right" />
              <TextBlock Grid.Column="3" Text="Code" FontWeight="Medium" TextAlignment="Right" />
              <TextBlock Grid.Column="4" Text="Comments" FontWeight="Medium" TextAlignment="Right" />
              <TextBlock Grid.Column="5" Text="Blanks" FontWeight="Medium" TextAlignment="Right" />
            </Grid>
            <ListBox BorderThickness="1,1,1,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" HorizontalContentAlignment="Stretch" VerticalAlignment="Top" Style="{DynamicResource NoSelectionListBoxStyle}" x:Name="CodeLinesListBox">
              <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource NoSelectionListBoxItemStyle}">
                  <Setter Property="Panel.Background" Value="{DynamicResource BackgroundBrush}" />
                  <Setter Property="Border.BorderThickness" Value="0,0,0,1" />
                  <Setter Property="Border.BorderBrush" Value="{DynamicResource BorderBrush}" />
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid Height="20">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="10" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="80" />
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding Color}" />
                    <TextBlock Grid.Column="1" Margin="4,0,8,0" TextTrimming="CharacterEllipsis" Text="{Binding Name}" />
                    <TextBlock Grid.Column="2" Margin="4,0,0,0" TextAlignment="Right" Text="{Binding Files}" />
                    <TextBlock Grid.Column="3" Margin="4,0,0,0" TextAlignment="Right" Text="{Binding Code}" />
                    <TextBlock Grid.Column="4" Margin="4,0,0,0" TextAlignment="Right" Text="{Binding Comments}" />
                    <TextBlock Grid.Column="5" Margin="4,0,0,0" TextAlignment="Right" Text="{Binding Blanks}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Grid>
    <usercontrols:FallbackUserControl Margin="30,15,20,15" Height="600" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="FallbackUserControl" />
  </Grid>
</UserControl>