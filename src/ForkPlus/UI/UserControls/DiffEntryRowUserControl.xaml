<!-- 阶段 4.5：WPF→Avalonia XAML 迁移。
     - xmlns schemas.microsoft.com → https://github.com/avaloniaui
     - 移除 WPF 特有 SnapsToDevicePixels
     - TODO：ControlTemplate.Triggers/Trigger 是 WPF 特有语法，Avalonia 需用 Selector 重写，此处保留原样待后续迁移
     -->
<UserControl x:Class="ForkPlus.UI.UserControls.DiffEntryRowUserControl" xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border BorderBrush="#00FFFFFF" BorderThickness="1" Background="#00FFFFFF" Margin="4,0,4,0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <ToggleButton Grid.Row="0" Background="#00FFFFFF" BorderThickness="0" HorizontalContentAlignment="Stretch" MinHeight="0" MinWidth="0" Padding="0" Checked="HeaderToggleButton_CheckedChanged" Unchecked="HeaderToggleButton_CheckedChanged" x:Name="HeaderToggleButton">
        <ToggleButton.FocusVisualStyle>
          <x:Null />
        </ToggleButton.FocusVisualStyle>
        <ToggleButton.Template>
          <ControlTemplate TargetType="{x:Type ToggleButton}">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Cursor" Value="Hand" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </ToggleButton.Template>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="33" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Path Grid.Column="0" Data="M0,0L3.5,3.5 0,7" HorizontalAlignment="Right" Margin="25,1,0,0" Stroke="{DynamicResource Expander.Static.Arrow.Stroke}" StrokeThickness="1.5" VerticalAlignment="Center" x:Name="ArrowPath" />
          <Image Grid.Column="1" Height="14" Width="14" Margin="2,0,2,0" VerticalAlignment="Center" Source="{Binding ChangeTypeIcon}" />
          <Image Grid.Column="2" Height="14" Width="14" Margin="2,0,2,0" VerticalAlignment="Center" Source="{Binding FileTypeIcon}" />
          <TextBlock Grid.Column="3" Margin="11,0,0,0" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Text="{Binding FilePath}" ToolTip="{Binding ToolTip}" />
        </Grid>
      </ToggleButton>
      <Border Grid.Row="0" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Background="{DynamicResource BorderBrush}" Visibility="Collapsed" x:Name="SeparatorBorder" />
      <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1" MinHeight="180" MaxHeight="420" Visibility="Collapsed" x:Name="DiffContentHost" />
    </Grid>
  </Border>
</UserControl>
