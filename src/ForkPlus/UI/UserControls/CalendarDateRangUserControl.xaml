<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.CalendarDateRangUserControl">
  <StackPanel Orientation="Horizontal">
    <StackPanel.Children>
      <Calendar SelectionMode="SingleDate" SelectedDatesChanged="StartCalendar_SelectedDatesChanged" GotMouseCapture="Calendar_GotMouseCapture" x:Name="StartCalendar" />
      <Calendar SelectionMode="SingleDate" SelectedDatesChanged="EndCalendar_SelectedDatesChanged" GotMouseCapture="Calendar_GotMouseCapture" x:Name="EndCalendar" />
    </StackPanel.Children>
  </StackPanel>
</UserControl>