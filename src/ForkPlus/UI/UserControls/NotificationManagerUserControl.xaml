<UserControl xmlns:UserControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.NotificationManagerUserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls">
  <UserControl.Resources>
    <ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
      <BooleanToVisibilityConverter x:Key="BooleanToVisibility" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
    </ResourceDictionary>
  </UserControl.Resources>
  <Border Width="350" Height="460" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource ToolbarBackgroundBrush}" Margin="10,0,10,10" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Border.Effect>
      <DropShadowEffect BlurRadius="10" Color="DimGray" Opacity="0.4" ShadowDepth="2" />
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="26" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <TextBlock Text="Notifications" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource LabelBrush}" FontWeight="Medium" />
      <ProgressBar HorizontalAlignment="Right" Margin="0,0,5,0" Style="{DynamicResource CircularProgressBar}" Width="14" Height="14" Foreground="{DynamicResource ForegroundBrush.Gray}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="BusyIndicator" />
      <Button HorizontalAlignment="Right" Margin="0,0,5,0" IsTabStop="False" Style="{DynamicResource CodeEditorHeaderButtonStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="RefreshButton">
        <Image Source="{DynamicResource RefreshIcon}" />
      </Button>
      <ListBox Grid.Row="1" SelectionMode="Single" HorizontalContentAlignment="Stretch" BorderThickness="1" Margin="-1" ItemContainerStyle="{DynamicResource ListBoxItemWithBorderStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" SelectionChanged="ListBox_SelectionChanged" x:Name="ListBox">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Height="42" BorderThickness="0" RenderOptions.ClearTypeHint="Enabled" x:Name="CellBorder">
              <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="26" />
                  <ColumnDefinition />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition />
                  <RowDefinition />
                </Grid.RowDefinitions>
                <Ellipse Grid.Row="0" Grid.RowSpan="1" Margin="4,4,4,0" Width="6" Height="6" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}">
                  <Ellipse.Visibility>
                    <Binding Path="Unread" />
                  </Ellipse.Visibility>
                </Ellipse>
                <controls:AvatarImage Grid.Column="1" Width="16" Height="16" Margin="3,3,7,0" VerticalAlignment="Center">
                  <controls:AvatarImage.Url>
                    <Binding Path="RepositoryAvatarUrl" />
                  </controls:AvatarImage.Url>
                </controls:AvatarImage>
                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal">
                  <TextBlock FontSize="13" Margin="0,0,2,0" HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontWeight="Medium" x:Name="TitleTextBlock">
                    <TextBlock.Text>
                      <Binding Path="Title" />
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock FontSize="11" Margin="2,2,2,0" HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryLabelBrush}">
                    <TextBlock.Text>
                      <Binding Path="TargetId" />
                    </TextBlock.Text>
                  </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="3" Grid.Row="0" FontSize="11" Foreground="{DynamicResource SecondaryLabelBrush}" Margin="2,2,0,0" VerticalAlignment="Center" x:Name="FinishTimeTextBlock">
                  <TextBlock.Text>
                    <Binding Path="DateTime" />
                  </TextBlock.Text>
                </TextBlock>
                <Image Grid.Column="1" Grid.Row="1" Width="16" Height="16" Margin="3,3,7,0" VerticalAlignment="Center">
                  <Image.Source>
                    <Binding Path="TargetTypeIcon" />
                  </Image.Source>
                </Image>
                <TextBlock Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,2,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis" x:Name="DescriptionTextBlock">
                  <TextBlock.Text>
                    <Binding Path="Description" />
                  </TextBlock.Text>
                </TextBlock>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Border>
</UserControl>