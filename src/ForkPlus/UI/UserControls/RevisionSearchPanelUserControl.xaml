<!-- Migrated from WPF to Avalonia: root xmlns updated to https://github.com/avaloniaui; redundant child xmlns declarations removed; Border.Child/DockPanel.Children/Grid.Children property elements expanded into direct content; PlaceholderTextBox converted to controls: prefix. -->
<UserControl xmlns="https://github.com/avaloniaui" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:fuu="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.RevisionSearchPanelUserControl" xmlns:fuc="clr-namespace:ForkPlus.UI.Controls">
  <Border Padding="6,4,4,4">
    <Border.Background>
      <DynamicResource ResourceKey="ToolbarBackgroundBrush" />
    </Border.Background>
    <Border.VerticalAlignment>Top</Border.VerticalAlignment>
    <Border.RenderTransform>
      <TranslateTransform x:Name="TranslateTransform" />
    </Border.RenderTransform>
    <DockPanel>
      <Button DockPanel.Dock="Right" Margin="0,0,2,0" Click="CloseSearchContainerButton_Click">
        <Button.Style>
          <DynamicResource ResourceKey="IconButtonStyle" />
        </Button.Style>
        <Button.Padding>0</Button.Padding>
        <Button.BorderThickness>0</Button.BorderThickness>
        <Image>
          <Image.Source>
            <DynamicResource ResourceKey="CancelSearchIcon" />
          </Image.Source>
          <Image.Width>16</Image.Width>
          <Image.Height>16</Image.Height>
          <Image.VerticalAlignment>Center</Image.VerticalAlignment>
        </Image>
      </Button>
      <Button DockPanel.Dock="Right" Margin="0,0,2,0" Click="JumpToNextSearchResultButton_Click">
        <Button.Style>
          <DynamicResource ResourceKey="IconButtonStyle" />
        </Button.Style>
        <Button.Padding>0</Button.Padding>
        <Button.BorderThickness>0</Button.BorderThickness>
        <Image>
          <Image.Source>
            <DynamicResource ResourceKey="NextIcon" />
          </Image.Source>
          <Image.Width>16</Image.Width>
          <Image.Height>16</Image.Height>
          <Image.VerticalAlignment>Center</Image.VerticalAlignment>
        </Image>
      </Button>
      <Button DockPanel.Dock="Right" Margin="2,0,2,0" Click="JumpToPreviousSearchResultButton_Click">
        <Button.Style>
          <DynamicResource ResourceKey="IconButtonStyle" />
        </Button.Style>
        <Button.Padding>0</Button.Padding>
        <Button.BorderThickness>0</Button.BorderThickness>
        <Image>
          <Image.Source>
            <DynamicResource ResourceKey="PrevIcon" />
          </Image.Source>
          <Image.Width>16</Image.Width>
          <Image.Height>16</Image.Height>
          <Image.VerticalAlignment>Center</Image.VerticalAlignment>
        </Image>
      </Button>
      <Grid>
        <controls:PlaceholderTextBox TextChanged="SearchTextBox_TextChanged" HorizontalAlignment="Stretch" Placeholder="Search SHA, branch, author or message" x:Name="SearchTextBox">
          <controls:PlaceholderTextBox.Style>
            <DynamicResource ResourceKey="SearchPanelPlaceholderTextBox" />
          </controls:PlaceholderTextBox.Style>
          <controls:PlaceholderTextBox.Icon>
            <DynamicResource ResourceKey="SearchIcon" />
          </controls:PlaceholderTextBox.Icon>
        </controls:PlaceholderTextBox>
        <DockPanel HorizontalAlignment="Right" Margin="0,0,4,0">
          <ProgressBar DockPanel.Dock="Left" x:Name="BusyIndicator">
            <ProgressBar.Style>
              <DynamicResource ResourceKey="CircularProgressBar" />
            </ProgressBar.Style>
            <ProgressBar.Visibility>Collapsed</ProgressBar.Visibility>
            <ProgressBar.Width>12</ProgressBar.Width>
            <ProgressBar.Height>12</ProgressBar.Height>
            <ProgressBar.Foreground>
              <DynamicResource ResourceKey="ForegroundBrush.Gray" />
            </ProgressBar.Foreground>
            <ProgressBar.Margin>0,0,4,0</ProgressBar.Margin>
          </ProgressBar>
          <TextBlock DockPanel.Dock="Right" VerticalAlignment="Bottom" Margin="0,0,4,3" x:Name="MatchesTextBlock" />
        </DockPanel>
      </Grid>
    </DockPanel>
  </Border>
</UserControl>
