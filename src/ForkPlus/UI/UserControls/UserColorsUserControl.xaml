<UserControl xmlns:UserControls="clr-namespace:ForkPlus.UI.UserControls" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="ForkPlus.UI.UserControls.UserColorsUserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <Border Style="{DynamicResource MenuShadowBorderStyle}" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource BackgroundBrush}" CornerRadius="6">
      <ItemsControl Margin="4" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="Colors">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Rows="4" Columns="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="1">
              <ToggleButton Style="{DynamicResource UserColorToggleButton}" Checked="ColorButton_Changed" Unchecked="ColorButton_Changed" x:Name="UserColorRadioButton">
                <ToggleButton.Background>
                  <Binding Path="Brush" />
                </ToggleButton.Background>
                <ToggleButton.IsChecked>
                  <Binding Path="IsSelected" />
                </ToggleButton.IsChecked>
              </ToggleButton>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>
  </Border>
</UserControl>