                    <Canvas HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0" x:Name="Canvas">
                      <Rectangle x:Name="OpaqueRect">
                        <Rectangle.Fill>
                          <Binding Path="Background" />
                        </Rectangle.Fill>
                        <Rectangle.Height>
                          <Binding Path="ActualHeight" />
                        </Rectangle.Height>
                        <Rectangle.Width>
                          <Binding Path="ActualWidth" />
                        </Rectangle.Width>
                      </Rectangle>
                    </Canvas>
                    <Rectangle Fill="{TemplateBinding Panel.Background}" HorizontalAlignment="Left" Margin="29,2,0,2" Width="1" x:Name="Rectangle" />
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="True" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle" x:Name="ItemsPresenter" />
