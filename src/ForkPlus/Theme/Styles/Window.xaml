<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:ForkPlus.UI.Controls" xmlns:ui="clr-namespace:ForkPlus.UI" xmlns:dialogs="clr-namespace:ForkPlus.UI.Dialogs" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <BooleanToVisibilityConverter x:Key="BooleanToVisibility" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
  <controls:ResizeModeToVisibilityConverter x:Key="ResizeModeToVisibilityConverter" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
  <Geometry x:Key="MinimizeGeometry" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">M0,0 L10,0 10,1.0 10,1.0 1,1.0 0,1.0 z</Geometry>
  <Geometry x:Key="MaximizeGeometry" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">M1,1 L1,11 11,11 11,1 z M0,0 L12,0 12,12 0,12 z</Geometry>
  <Geometry x:Key="RestoreGeometry" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">M1,4.56 L1,14.56 11,14.56 11,4.56z M4.0,1 L4.0,3.56 12,3.56 12,11 14.0,11 14.0,1 z M3.0,0 L15.0,0 15.0,12 12,12 12,15.56 0,15.56 0,3.56 3.0,3.56 z</Geometry>
  <Geometry x:Key="CloseGeometry" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">M0.71,0 L4.6,3.8 8.5,0 9.2,0.71 5.3,4.6 9.2,8.48 8.48,9.2 4.6,5.3 0.71,9.2 0,8.48 3.89,4.6 4.77E-07,0.71 z</Geometry>
  <Style x:Key="WindowPathStyle" TargetType="{x:Type Path}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="10" />
    <Setter Property="FrameworkElement.Width" Value="10" />
    <Setter Property="FrameworkElement.Margin" Value="0" />
    <Setter Property="Shape.Stretch" Value="Uniform" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Shape.Fill" Value="{DynamicResource Window.Button.Static.Foreground}" />
    <Style.Triggers>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Value="true">
            <Condition.Binding>
              <Binding Path="IsMouseOver">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type Button}" />
                </Binding.RelativeSource>
              </Binding>
            </Condition.Binding>
          </Condition>
          <Condition Value="false">
            <Condition.Binding>
              <Binding Path="IsPressed">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type Button}" />
                </Binding.RelativeSource>
              </Binding>
            </Condition.Binding>
          </Condition>
        </MultiDataTrigger.Conditions>
        <Setter Property="Shape.Fill" Value="{DynamicResource Window.Button.MouseOver.Foreground}" />
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="WindowCloseButtonPathStyle" TargetType="{x:Type Path}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="10" />
    <Setter Property="FrameworkElement.Width" Value="10" />
    <Setter Property="FrameworkElement.Margin" Value="0" />
    <Setter Property="Shape.Stretch" Value="Uniform" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Shape.Fill" Value="{DynamicResource Window.Button.Static.Foreground}" />
    <Style.Triggers>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Value="true">
            <Condition.Binding>
              <Binding Path="IsMouseOver">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type Button}" />
                </Binding.RelativeSource>
              </Binding>
            </Condition.Binding>
          </Condition>
          <Condition Value="false">
            <Condition.Binding>
              <Binding Path="IsPressed">
                <Binding.RelativeSource>
                  <RelativeSource Mode="FindAncestor" AncestorType="{x:Type Button}" />
                </Binding.RelativeSource>
              </Binding>
            </Condition.Binding>
          </Condition>
        </MultiDataTrigger.Conditions>
        <Setter Property="Shape.Fill" Value="#FFFFFFFF" />
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="WindowButton" TargetType="{x:Type Button}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="26" />
    <Setter Property="FrameworkElement.Width" Value="46" />
    <Setter Property="Panel.Background" Value="{DynamicResource Window.Button.Static.Background}" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="UIElement.Focusable" Value="False" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Background="{TemplateBinding Panel.Background}" x:Name="border">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.MouseOver.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.Pressed.Background}" Property="Panel.Background" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="WindowRoundedButton" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowButton}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Margin" Value="0,2,6,0" />
    <Setter Property="FrameworkElement.Height" Value="24" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Background="{TemplateBinding Panel.Background}" CornerRadius="3" x:Name="border">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.MouseOver.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.Pressed.Background}" Property="Panel.Background" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="WindowToggleButton" TargetType="{x:Type ToggleButton}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="26" />
    <Setter Property="FrameworkElement.Width" Value="30" />
    <Setter Property="Panel.Background" Value="{DynamicResource Window.Button.Static.Background}" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="UIElement.Focusable" Value="False" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToggleButton}">
          <Border Background="{TemplateBinding Panel.Background}" x:Name="border">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.MouseOver.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.Pressed.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="border" Property="UIElement.Opacity" Value="0.4" />
              <Setter TargetName="border" Property="Panel.Background" Value="#00FFFFFF" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="WindowRoundedToggleButton" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource WindowToggleButton}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Margin" Value="0,2,6,0" />
    <Setter Property="FrameworkElement.Height" Value="24" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToggleButton}">
          <Border Background="{TemplateBinding Panel.Background}" CornerRadius="3" x:Name="border">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.MouseOver.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.Button.Pressed.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="border" Property="UIElement.Opacity" Value="0.4" />
              <Setter TargetName="border" Property="Panel.Background" Value="#00FFFFFF" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="WindowCloseButton" TargetType="{x:Type Button}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="26" />
    <Setter Property="FrameworkElement.Width" Value="46" />
    <Setter Property="Panel.Background" Value="{DynamicResource Window.CloseButton.Static.Background}" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="UIElement.Focusable" Value="False" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Background="{TemplateBinding Panel.Background}" x:Name="border">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.CloseButton.MouseOver.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Window.CloseButton.Pressed.Background}" Property="Panel.Background" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type ui:CustomWindow}" TargetType="{x:Type ui:CustomWindow}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Panel.Background" Value="{DynamicResource Window.BackgroundBrush}" />
    <Setter Property="Border.BorderBrush" Value="{DynamicResource WindowBorderBrush}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource Window.Foreground}" />
    <Setter Property="Border.BorderThickness" Value="1" />
    <Setter Property="TextElement.FontSize" Value="12" />
    <Setter Property="FrameworkElement.Margin" Value="0" />
    <Setter Property="Control.Padding" Value="0" />
    <Setter Property="FrameworkElement.MinWidth" Value="240" />
    <Setter Property="FrameworkElement.MinHeight" Value="80" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ui:CustomWindow}">
          <Border BorderThickness="{TemplateBinding ui:CustomWindow.WindowResizeBorderThickness}">
            <Border SnapsToDevicePixels="True" BorderThickness="{TemplateBinding Border.BorderThickness}" BorderBrush="{TemplateBinding Border.BorderBrush}" Background="{TemplateBinding Panel.Background}">
              <Grid LayoutTransform="{DynamicResource LayoutScaleTransform}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource Window.TitleBar.Background}" BorderThickness="0" Padding="0" x:Name="PART_WindowHeader">
                  <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                      <Button Command="SystemCommands.MinimizeWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_MinimizeButton">
                        <Path Data="{StaticResource MinimizeGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.RestoreWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_RestoreButton">
                        <Path Data="{StaticResource RestoreGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.MaximizeWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_MaximizeButton">
                        <Path Data="{StaticResource MaximizeGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.CloseWindowCommand" Style="{DynamicResource WindowCloseButton}" x:Name="PART_CloseButton">
                        <Path Data="{StaticResource CloseGeometry}" Style="{DynamicResource WindowCloseButtonPathStyle}" />
                      </Button>
                    </StackPanel>
                    <Border Background="{DynamicResource Window.TitleBar.Background}">
                      <StackPanel Orientation="Horizontal">
                        <Image Source="{TemplateBinding Window.Icon}" />
                        <Label Content="{TemplateBinding Window.Title}" Foreground="{TemplateBinding TextElement.Foreground}">
                          <Label.Visibility>
                            <Binding Path="IsTitleVisible" RelativeSource="{RelativeSource TemplatedParent}" Converter="{StaticResource BooleanToVisibility}" />
                          </Label.Visibility>
                        </Label>
                      </StackPanel>
                    </Border>
                  </DockPanel>
                </Border>
                <AdornerDecorator Grid.Row="1">
                  <ContentPresenter ClipToBounds="True" />
                </AdornerDecorator>
                <ResizeGrip Grid.Row="1" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" IsTabStop="False" Visibility="Collapsed" WindowChrome.ResizeGripDirection="BottomRight" x:Name="ResizeGrip" />
              </Grid>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Window.ResizeMode" Value="CanResizeWithGrip" />
                <Condition Property="Window.WindowState" Value="Normal" />
              </MultiTrigger.Conditions>
              <Setter TargetName="ResizeGrip" Property="UIElement.Visibility" Value="Visible" />
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="ForkPlusDialogWindowStyle" TargetType="{x:Type dialogs:ForkPlusDialogWindow}" BasedOn="{StaticResource {x:Type ui:CustomWindow}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="ui:CustomWindow.HideMinimizeMaximizeButtons" Value="True" />
    <Setter Property="Panel.Background" Value="{DynamicResource Window.Dialog.Background}" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ui:CustomWindow}">
          <Border BorderThickness="{TemplateBinding ui:CustomWindow.WindowResizeBorderThickness}">
            <Border SnapsToDevicePixels="True" BorderThickness="{TemplateBinding Border.BorderThickness}" BorderBrush="{TemplateBinding Border.BorderBrush}" Background="{TemplateBinding Panel.Background}">
              <Grid LayoutTransform="{DynamicResource LayoutScaleTransform}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource Window.Dialog.Background}" BorderThickness="0" Padding="0" x:Name="PART_WindowHeader">
                  <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                      <Button Command="SystemCommands.MinimizeWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_MinimizeButton">
                        <Path Data="{StaticResource MinimizeGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.RestoreWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_RestoreButton">
                        <Path Data="{StaticResource RestoreGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.MaximizeWindowCommand" Style="{DynamicResource WindowButton}" x:Name="PART_MaximizeButton">
                        <Path Data="{StaticResource MaximizeGeometry}" Style="{DynamicResource WindowPathStyle}" />
                      </Button>
                      <Button Command="SystemCommands.CloseWindowCommand" Style="{DynamicResource WindowCloseButton}" x:Name="PART_CloseButton">
                        <Path Data="{StaticResource CloseGeometry}" Style="{DynamicResource WindowCloseButtonPathStyle}" />
                      </Button>
                    </StackPanel>
                    <Border>
                      <StackPanel Orientation="Horizontal">
                        <Image Source="{TemplateBinding Window.Icon}" />
                        <Label Content="{TemplateBinding Window.Title}" Foreground="{TemplateBinding TextElement.Foreground}">
                          <Label.Visibility>
                            <Binding Path="IsTitleVisible" RelativeSource="{RelativeSource TemplatedParent}" Converter="{StaticResource BooleanToVisibility}" />
                          </Label.Visibility>
                        </Label>
                      </StackPanel>
                    </Border>
                  </DockPanel>
                </Border>
                <AdornerDecorator Grid.Row="1">
                  <ContentPresenter ClipToBounds="True" />
                </AdornerDecorator>
                <ResizeGrip Grid.Row="1" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" IsTabStop="False" Visibility="Collapsed" WindowChrome.ResizeGripDirection="BottomRight" x:Name="ResizeGrip" />
              </Grid>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Window.ResizeMode" Value="CanResizeWithGrip" />
                <Condition Property="Window.WindowState" Value="Normal" />
              </MultiTrigger.Conditions>
              <Setter TargetName="ResizeGrip" Property="UIElement.Visibility" Value="Visible" />
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>