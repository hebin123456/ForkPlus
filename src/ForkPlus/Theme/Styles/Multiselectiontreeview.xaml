  <Style x:Key="SideBarIssuesTreeViewControlItemStyle" TargetType="{x:Type controls:TreeViewControlItem}" BasedOn="{StaticResource ExpandButtonAutoWidthTreeViewControlItemStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="50" />
    <Setter Property="Control.Padding" Value="0" />
    <Setter Property="FrameworkElement.Margin" Value="0" />
    <Setter Property="FrameworkElement.Height" Value="Auto" />
    <Setter Property="Border.BorderThickness" Value="0,0,0,1" />
    <Setter Property="Panel.Background" Value="{DynamicResource Sidebar.Static.Background}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
  </Style>
  <Style x:Key="SideBarIssuesMultiselectionTreeViewStyle" TargetType="{x:Type controls:MultiselectionTreeView}" BasedOn="{StaticResource FileHistoryMultiselectionTreeViewStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Panel.Background" Value="{DynamicResource Sidebar.Static.Background}" />
    <Setter Property="FrameworkElement.Margin" Value="0" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="ItemsControl.ItemContainerStyle" Value="{DynamicResource SideBarIssuesTreeViewControlItemStyle}" />
  </Style>
  <Style x:Key="SideBarTreeViewControlItemStyle" TargetType="{x:Type controls:TreeViewControlItem}" BasedOn="{StaticResource TreeViewControlItemStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="22" />
    <Setter Property="TextElement.FontSize" Value="13" />
    <Setter Property="Panel.Background" Value="{DynamicResource Sidebar.Static.Background}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
  </Style>
  <Style x:Key="SideBarMultiselectionTreeViewStyle" TargetType="{x:Type controls:MultiselectionTreeView}" BasedOn="{StaticResource {x:Type controls:MultiselectionTreeView}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Panel.Background" Value="{DynamicResource Sidebar.Static.Background}" />
    <Setter Property="ItemsControl.ItemContainerStyle" Value="{DynamicResource SideBarTreeViewControlItemStyle}" />
  </Style>
