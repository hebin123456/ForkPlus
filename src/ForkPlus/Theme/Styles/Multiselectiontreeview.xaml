  <Style x:Key="SideBarSearchMultiselectionTreeViewStyle" TargetType="{x:Type controls:MultiselectionTreeView}" BasedOn="{StaticResource FileHistoryMultiselectionTreeViewStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
