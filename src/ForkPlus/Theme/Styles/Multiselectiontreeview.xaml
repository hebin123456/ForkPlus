      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="FileListMultiselectionTreeViewWithGridViewStyle" TargetType="{x:Type controls:MultiselectionTreeView}" BasedOn="{StaticResource {x:Type controls:MultiselectionTreeView}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
