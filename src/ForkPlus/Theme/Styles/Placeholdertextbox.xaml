  <Style x:Key="{x:Type controls:FilterTextBox}" TargetType="{x:Type controls:FilterTextBox}" BasedOn="{StaticResource {x:Type controls:PlaceholderTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Top" />
    <Setter Property="controls:PlaceholderTextBox.Placeholder" Value="Filter" />
    <Setter Property="FrameworkElement.MinHeight" Value="22" />
    <Setter Property="FrameworkElement.Height" Value="22" />
    <Setter Property="Control.Padding" Value="2,1,2,1" />
    <Setter Property="Border.BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:FilterTextBox}">
          <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" SnapsToDevicePixels="True" CornerRadius="{TemplateBinding Border.CornerRadius}" x:Name="Border">
            <Border.RenderTransform>
              <TranslateTransform x:Name="PART_TranslateTransform" />
            </Border.RenderTransform>
            <Grid Background="#00FFFFFF">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Image Source="{DynamicResource SearchOnIcon}" Width="13" Height="13" Margin="4,0,0,0" x:Name="PART_Icon" />
              <controls:DropDownButton HorizontalAlignment="Left" Height="20" Margin="0" Visibility="Collapsed" Background="#00FFFFFF" BorderThickness="0" Focusable="False" x:Name="PART_DropDownButton">
                <controls:DropDownButton.FocusVisualStyle>
                  <x:Null />
                </controls:DropDownButton.FocusVisualStyle>
                <controls:DropDownButton.ContextMenu>
                  <ContextMenu />
                </controls:DropDownButton.ContextMenu>
                <StackPanel Orientation="Horizontal" Background="#00FFFFFF">
                  <Image Height="13" Width="13" Margin="4,0,0,0" Source="{DynamicResource SearchOnIcon}" x:Name="DropdownButtonImage" />
                  <Path Margin="2,2,2,2" HorizontalAlignment="Center" VerticalAlignment="Center" Data="{DynamicResource ArrowGeometry}" Fill="{DynamicResource AccentBrush}" x:Name="DropdownButtonPath" />
                </StackPanel>
              </controls:DropDownButton>
              <ScrollViewer Grid.Column="1" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#00FFFFFF" x:Name="PART_ContentHost" />
              <TextBlock Grid.Column="1" Padding="{TemplateBinding Control.Padding}" Visibility="Collapsed" IsHitTestVisible="False" FontSize="{TemplateBinding TextElement.FontSize}" Margin="1,0,0,0" Foreground="{TemplateBinding TextElement.Foreground}" Opacity="0.56" Text="{TemplateBinding controls:PlaceholderTextBox.Placeholder}" x:Name="placeholderElement" />
              <TextBlock Grid.Column="2" Text="?" Margin="4,-2,4,0" VerticalAlignment="Center" FontWeight="Medium" Foreground="{DynamicResource AccentBrush}" ToolTipService.ShowDuration="15000" x:Name="HintTextBlock">
                <TextBlock.ToolTip>
                  <Binding Path="Hint"><Binding.RelativeSource><RelativeSource Mode="FindAncestor" AncestorType="{x:Type controls:FilterTextBox}" /></Binding.RelativeSource></Binding>
                </TextBlock.ToolTip>
              </TextBlock>
              <Button Grid.Column="3" Margin="0,0,2,0" Height="16" Width="16" Padding="0" BorderThickness="0" Background="#00FFFFFF" Style="{DynamicResource InlineButton}" x:Name="PART_ClearButton">
                <Image Source="{DynamicResource CancelSearchIcon}" Width="14" Height="14" VerticalAlignment="Center" />
              </Button>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="controls:FilterTextBox.Hint">
              <Trigger.Value>
                <x:Null />
              </Trigger.Value>
              <Setter TargetName="HintTextBlock" Property="UIElement.Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="TextBox.Text" Value="">
              <Setter TargetName="placeholderElement" Property="UIElement.Visibility" Value="Visible" />
              <Setter TargetName="PART_ClearButton" Property="UIElement.Visibility" Value="Collapsed" />
              <Setter TargetName="PART_Icon" Value="{DynamicResource SearchIcon}" Property="Image.Source" />
              <Setter TargetName="DropdownButtonImage" Value="{DynamicResource SearchIcon}" Property="Image.Source" />
              <Setter TargetName="DropdownButtonPath" Value="{DynamicResource ComboBox.Static.Glyph}" Property="Shape.Fill" />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="False">
              <Setter TargetName="Border" Property="UIElement.Opacity" Value="0.56" />
            </Trigger>
            <Trigger Property="UIElement.IsKeyboardFocused" Value="True">
              <Setter TargetName="Border" Value="{DynamicResource TextBox.Static.Background}" Property="Panel.Background" />
              <Setter TargetName="Border" Value="{DynamicResource BorderBrush}" Property="Border.BorderBrush" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>