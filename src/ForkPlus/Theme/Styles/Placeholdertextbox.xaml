  <Style x:Key="CommitPlaceholderTextBox" TargetType="{x:Type controls:PlaceholderTextBox}" BasedOn="{StaticResource {x:Type controls:PlaceholderTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="TextElement.FontWeight" Value="Medium" />
    <Setter Property="TextElement.FontSize" Value="14" />
    <Setter Property="Border.CornerRadius" Value="3,3,0,0" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:PlaceholderTextBox}">
          <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" SnapsToDevicePixels="True" CornerRadius="{TemplateBinding Border.CornerRadius}" x:Name="Border">
            <Grid Background="#00FFFFFF">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Image Source="{TemplateBinding controls:PlaceholderTextBox.Icon}" MaxHeight="15" Margin="2,0,-1,0" x:Name="iconElement" />
              <ScrollViewer Grid.Column="1" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#00FFFFFF" x:Name="PART_ContentHost" />
              <TextBlock Grid.Column="1" Padding="{TemplateBinding Control.Padding}" Visibility="Collapsed" IsHitTestVisible="False" FontSize="13" Margin="2,1,0,0" FontWeight="Normal" Foreground="{TemplateBinding TextElement.Foreground}" Opacity="0.56" Text="{TemplateBinding controls:PlaceholderTextBox.Placeholder}" x:Name="placeholderElement" />
              <Popup AllowsTransparency="True" Focusable="False" VerticalOffset="-3" HorizontalOffset="-8" x:Name="Popup" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="TextBox.Text" Value="">
              <Setter TargetName="placeholderElement" Property="UIElement.Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="controls:PlaceholderTextBox.Icon">
              <Trigger.Value>
                <x:Null />
              </Trigger.Value>
              <Setter TargetName="iconElement" Property="UIElement.Visibility" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type controls:CommitDescriptionTextBox}" TargetType="{x:Type controls:CommitDescriptionTextBox}" BasedOn="{StaticResource {x:Type controls:PlaceholderTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="TextElement.FontFamily" Value="Consolas" />
    <Setter Property="TextElement.FontSize" Value="13" />
    <Setter Property="Control.Padding" Value="4,4,4,2" />
    <Setter Property="Border.CornerRadius" Value="0,0,3,3" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:CommitDescriptionTextBox}">
          <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" SnapsToDevicePixels="True" CornerRadius="{TemplateBinding Border.CornerRadius}" x:Name="Border">
            <Grid Background="#00FFFFFF">
              <ScrollViewer Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#00FFFFFF" x:Name="PART_ContentHost" />
              <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Width="1" Margin="{TemplateBinding controls:CommitDescriptionTextBox.GuideLineMargin}" Visibility="Visible" HorizontalAlignment="Left" x:Name="PART_GuideLine" />
              <TextBlock Margin="2,0,0,0" Padding="{TemplateBinding Control.Padding}" Visibility="Collapsed" IsHitTestVisible="False" FontSize="{TemplateBinding TextElement.FontSize}" FontFamily="Segoe UI" Foreground="{TemplateBinding TextElement.Foreground}" Opacity="0.56" Text="{TemplateBinding controls:PlaceholderTextBox.Placeholder}" x:Name="placeholderElement" />
              <Popup AllowsTransparency="True" Focusable="False" VerticalOffset="-3" HorizontalOffset="-8" x:Name="Popup" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="TextBox.Text" Value="">
              <Setter TargetName="placeholderElement" Property="UIElement.Visibility" Value="Visible" />
              <Setter TargetName="placeholderElement" Property="TextBlock.Padding" Value="4,2,4,3" />
              <Setter TargetName="PART_GuideLine" Property="UIElement.Visibility" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type controls:ReferenceTextBox}" TargetType="{x:Type controls:ReferenceTextBox}" BasedOn="{StaticResource {x:Type controls:AutoCompleteTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
  <Style x:Key="{x:Type controls:SpellingPlaceholderTextBox}" TargetType="{x:Type controls:SpellingPlaceholderTextBox}" BasedOn="{StaticResource {x:Type controls:AutoCompleteTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
  <Style x:Key="SearchPanelPlaceholderTextBox" TargetType="{x:Type controls:PlaceholderTextBox}" BasedOn="{StaticResource {x:Type controls:PlaceholderTextBox}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="22" />
    <Setter Property="FrameworkElement.MinHeight" Value="22" />
    <Setter Property="Control.Padding" Value="2,1,2,1" />
    <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True" />
