<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="SettingsHeaderTextBlockStyle" TargetType="{x:Type TextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="TextElement.FontSize" Value="14" />
    <Setter Property="TextElement.FontWeight" Value="Medium" />
    <Setter Property="FrameworkElement.Margin" Value="0,12,0,6" />
  </Style>
  <Style x:Key="ReferenceLabelTextBlockStyle" TargetType="{x:Type TextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceForeground}" />
    <Setter Property="TextElement.FontWeight" Value="Normal" />
    <Setter Property="FrameworkElement.Margin" Value="2,-1,2,1" />
  </Style>
  <Style x:Key="ToolbarButtonTitle" TargetType="{x:Type TextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center" />
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Top" />
    <Setter Property="TextElement.FontSize" Value="11" />
    <Setter Property="FrameworkElement.Margin" Value="4,-3,4,2" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ToolbarForeground}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
  </Style>
  <Style x:Key="LfsLabel" TargetType="{x:Type Label}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="16" />
    <Setter Property="FrameworkElement.Width" Value="28" />
    <Setter Property="UIElement.Focusable" Value="False" />
    <Setter Property="FrameworkElement.HorizontalAlignment" Value="Left" />
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Center" />
    <Setter Property="Panel.Background" Value="{DynamicResource AccentSecondaryBrush}" />
    <Setter Property="TextElement.FontSize" Value="11" />
    <Setter Property="TextElement.Foreground" Value="#FFFFFFFF" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Label}">
          <Border Width="{TemplateBinding FrameworkElement.Width}" Background="{TemplateBinding Panel.Background}" CornerRadius="4">
            <TextBlock Margin="0,0,0,1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="LFS" FontSize="{TemplateBinding TextElement.FontSize}" Foreground="{TemplateBinding TextElement.Foreground}" x:Name="ContentTextBlock" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="NotLfsLabel" TargetType="{x:Type Label}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.Height" Value="16" />
    <Setter Property="FrameworkElement.Width" Value="42" />
    <Setter Property="UIElement.Focusable" Value="False" />
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Center" />
    <Setter Property="Panel.Background" Value="#FFFF6663" />
    <Setter Property="TextElement.FontSize" Value="11" />
    <Setter Property="TextElement.Foreground" Value="#FFFFFFFF" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Label}">
          <Border Width="{TemplateBinding FrameworkElement.Width}" Background="{TemplateBinding Panel.Background}" CornerRadius="4">
            <TextBlock Margin="0,0,0,1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="not LFS" FontSize="{TemplateBinding TextElement.FontSize}" Foreground="{TemplateBinding TextElement.Foreground}" x:Name="ContentTextBlock" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="BugtrackerHyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource {x:Type Hyperlink}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkContentElement.FocusVisualStyle">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
    <Setter Property="Inline.TextDecorations">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="ContentElement.IsMouseOver" Value="True">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
        <Setter Property="Inline.TextDecorations" Value="Underline" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="BlueHyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource {x:Type Hyperlink}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkContentElement.FocusVisualStyle">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
    <Style.Triggers>
      <Trigger Property="ContentElement.IsMouseOver" Value="True">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="BlueUnderlineHyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource {x:Type Hyperlink}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkContentElement.FocusVisualStyle">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
    <Setter Property="Inline.TextDecorations">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="ContentElement.IsMouseOver" Value="True">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
        <Setter Property="Inline.TextDecorations" Value="Underline" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="GrayHyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource {x:Type Hyperlink}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkContentElement.FocusVisualStyle">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ForegroundBrush.Gray}" />
    <Style.Triggers>
      <Trigger Property="ContentElement.IsMouseOver" Value="True">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="GrayUnderlineHyperlinkStyle" TargetType="{x:Type Hyperlink}" BasedOn="{StaticResource GrayHyperlinkStyle}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Inline.TextDecorations">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="ContentElement.IsMouseOver" Value="True">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ReferenceBrush}" />
        <Setter Property="Inline.TextDecorations" Value="Underline" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="HintTextBlock" TargetType="{x:Type TextBlock}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="TextBlock.Text" Value="?" />
    <Setter Property="FrameworkElement.Margin" Value="4,2,6,2" />
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Center" />
    <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
    <Setter Property="TextElement.FontWeight" Value="Medium" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FrameworkElement.ToolTip">
      <Setter.Value>
        <ToolTip>
          <ToolTip.DataContext>
            <Binding Path="PlacementTarget" RelativeSource="{x:Static RelativeSource.Self}" />
          </ToolTip.DataContext>
          <StackPanel>
            <TextBlock>
              <TextBlock.Text>
                <Binding Path="Tag" />
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </ToolTip>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>