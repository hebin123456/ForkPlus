          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="ToggleButton.IsChecked" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Sidebar.SelectionActive.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ToggleButton.IsChecked" Value="false">
              <Setter TargetName="border" Value="{DynamicResource Sidebar.Static.Background}" Property="Panel.Background" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="border" Value="{DynamicResource Sidebar.Static.Background}" Property="Panel.Background" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
