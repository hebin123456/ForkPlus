    </Setter>
  </Style>
  <Style x:Key="RepositoryManagerTabControl" TargetType="{x:Type controls:ModernTabControl}" BasedOn="{StaticResource {x:Type controls:ModernTabControl}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style.Resources>
      <ResourceDictionary>
        <Style x:Key="{x:Type TabPanel}" TargetType="{x:Type TabPanel}">
          <Setter Property="Panel.Background" Value="#00FFFFFF" />
        </Style>
        <Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}" BasedOn="{StaticResource ModernTabControlTabItemStyle}">
