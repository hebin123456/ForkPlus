  <Style x:Key="{x:Type TabControl}" TargetType="{x:Type TabControl}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style.Resources>
      <ResourceDictionary>
        <Style x:Key="{x:Type TabPanel}" TargetType="{x:Type TabPanel}">
          <Setter Property="Panel.Background" Value="{DynamicResource TabItem.Static.Background}" />
        </Style>
        <Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}" BasedOn="{StaticResource {x:Type TabItem}}" />
      </ResourceDictionary>
    </Style.Resources>
    <Setter Property="Control.Padding" Value="2" />
    <Setter Property="Control.HorizontalContentAlignment" Value="Center" />
    <Setter Property="Control.VerticalContentAlignment" Value="Center" />
    <Setter Property="Panel.Background" Value="{DynamicResource TabItem.Static.Background}" />
    <Setter Property="Border.BorderBrush" Value="{DynamicResource TabItem.Static.Border}" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ForegroundBrush}" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabControl}">
          <Grid ClipToBounds="true" SnapsToDevicePixels="true" KeyboardNavigation.TabNavigation="Local" x:Name="templateRoot">
            <Grid.ColumnDefinitions>
              <ColumnDefinition x:Name="ColumnDefinition0" />
              <ColumnDefinition Width="0" x:Name="ColumnDefinition1" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" x:Name="RowDefinition0" />
              <RowDefinition Height="*" x:Name="RowDefinition1" />
            </Grid.RowDefinitions>
            <TabPanel Grid.Column="0" IsItemsHost="true" Margin="0" Grid.Row="0" KeyboardNavigation.TabIndex="1" Panel.ZIndex="1" x:Name="headerPanel" />
            <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" Grid.Column="0" KeyboardNavigation.DirectionalNavigation="Contained" Grid.Row="1" KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local" x:Name="contentPanel">
              <ContentPresenter ContentSource="SelectedContent" Margin="{TemplateBinding Control.Padding}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" x:Name="PART_SelectedContentHost" />
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="TabControl.TabStripPlacement" Value="Bottom">
              <Setter TargetName="headerPanel" Property="Grid.Row" Value="1" />
              <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
              <Setter TargetName="RowDefinition0" Property="RowDefinition.Height" Value="*" />
              <Setter TargetName="RowDefinition1" Property="RowDefinition.Height" Value="Auto" />
            </Trigger>
            <Trigger Property="TabControl.TabStripPlacement" Value="Left">
              <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
              <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
              <Setter TargetName="headerPanel" Property="Grid.Column" Value="0" />
              <Setter TargetName="contentPanel" Property="Grid.Column" Value="1" />
              <Setter TargetName="ColumnDefinition0" Property="ColumnDefinition.Width" Value="Auto" />
              <Setter TargetName="ColumnDefinition1" Property="ColumnDefinition.Width" Value="*" />
              <Setter TargetName="RowDefinition0" Property="RowDefinition.Height" Value="*" />
              <Setter TargetName="RowDefinition1" Property="RowDefinition.Height" Value="0" />
            </Trigger>
            <Trigger Property="TabControl.TabStripPlacement" Value="Right">
              <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
              <Setter TargetName="contentPanel" Property="Grid.Row" Value="0" />
              <Setter TargetName="headerPanel" Property="Grid.Column" Value="1" />
              <Setter TargetName="contentPanel" Property="Grid.Column" Value="0" />
              <Setter TargetName="ColumnDefinition0" Property="ColumnDefinition.Width" Value="*" />
              <Setter TargetName="ColumnDefinition1" Property="ColumnDefinition.Width" Value="Auto" />
              <Setter TargetName="RowDefinition0" Property="RowDefinition.Height" Value="*" />
              <Setter TargetName="RowDefinition1" Property="RowDefinition.Height" Value="0" />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="templateRoot" Value="{DynamicResource Disabled.ForegroundColor}" Property="TextElement.Foreground" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Panel.Background" Value="{DynamicResource CloseButton.Static.Background}" />
    <Setter Property="Border.BorderThickness" Value="0" />
    <Setter Property="FrameworkElement.Width" Value="16" />
    <Setter Property="FrameworkElement.Margin" Value="0,0,2,0" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="FrameworkElement.VerticalAlignment" Value="Center" />
    <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
    <Setter Property="Control.HorizontalContentAlignment" Value="Center" />
    <Setter Property="Control.VerticalContentAlignment" Value="Center" />
    <Setter Property="Border.CornerRadius" Value="3" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" CornerRadius="{TemplateBinding Border.CornerRadius}" x:Name="border">
            <Path Margin="3" Fill="{DynamicResource CloseButton.Static.Foreground}" Stretch="Uniform" Focusable="False" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41z" x:Name="cross" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter Value="{DynamicResource CloseButton.MouseOver.Background}" Property="Panel.Background" />
              <Setter TargetName="cross" Value="{DynamicResource CloseButton.MouseOver.Foreground}" Property="Shape.Fill" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="True">
              <Setter Value="{DynamicResource CloseButton.Pressed.Background}" Property="Panel.Background" />
              <Setter TargetName="cross" Value="{DynamicResource CloseButton.Pressed.Foreground}" Property="Shape.Fill" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="AddButtonStyle" TargetType="{x:Type Button}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Panel.Background" Value="{DynamicResource AddButtonBackground}" />
    <Setter Property="Border.BorderBrush" Value="#00FFFFFF" />
    <Setter Property="Border.BorderThickness" Value="1" />
    <Setter Property="FrameworkElement.Margin" Value="2,1,1,1" />
    <Setter Property="Control.HorizontalContentAlignment" Value="Center" />
    <Setter Property="Control.VerticalContentAlignment" Value="Center" />
    <Setter Property="Border.CornerRadius" Value="3" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border BorderBrush="{TemplateBinding Border.BorderBrush}" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" SnapsToDevicePixels="true" CornerRadius="{TemplateBinding Border.CornerRadius}" x:Name="border">
            <Path Margin="3" Fill="{DynamicResource CloseButton.MouseOver.Foreground}" Stretch="Uniform" Focusable="False" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" Data="M19,13L13,13 13,19 11,19 11,13 5,13 5,11 11,11 11,5 13,5 13,11 19,11 19,13z" x:Name="plus" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter Value="{DynamicResource ClosableTabItem.MouseOver.Background}" Property="Panel.Background" />
              <Setter Value="{DynamicResource ClosableTabItem.MouseOver.Border}" Property="Border.BorderBrush" />
              <Setter TargetName="plus" Value="{DynamicResource CloseButton.MouseOver.Foreground}" Property="Shape.Fill" />
            </Trigger>
            <Trigger Property="ButtonBase.IsPressed" Value="True">
              <Setter Value="{DynamicResource ClosableTabItem.MouseOver.Background}" Property="Panel.Background" />
              <Setter Value="{DynamicResource ClosableTabItem.MouseOver.Border}" Property="Border.BorderBrush" />
              <Setter TargetName="plus" Value="{DynamicResource CloseButton.Pressed.Foreground}" Property="Shape.Fill" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type controls:ClosableTabControl}" TargetType="{x:Type controls:ClosableTabControl}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Border.BorderThickness" Value="0,0,0,0" />
    <Setter Property="Border.BorderBrush" Value="{DynamicResource ClosableTabItem.Static.Background}" />
    <Setter Property="Panel.Background" Value="{DynamicResource BackgroundBrush}" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabControl}">
          <Grid Background="{DynamicResource ClosableTabItem.Static.Background}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>
            <UniformGrid Grid.Row="0" Grid.Column="0" IsItemsHost="True" Rows="1" Background="{DynamicResource ClosableTabItem.Static.Background}" x:Name="HeaderPanel" />
            <Border Grid.Column="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ClosableTabItem.TopBorder}" />
            <Button Grid.Row="0" Grid.Column="1" Style="{DynamicResource AddButtonStyle}" x:Name="PART_Add" />
            <Border Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ClosableTabItem.Static.Border}" />
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BorderThickness="{TemplateBinding Border.BorderThickness}" Background="{TemplateBinding Panel.Background}" BorderBrush="{TemplateBinding Border.BorderBrush}" x:Name="Border">
              <ContentPresenter ContentSource="SelectedContent" x:Name="PART_SelectedContentHost" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="TabItemFocusVisual" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Rectangle StrokeThickness="0" Fill="#00FFFFFF" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <DropShadowEffect x:Key="ClosableTabItemShadow" BlurRadius="10" Color="Black" ShadowDepth="4" Direction="270" Opacity="{DynamicResource ClosableTabItem.ShadowOpacity}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" />
  <Style x:Key="{x:Type controls:ClosableTabItem}" TargetType="{x:Type controls:ClosableTabItem}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{DynamicResource TabItemFocusVisual}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource TabItem.Static.Foreground}" />
    <Setter Property="Control.Padding" Value="2,0,2,0" />
    <Setter Property="FrameworkElement.Height" Value="24" />
    <Setter Property="Border.BorderBrush" Value="{DynamicResource ClosableTabItem.Static.Border}" />
    <Setter Property="Panel.Background" Value="{DynamicResource ClosableTabItem.Static.Background}" />
    <Setter Property="Control.HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Control.VerticalContentAlignment" Value="Stretch" />
    <Setter Property="UIElement.AllowDrop" Value="True" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:ClosableTabItem}">
          <Grid>
            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ClosableTabItem.TopBorder}" x:Name="TopBorder" />
            <Border SnapsToDevicePixels="True" BorderThickness="0,0,0,1" Margin="0,1,0,0" CornerRadius="4,4,0,0" Background="{TemplateBinding Panel.Background}" BorderBrush="{TemplateBinding Border.BorderBrush}" x:Name="Bd" />
            <Border Margin="0,4,0,4" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource ClosableTabItem.SeparatorBorder}" x:Name="TabSeparatorBorder" />
            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Control.Padding}" HorizontalAlignment="Stretch" RecognizesAccessKey="True" SnapsToDevicePixels="True" VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" x:Name="Content">
              <ContentPresenter.Content>
                <controls:CenteredDockPanel Background="#00FFFFFF" x:Name="PART_Header">
                  <Ellipse DockPanel.Dock="Left" Width="8" Height="8" Margin="3,0,3,-2" HorizontalAlignment="Left" VerticalAlignment="Center" Stroke="{TemplateBinding controls:ClosableTabItem.TagBrush}" StrokeThickness="2">
                    <Ellipse.IsVisible>
                      <MultiBinding>
                        <MultiBinding.Converter>
                          <controls:TabEllipseVisibilityConverter />
                        </MultiBinding.Converter>
                        <Binding Path="TagBrush">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="TemplatedParent" />
                          </Binding.RelativeSource>
                        </Binding>
                        <Binding Path="IsDirty">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="TemplatedParent" />
                          </Binding.RelativeSource>
                        </Binding>
                      </MultiBinding>
                    </Ellipse.IsVisible>
                    <Ellipse.Fill>
                      <MultiBinding>
                        <MultiBinding.Converter>
                          <controls:TabEllipseFillBrushConverter />
                        </MultiBinding.Converter>
                        <Binding Path="TagBrush">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="TemplatedParent" />
                          </Binding.RelativeSource>
                        </Binding>
                        <Binding Path="IsDirty">
                          <Binding.RelativeSource>
                            <RelativeSource Mode="TemplatedParent" />
                          </Binding.RelativeSource>
                        </Binding>
                      </MultiBinding>
                    </Ellipse.Fill>
                  </Ellipse>
                  <Button DockPanel.Dock="Right" Style="{DynamicResource CloseButtonStyle}" Visibility="Collapsed" x:Name="PART_Close" />
                  <AdornerDecorator>
                    <controls:EditableTextBlock Height="22" Margin="0,1,0,1" Padding="0,2,0,2" HorizontalAlignment="Left" Value="{TemplateBinding HeaderedContentControl.Header}" x:Name="PART_Title" />
                  </AdornerDecorator>
                </controls:CenteredDockPanel>
              </ContentPresenter.Content>
            </ContentPresenter>
          </Grid>
          <ControlTemplate.Triggers>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Value="true">
                  <Condition.Binding>
                    <Binding Path="IsMouseOver">
                      <Binding.RelativeSource>
                        <RelativeSource Mode="TemplatedParent" />
                      </Binding.RelativeSource>
                    </Binding>
                  </Condition.Binding>
                </Condition>
                <Condition Value="false">
                  <Condition.Binding>
                    <Binding ElementName="PART_Title" Path="IsInEditMode" />
                  </Condition.Binding>
                </Condition>
              </MultiDataTrigger.Conditions>
              <Setter TargetName="PART_Close" Property="UIElement.Visibility" Value="Visible" />
            </MultiDataTrigger>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter TargetName="Bd" Value="{DynamicResource TabItemHotBackground}" Property="Panel.Background" />
              <Setter TargetName="TabSeparatorBorder" Property="UIElement.Visibility" Value="Hidden" />
            </Trigger>
            <Trigger Property="TabItem.IsSelected" Value="true">
              <Setter Property="Panel.ZIndex" Value="1" />
              <Setter TargetName="PART_Close" Property="UIElement.Visibility" Value="Visible" />
              <Setter TargetName="TabSeparatorBorder" Property="UIElement.Visibility" Value="Hidden" />
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.Selected.Background}" Property="Panel.Background" />
              <Setter TargetName="Bd" Property="Border.BorderThickness" Value="1,1,1,0" />
              <Setter TargetName="Bd" Property="FrameworkElement.Margin" Value="-1,0,0,0" />
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.Selected.Border}" Property="Border.BorderBrush" />
              <Setter Value="{DynamicResource TabItem.Selected.Foreground}" Property="TextElement.Foreground" />
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItemShadow}" Property="UIElement.Effect" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="TabItem.IsSelected" Value="false" />
                <Condition Property="UIElement.IsMouseOver" Value="true" />
              </MultiTrigger.Conditions>
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.MouseOver.Background}" Property="Panel.Background" />
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.MouseOver.Border}" Property="Border.BorderBrush" />
              <Setter TargetName="Bd" Property="Border.BorderThickness" Value="1,1,1,1" />
              <Setter TargetName="Bd" Property="FrameworkElement.Margin" Value="-1,0,0,0" />
            </MultiTrigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.Disabled.Background}" Property="Panel.Background" />
              <Setter TargetName="Bd" Value="{DynamicResource ClosableTabItem.Disabled.Border}" Property="Border.BorderBrush" />
              <Setter Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Property="TextElement.Foreground" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="ModernTabControlTabItemStyle" TargetType="{x:Type TabItem}" BasedOn="{StaticResource {x:Type TabItem}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Setter Property="FrameworkElement.FocusVisualStyle">
      <Setter.Value>
        <x:Null />
      </Setter.Value>
    </Setter>
    <Setter Property="FrameworkElement.Height" Value="30" />
    <Setter Property="Control.Padding" Value="16,2" />
    <Setter Property="TextElement.FontSize" Value="13" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabItem}">
          <Grid SnapsToDevicePixels="true" Background="#00FFFFFF" x:Name="templateRoot">
            <ContentPresenter ContentSource="Header" Focusable="False" Margin="{TemplateBinding Control.Padding}" RecognizesAccessKey="True" TextElement.FontWeight="Medium" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" x:Name="contentPresenter">
              <ContentPresenter.HorizontalAlignment>
                <Binding Path="HorizontalContentAlignment"><Binding.RelativeSource><RelativeSource AncestorType="{x:Type ItemsControl}" /></Binding.RelativeSource></Binding>
              </ContentPresenter.HorizontalAlignment>
              <ContentPresenter.VerticalAlignment>
                <Binding Path="VerticalContentAlignment"><Binding.RelativeSource><RelativeSource AncestorType="{x:Type ItemsControl}" /></Binding.RelativeSource></Binding>
              </ContentPresenter.VerticalAlignment>
            </ContentPresenter>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="TabItem.IsSelected" Value="true">
              <Setter TargetName="contentPresenter" Value="{DynamicResource SystemAccentBrush}" Property="TextElement.Foreground" />
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="contentPresenter" Value="{DynamicResource TabItem.Disabled.Foreground}" Property="TextElement.Foreground" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type controls:ModernTabControl}" TargetType="{x:Type controls:ModernTabControl}" BasedOn="{StaticResource {x:Type TabControl}}" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style.Resources>
      <ResourceDictionary>
        <Style x:Key="{x:Type TabPanel}" TargetType="{x:Type TabPanel}">
          <Setter Property="Panel.Background" Value="#00FFFFFF" />
        </Style>
        <Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}" BasedOn="{StaticResource ModernTabControlTabItemStyle}" />
      </ResourceDictionary>
    </Style.Resources>
    <Setter Property="Border.BorderThickness" Value="0,1,0,0" />
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabControl}">
          <Grid ClipToBounds="true" SnapsToDevicePixels="true" KeyboardNavigation.TabNavigation="Local" x:Name="templateRoot">
            <Grid.ColumnDefinitions>
              <ColumnDefinition x:Name="ColumnDefinition0" />
              <ColumnDefinition Width="0" x:Name="ColumnDefinition1" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" x:Name="RowDefinition0" />
              <RowDefinition Height="*" x:Name="RowDefinition1" />
